{% doc %}
  @prompt
    create a rich text section and give button in that section and give all customize settings for content allingement and fonts customize settings and name this section as rich text with button
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rich-text-with-button-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-rich-text-with-button__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-rich-text-with-button__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-rich-text-with-button__content-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    font-size: {{ block.settings.body_size }}px;
    color: {{ block.settings.body_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.content_spacing }}px 0;
  }

  .ai-rich-text-with-button__content-{{ ai_gen_id }} p {
    margin: 0 0 16px 0;
  }

  .ai-rich-text-with-button__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-rich-text-with-button__button-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.button_alignment }};
    margin-top: {{ block.settings.button_spacing }}px;
  }

  .ai-rich-text-with-button__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-style: {{ block.settings.button_font.style }};
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-rich-text-with-button__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-rich-text-with-button-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
    }

    .ai-rich-text-with-button__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-rich-text-with-button__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size_mobile }}px;
    }

    .ai-rich-text-with-button__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }
  }
{% endstyle %}

<rich-text-with-button-{{ ai_gen_id }}
  class="ai-rich-text-with-button-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-rich-text-with-button__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-rich-text-with-button__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.content != blank %}
      <div class="ai-rich-text-with-button__content-{{ ai_gen_id }}">
        {{ block.settings.content }}
      </div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <div class="ai-rich-text-with-button__button-wrapper-{{ ai_gen_id }}">
        <a
          href="{{ block.settings.button_link }}"
          class="ai-rich-text-with-button__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</rich-text-with-button-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Rich text with button",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Rich text with button"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Text content",
      "default": "<p>Use this section to create unique side-by-side layouts with various content blocks. Pair text with images, newsletter blocks, products, videos, testimonials and more.</p>"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn more"
    },
    {
