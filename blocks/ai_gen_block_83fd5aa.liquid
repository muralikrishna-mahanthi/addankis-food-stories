      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding on mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
