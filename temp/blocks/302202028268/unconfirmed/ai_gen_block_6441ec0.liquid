{% doc %}
  @prompt
    generate a marquee of single row and give me all the settings customizable by me and give padding settings for me and color of fonts and background color settings and boldness of text and all
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }

  .ai-marquee-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
  }

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ai-marquee-item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: 0 {{ block.settings.item_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  .ai-marquee-separator-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.separator_size }}px;
    height: {{ block.settings.separator_size }}px;
    background-color: {{ block.settings.separator_color }};
    border-radius: 50%;
    margin: 0 {{ block.settings.item_spacing }}px;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-marquee-container-{{ ai_gen_id }}:hover .ai-marquee-wrapper-{{ ai_gen_id }} {
    {% if block.settings.pause_on_hover %}
      animation-play-state: paused;
    {% endif %}
  }
{% endstyle %}

<marquee-block-{{ ai_gen_id }} class="ai-marquee-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-wrapper-{{ ai_gen_id }}">
    <div class="ai-marquee-content-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        <span class="ai-marquee-item-{{ ai_gen_id }}">{{ block.settings.marquee_text }}</span>
        {% if block.settings.show_separator %}
          <span class="ai-marquee-separator-{{ ai_gen_id }}"></span>
        {% endif %}
      {% endfor %}
    </div>
    <div class="ai-marquee-content-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        <span class="ai-marquee-item-{{ ai_gen_id }}">{{ block.settings.marquee_text }}</span>
        {% if block.settings.show_separator %}
          <span class="ai-marquee-separator-{{ ai_gen_id }}"></span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</marquee-block-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustSpeed();
      }

      adjustSpeed() {
        const wrapper = this.querySelector('.ai-marquee-wrapper-{{ ai_gen_id }}');
        if (wrapper) {
          const contentWidth = wrapper.scrollWidth / 2;
          const speed = {{ block.settings.animation_speed }};
          wrapper.style.animationDuration = speed + 's';
        }
      }
    }

    customElements.define('marquee-block-{{ ai_gen_id }}', MarqueeBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Marquee text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
