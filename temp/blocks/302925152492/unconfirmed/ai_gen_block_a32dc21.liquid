{% doc %}
  @prompt
    create section where one side should be video and another side should be text and give complete customize settings for both side and complete section settings give video only to upload from shopify and works correctly
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-video-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.container_padding_horizontal }}px;
  }

  .ai-video-text-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap_between_columns }}px;
    align-items: {{ block.settings.vertical_alignment }};
    {% if block.settings.layout == 'video_left' %}
      flex-direction: row;
    {% else %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-video-text-video-column-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.video_column_width }}%;
    max-width: {{ block.settings.video_column_width }}%;
  }

  .ai-video-text-text-column-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.text_padding_top }}px {{ block.settings.text_padding_horizontal }}px {{ block.settings.text_padding_bottom }}px;
  }

  .ai-video-text-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-video-text-video-wrapper-{{ ai_gen_id }} video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-text-video-placeholder-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-text-video-placeholder-{{ ai_gen_id }} svg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-video-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-text-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    color: {{ block.settings.heading_color }};
    line-height: {{ block.settings.heading_line_height }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-video-text-subheading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subheading_margin_bottom }}px;
    font-size: {{ block.settings.subheading_font_size }}px;
    font-weight: {{ block.settings.subheading_font_weight }};
    color: {{ block.settings.subheading_color }};
    line-height: {{ block.settings.subheading_line_height }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-video-text-description-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.description_margin_bottom }}px;
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: {{ block.settings.description_line_height }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-video-text-description-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-video-text-description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-video-text-button-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    {% if block.settings.text_alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% else %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-video-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-video-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-video-text-button-secondary-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_secondary_background_color }};
    color: {{ block.settings.button_secondary_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_secondary_border_color }};
  }

  .ai-video-text-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_background_color }};
    color: {{ block.settings.button_secondary_hover_text_color }};
    border-color: {{ block.settings.button_secondary_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-video-text-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-video-text-video-column-{{ ai_gen_id }} {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .ai-video-text-text-column-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_text_padding }}px 0;
    }

    .ai-video-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_font_size }}px;
    }

    .ai-video-text-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_subheading_font_size }}px;
    }

    .ai-video-text-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_description_font_size }}px;
    }

    .ai-video-text-button-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-video-text-button-{{ ai_gen_id }},
    .ai-video-text-button-secondary-{{ ai_gen_id }} {
      text-align: center;
    }
  }
{% endstyle %}

<video-text-section-{{ ai_gen_id }} class="ai-video-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-text-container-{{ ai_gen_id }}">
    <div class="ai-video-text-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-text-video-column-{{ ai_gen_id }}">
        <div class="ai-video-text-video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video != blank %}
            <video
              {% if block.settings.video_autoplay %}autoplay{% endif %}
              {% if block.settings.video_loop %}loop{% endif %}
              {% if block.settings.video_muted %}muted{% endif %}
              {% if block.settings.video_controls %}controls{% endif %}
              playsinline
              preload="metadata"
            >
              <source src="{{ block.settings.video.sources[1].url }}" type="{{ block.settings.video.sources[1].mime_type }}">
              Your browser does not support the video tag.
            </video>
          {% else %}
            <div class="ai-video-text-video-placeholder-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
              </svg>
              <div class="ai-video-text-empty-state-{{ ai_gen_id }}">
                Next, upload a video
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-video-text-text-column-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-video-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.subheading != blank %}
          <div class="ai-video-text-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-video-text-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}

        {% if block.settings.button_text != blank or block.settings.button_secondary_text != blank %}
          <div class="ai-video-text-button-wrapper-{{ ai_gen_id }}">
            {% if block.settings.button_text != blank %}
              <a href="{{ block.settings.button_link }}" class="ai-video-text-button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            {% endif %}

            {% if block.settings.button_secondary_text != blank %}
              <a href="{{ block.settings.button_secondary_link }}" class="ai-video-text-button-secondary-{{ ai_gen_id }}">
                {{ block.settings.button_secondary_text }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</video-text-section-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoTextSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('video');
        if (this.video) {
          this.setupVideoObserver();
        }
      }

      setupVideoObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && this.video.paused && this.video.hasAttribute('autoplay')) {
              this.video.play().catch(() => {});
            } else if (!entry.isIntersecting && !this.video.paused) {
              this.video.pause();
            }
          });
        }, options);

        observer.observe(this.video);
      }
    }

    customElements.define('video-text-section-{{ ai_gen_id }}', VideoTextSection{{ ai_gen_id }});
  })();
</script>

