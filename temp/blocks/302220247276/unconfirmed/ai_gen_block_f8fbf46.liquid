{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scroll-sections-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-scroll-sections__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-scroll-sections__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-scroll-sections__section-{{ ai_gen_id }} {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-scroll-sections__sticky-wrapper-{{ ai_gen_id }} {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-scroll-sections__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 1200px;
    opacity: 0;
    transition: opacity {{ block.settings.transition_duration }}s ease-in-out;
    pointer-events: none;
    text-align: center;
    z-index: 2;
  }

  .ai-scroll-sections__content-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-scroll-sections__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity {{ block.settings.transition_duration }}s ease-in-out;
    z-index: 1;
  }

  .ai-scroll-sections__background-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-scroll-sections__background-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity {{ block.settings.transition_duration }}s ease-in-out;
    z-index: 1;
  }

  .ai-scroll-sections__background-placeholder-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-scroll-sections__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-scroll-sections__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-scroll-sections__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 30px;
    line-height: 1.6;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-scroll-sections__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 15px 40px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-scroll-sections__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-scroll-sections__progress-{{ ai_gen_id }} {
    position: fixed;
    top: 50%;
    right: 30px;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 15px;
    z-index: 100;
  }

  .ai-scroll-sections__progress-dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.progress_inactive_color }};
    transition: all 0.3s ease;
    cursor: pointer;
    border: 2px solid {{ block.settings.progress_inactive_color }};
  }

  .ai-scroll-sections__progress-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.progress_active_color }};
    border-color: {{ block.settings.progress_active_color }};
    transform: scale(1.3);
  }

  @media screen and (max-width: 749px) {
    .ai-scroll-sections__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.6);
    }

    .ai-scroll-sections__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-scroll-sections__button-{{ ai_gen_id }} {
      padding: 12px 30px;
      font-size: calc({{ block.settings.button_text_size }}px * 0.9);
    }

    .ai-scroll-sections__progress-{{ ai_gen_id }} {
      right: 15px;
    }

    .ai-scroll-sections__progress-dot-{{ ai_gen_id }} {
      width: 10px;
      height: 10px;
    }
  }
{% endstyle %}

<scroll-sections-{{ ai_gen_id }} class="ai-scroll-sections-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-scroll-sections__wrapper-{{ ai_gen_id }}">
    <div class="ai-scroll-sections__container-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        <div class="ai-scroll-sections__section-{{ ai_gen_id }}" data-section-index="{{ i }}">
          {% if i == 1 %}
            <div class="ai-scroll-sections__sticky-wrapper-{{ ai_gen_id }}">
              {% for j in (1..4) %}
                {% liquid
                  assign bg_image_key = 'section_' | append: j | append: '_bg_image'
                  assign heading_key = 'section_' | append: j | append: '_heading'
                  assign text_key = 'section_' | append: j | append: '_text'
                  assign button_text_key = 'section_' | append: j | append: '_button_text'
                  assign button_link_key = 'section_' | append: j | append: '_button_link'
                  
                  assign bg_image = block.settings[bg_image_key]
                  assign heading = block.settings[heading_key]
                  assign text = block.settings[text_key]
                  assign button_text = block.settings[button_text_key]
                  assign button_link = block.settings[button_link_key]
                %}

                {% if bg_image %}
                  <img
                    src="{{ bg_image | image_url: width: 2000 }}"
                    alt="{{ bg_image.alt | escape }}"
                    loading="lazy"
                    class="ai-scroll-sections__background-{{ ai_gen_id }}"
                    data-section="{{ j }}"
                  >
                {% else %}
                  <div class="ai-scroll-sections__background-placeholder-{{ ai_gen_id }}" data-section="{{ j }}">
                    {{ 'hero-apparel-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                <div class="ai-scroll-sections__content-{{ ai_gen_id }}" data-section="{{ j }}">
                  {% if heading != blank %}
                    <h2 class="ai-scroll-sections__heading-{{ ai_gen_id }}">{{ heading }}</h2>
                  {% endif %}
                  
                  {% if text != blank %}
                    <div class="ai-scroll-sections__text-{{ ai_gen_id }}">{{ text }}</div>
                  {% endif %}
                  
                  {% if button_text != blank %}
                    {% if button_link != blank %}
                      <a href="{{ button_link }}" class="ai-scroll-sections__button-{{ ai_gen_id }}">
                        {{ button_text }}
                      </a>
                    {% else %}
                      <span class="ai-scroll-sections__button-{{ ai_gen_id }}" style="cursor: default;">
                        {{ button_text }}
                      </span>
                    {% endif %}
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if block.settings.show_progress %}
      <div class="ai-scroll-sections__progress-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          <div class="ai-scroll-sections__progress-dot-{{ ai_gen_id }}" data-dot="{{ i }}"></div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</scroll-sections-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollSections{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.sections = [];
        this.contents = [];
        this.backgrounds = [];
        this.dots = [];
        this.currentSection = 1;
      }

      connectedCallback() {
        this.sections = Array.from(this.querySelectorAll('.ai-scroll-sections__section-{{ ai_gen_id }}'));
        this.contents = Array.from(this.querySelectorAll('.ai-scroll-sections__content-{{ ai_gen_id }}'));
        this.backgrounds = Array.from(this.querySelectorAll('.ai-scroll-sections__background-{{ ai_gen_id }}, .ai-scroll-sections__background-placeholder-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-scroll-sections__progress-dot-{{ ai_gen_id }}'));
        
        this.setupScrollObserver();
        this.setupDotNavigation();
        this.activateSection(1);
      }

      setupScrollObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: [0, 0.25, 0.5, 0.75, 1]
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const sectionIndex = parseInt(entry.target.dataset.sectionIndex);
              
              if (entry.intersectionRatio > 0.3) {
                this.activateSection(sectionIndex);
              }
            }
          });
        }, options);

        this.sections.forEach(section => {
          observer.observe(section);
        });
      }

      setupDotNavigation() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            const targetSection = this.sections[index];
            if (targetSection) {
              targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          });
        });
      }

      activateSection(index) {
        if (this.currentSection === index) return;
        
        this.currentSection = index;

        this.contents.forEach(content => {
          const sectionNum = parseInt(content.dataset.section);
          if (sectionNum === index) {
            content.classList.add('active');
          } else {
            content.classList.remove('active');
          }
        });

        this.backgrounds.forEach(bg => {
          const sectionNum = parseInt(bg.dataset.section);
          if (sectionNum === index) {
            bg.classList.add('active');
          } else {
            bg.classList.remove('active');
          }
        });

        this.dots.forEach((dot, dotIndex) => {
          if (dotIndex + 1 === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('scroll-sections-{{ ai_gen_id }}', ScrollSections{{ ai_gen_id }});
  })();
</script>

