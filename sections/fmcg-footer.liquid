{% schema %}
{
  "name": "Premium FMCG Footer",
  "tag": "footer",
  "class": "section fmcg-footer",
  "settings": [
    {
      "type": "header",
      "content": "Footer Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#002e50"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Link/Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Logo Styling"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Logo Width (Desktop)",
      "default": 180
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "link_font",
      "label": "Links Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "link_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Link Font Size",
      "default": 16
    },
    {
      "type": "select",
      "id": "link_weight",
      "label": "Link Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "header",
      "content": "Sub-Footer Settings"
    },
    {
      "type": "checkbox",
      "id": "show_socials",
      "label": "Show Social Media Icons",
      "default": true
    },
    {
      "type": "link_list",
      "id": "sub_menu",
      "label": "Legal Links Menu",
      "info": "Appears horizontally at the bottom (Privacy, Terms, etc.)"
    },
    {
      "type": "textarea",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© PepsiCo 2026"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Link Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading (Optional)"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "checkbox",
          "id": "show_external_icon",
          "label": "Show External Link Icon (↗)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium FMCG Footer",
      "blocks": [
        { "type": "menu_column" },
        { "type": "menu_column" }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign link_font = section.settings.link_font
-%}

<style>
  {{ link_font | font_face: display: 'swap' }}

  .fmcg-footer-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 768px) {
    .fmcg-footer-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .ff-container {
    max-width: var(--page-width, 1440px);
    margin: 0 auto;
    padding: 0 20px;
  }

  .ff-top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 60px;
  }

  .ff-logo-col {
    flex: 0 0 100%;
  }

  @media screen and (min-width: 768px) {
    .ff-logo-col { flex: 0 0 {{ section.settings.logo_width }}px; }
  }

  .ff-logo-img {
    max-width: {{ section.settings.logo_width }}px;
    height: auto;
    display: block;
  }

  .ff-menu-cols {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    flex: 1;
    justify-content: flex-end;
  }

  .ff-col {
    flex: 0 0 calc(50% - 20px);
    min-width: 150px;
  }

  @media screen and (min-width: 1024px) {
    .ff-col { flex: 1; max-width: 250px; }
  }

  .ff-col-heading {
    font-family: {{ link_font.family }}, {{ link_font.fallback_families }};
    font-size: {{ section.settings.link_size }}px;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: none; 
  }

  .ff-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ff-list-item {
    margin-bottom: 12px;
  }

  .ff-list-link {
    font-family: {{ link_font.family }}, {{ link_font.fallback_families }};
    font-size: {{ section.settings.link_size }}px;
    font-weight: {{ section.settings.link_weight }};
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: opacity 0.2s ease;
  }

  .ff-list-link:hover { opacity: 0.7; }

  .ff-external-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
  }

  /* Bottom Row */
  .ff-bottom {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  @media screen and (min-width: 1024px) {
    .ff-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .ff-socials {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .ff-social-link {
    color: inherit;
    text-decoration: none;
    display: block;
    width: 20px;
    height: 20px;
    transition: transform 0.2s ease;
  }
  .ff-social-link:hover { transform: scale(1.1); }
  .ff-social-link svg { width: 100%; height: 100%; fill: currentColor; }

  .ff-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: center;
    font-family: {{ link_font.family }}, {{ link_font.fallback_families }};
    font-size: 13px;
    opacity: 0.9;
  }

  .ff-legal-link {
    color: inherit;
    text-decoration: none;
    font-weight: 600;
  }
  .ff-legal-link:hover { text-decoration: underline; }

  .ff-copyright {
    font-weight: 700;
  }

  .ff-dot {
    font-size: 24px;
    line-height: 1;
    color: #0076a9; /* Pepsi blue accent */
  }

  /* Decorative portal icon */
  .ff-portal {
    display: none;
  }
  @media screen and (min-width: 1200px) {
    .ff-portal {
      display: block;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #ffffff 0%, #0076a9 100%);
      opacity: 0.8;
    }
  }

</style>

<div class="fmcg-footer-{{ section.id }}">
  <div class="ff-container">
    
    <div class="ff-top">
      <div class="ff-logo-col">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | img_url: '400x' }}" 
               alt="{{ shop.name }}" 
               class="ff-logo-img"
               loading="lazy">
        {% else %}
          <h2 style="color:white; margin:0;">{{ shop.name }}</h2>
        {% endif %}
      </div>

      <div class="ff-menu-cols">
        {% for block in section.blocks %}
          <div class="ff-col" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}
              <div class="ff-col-heading">{{ block.settings.heading | escape }}</div>
            {% endif %}
            
            {% if block.settings.menu != blank %}
              <ul class="ff-list">
                {% for link in block.settings.menu.links %}
                  <li class="ff-list-item">
                    <a href="{{ link.url }}" class="ff-list-link">
                      {{ link.title | escape }}
                      {% if block.settings.show_external_icon %}
                        <svg class="ff-external-icon" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
                      {% endif %}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="ff-bottom">
      <div class="ff-socials">
        {% if section.settings.show_socials %}
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" class="ff-social-link" aria-label="Facebook">
              <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3V2z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank or settings.social_x_link != blank -%}
             <a href="{{ settings.social_x_link | default: settings.social_twitter_link }}" class="ff-social-link" aria-label="X">
              <svg viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.932zm-1.292 19.49h2.039L6.486 3.24H4.298l13.311 17.403z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_youtube_link != blank -%}
            <a href="{{ settings.social_youtube_link }}" class="ff-social-link" aria-label="YouTube">
              <svg viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33zM9.75 15.02V8.48L15.45 11.75l-5.7 3.27z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_linkedin_link != blank -%}
            <a href="{{ settings.social_linkedin_link }}" class="ff-social-link" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 2a2 2 0 110 4 2 2 0 010-4z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="ff-social-link" aria-label="Instagram">
              <svg viewBox="0 0 24 24"><path d="M12 2c2.717 0 3.056.01 4.122.058 1.066.048 1.79.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.637.417 1.361.465 2.427.048 1.066.058 1.405.058 4.122s-.01 3.056-.058 4.122c-.048 1.066-.217 1.79-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.637.247-1.361.417-2.427.465-1.066.048-1.405.058-4.122.058s-3.056-.01-4.122-.058c-1.066-.048-1.79-.217-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.637-.417-1.361-.465-2.427-.048-1.066-.058-1.405-.058-4.122s.01-3.056.058-4.122c.048-1.066.217-1.79.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.58c.637-.247 1.361-.417 2.427-.465C8.944 2.01 9.283 2 12 2zm0 5a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6zm5-2.5a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5z"/></svg>
            </a>
          {%- endif -%}
        {% endif %}
      </div>

      <div class="ff-legal">
        {% if section.settings.copyright_text != blank %}
          <span class="ff-copyright">{{ section.settings.copyright_text }}</span>
        {% endif %}

        {% if section.settings.sub_menu != blank %}
          {% for link in section.settings.sub_menu.links %}
            <a href="{{ link.url }}" class="ff-legal-link">{{ link.title | escape }}</a>
          {% endfor %}
        {% endif %}
      </div>

      <div class="ff-portal"></div>
    </div>

  </div>
</div>
