{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .asfpl-hero--{{ section.id }} {
    position: relative;
    width: 100%;
    height: {{ section.settings.desktop_height }};
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.content_alignment_desktop }};
    overflow: hidden;
    color: {{ section.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .asfpl-hero--{{ section.id }} {
      height: {{ section.settings.mobile_height }};
      justify-content: {{ section.settings.content_alignment_mobile }};
    }
  }

  .asfpl-hero__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .asfpl-hero__media img,
  .asfpl-hero__media video,
  .asfpl-hero__media iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .asfpl-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .asfpl-hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: {{ section.settings.text_alignment }};
  }

  @media screen and (min-width: 750px) {
    .asfpl-hero__content {
      padding: 0 5rem;
    }
  }

  .asfpl-hero__heading {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: {{ section.settings.text_color }};
    display: flex;
    flex-wrap: wrap;
    justify-content: {{ section.settings.text_alignment == 'center' ? 'center' : (section.settings.text_alignment == 'right' ? 'flex-end' : 'flex-start') }};
    align-items: center;
    gap: 0.3em;
  }

  .asfpl-hero__dynamic-word-wrapper {
    display: inline-block;
    position: relative;
    text-align: left;
    white-space: nowrap;
  }

  .asfpl-hero__dynamic-word {
    display: none;
    {%- if section.settings.enable_gradient -%}
      background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ec4899);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    {%- else -%}
      color: {{ section.settings.dynamic_word_color }};
    {%- endif -%}
  }

  .asfpl-hero__dynamic-word.active {
    display: inline-block;
    animation: asfplHeroPopIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  @keyframes asfplHeroPopIn {
    0% { opacity: 0; transform: translateY(20px) scale(0.9); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  .asfpl-hero__description {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    max-width: 800px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.9 }};
  }

  {% if section.settings.text_alignment == 'left' %}
    .asfpl-hero__description { margin-left: 0; }
  {% elsif section.settings.text_alignment == 'right' %}
    .asfpl-hero__description { margin-right: 0; }
  {% endif %}

  .asfpl-hero__buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: {{ section.settings.text_alignment == 'center' ? 'center' : (section.settings.text_alignment == 'right' ? 'flex-end' : 'flex-start') }};
  }

  .asfpl-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 50px;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
  }

  .asfpl-hero__btn--primary {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.overlay_color }};
    border: 2px solid {{ section.settings.text_color }};
  }

  .asfpl-hero__btn--primary:hover {
    background: transparent;
    color: {{ section.settings.text_color }};
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
  }

  .asfpl-hero__btn--secondary {
    background: transparent;
    color: {{ section.settings.text_color }};
    border: 2px solid {{ section.settings.text_color }};
  }

  .asfpl-hero__btn--secondary:hover {
    background: {{ section.settings.text_color }};
    color: {{ section.settings.overlay_color }};
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(255,255,255,0.15);
  }
{%- endstyle -%}

<div class="asfpl-hero asfpl-hero--{{ section.id }} section-{{ section.id }}-padding">
  
  <div class="asfpl-hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '2000x' }}
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2500 | image_tag: loading: 'lazy', widths: '500, 750, 1000, 1500, 2000, 2500' }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="asfpl-hero__overlay"></div>

  <div class="asfpl-hero__content">
    {%- if section.settings.heading != blank or section.settings.dynamic_words != blank -%}
      <h1 class="asfpl-hero__heading">
        {%- if section.settings.heading != blank -%}
          <span>{{ section.settings.heading }}</span>
        {%- endif -%}
        
        {%- if section.settings.dynamic_words != blank -%}
          {%- assign words = section.settings.dynamic_words | split: ',' -%}
          <span class="asfpl-hero__dynamic-word-wrapper" id="AsfplDynamicWords-{{ section.id }}">
            {%- for word in words -%}
              <span class="asfpl-hero__dynamic-word {% if forloop.first %}active{% endif %}">{{ word | strip }}</span>
            {%- endfor -%}
          </span>
        {%- endif -%}
      </h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="asfpl-hero__description">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    <div class="asfpl-hero__buttons">
      {%- if section.settings.button_1_label != blank -%}
        <a href="{{ section.settings.button_1_link }}" class="asfpl-hero__btn asfpl-hero__btn--primary">
          {{ section.settings.button_1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.button_2_label != blank -%}
        <a href="{{ section.settings.button_2_link }}" class="asfpl-hero__btn asfpl-hero__btn--secondary">
          {{ section.settings.button_2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    const containerId = 'AsfplDynamicWords-{{ section.id }}';
    const speed = {{ section.settings.animation_speed | default: 2000 }};

    function init() {
      const wrapper = document.getElementById(containerId);
      if (!wrapper) return;
      
      if (wrapper.dataset.intervalId) {
        clearInterval(parseInt(wrapper.dataset.intervalId));
      }

      const words = wrapper.querySelectorAll('.asfpl-hero__dynamic-word');
      if (words.length <= 1) return;

      let currentIndex = 0;
      words.forEach(w => w.classList.remove('active'));
      words[0].classList.add('active');

      const intervalId = setInterval(() => {
        words[currentIndex].classList.remove('active');
        currentIndex = (currentIndex + 1) % words.length;
        words[currentIndex].classList.add('active');
      }, speed);

      wrapper.dataset.intervalId = intervalId;
    }

    document.addEventListener('DOMContentLoaded', init);
    // Fallback if readyState is already loaded when script executes
    if (document.readyState !== 'loading') init();
    
    // Shopify Theme Editor specific events
    document.addEventListener('shopify:section:load', (e) => {
      if (e.detail.sectionId === '{{ section.id }}') {
        init();
      }
    });
    
    document.addEventListener('shopify:section:unload', (e) => {
      if (e.detail.sectionId === '{{ section.id }}') {
        const wrapper = document.getElementById(containerId);
        if (wrapper && wrapper.dataset.intervalId) {
          clearInterval(parseInt(wrapper.dataset.intervalId));
        }
      }
    });
  })();
</script>

{% schema %}
{
  "name": "ASFPL Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image",
      "info": "Displays if no video is selected."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background Video",
      "info": "Overrides the background image. Recommends native Shopify hosted video for best performance."
    },
    {
      "type": "header",
      "content": "Overlay styling"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 50
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Static Heading",
      "default": "Food and Drinks to"
    },
    {
      "type": "textarea",
      "id": "dynamic_words",
      "label": "Dynamic Words",
      "info": "Comma-separated list of words to animate e.g. Smile About, Crunch, Savor",
      "default": "Smile About, Crunch, Savor, Sip"
    },
    {
      "type": "checkbox",
      "id": "enable_gradient",
      "label": "Enable Gradient on Dynamic Words",
      "default": false
    },
    {
      "type": "color",
      "id": "dynamic_word_color",
      "label": "Dynamic Word Color",
      "info": "Used if gradient is disabled",
      "default": "#3b82f6"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "min": 1000,
      "max": 5000,
      "step": 500,
      "unit": "ms",
      "label": "Word Animation Speed",
      "default": 2000
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Experience the taste and energy of our iconic brands, delicious innovations, and the smiles we serve with every sip and bite.</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "General Text Color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Call To Actions"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Primary Button Label",
      "default": "Our Brands"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Secondary Button Label",
      "default": "Partner With Us"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Dimensions & Layout"
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Desktop Height",
      "options": [
        { "value": "50vh", "label": "Small (50vh)" },
        { "value": "75vh", "label": "Medium (75vh)" },
        { "value": "100vh", "label": "Full Screen (100vh)" }
      ],
      "default": "100vh"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile Height",
      "options": [
        { "value": "50vh", "label": "Small" },
        { "value": "75vh", "label": "Medium" },
        { "value": "100vh", "label": "Full Screen" }
      ],
      "default": "75vh"
    },
    {
      "type": "select",
      "id": "content_alignment_desktop",
      "label": "Content Box Vertical Alignment (Desktop)",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_alignment_mobile",
      "label": "Content Box Vertical Alignment (Mobile)",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "ASFPL Hero",
      "category": "Image"
    }
  ]
}
{% endschema %}
