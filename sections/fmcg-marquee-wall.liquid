{%- style -%}
  .fmcg-marquee-wall-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --fs-desktop: {{ section.settings.fs_desktop }}rem;
    --fs-mobile: {{ section.settings.fs_mobile }}rem;
    --font-weight: {{ section.settings.fw }};
    --letter-spacing: {{ section.settings.ls }}px;
    --row-gap: {{ section.settings.row_gap | default: 20 }}px;
    --section-min-height: {{ section.settings.section_height | default: '100vh' }};

    background-color: var(--bg-color);
    width: 100%;
    min-height: var(--section-min-height);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    padding: 6rem 0;
    position: relative;
    user-select: none;
    {% if section.settings.font_family != blank %}
      font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
      {{ section.settings.font_family | font_face: display: 'swap' }}
    {% endif %}
  }

  .fmcg-marquee-wall__row {
    white-space: nowrap;
    display: flex;
    align-items: center;
    line-height: 1;
    margin-bottom: var(--row-gap);
    will-change: transform;
    text-transform: {{ section.settings.text_transform }};
    pointer-events: none;
    width: fit-content;
  }

  .fmcg-marquee-wall__row:last-child { margin-bottom: 0; }

  .fmcg-marquee-wall__item {
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
  }

  .fmcg-marquee-wall__text {
    font-size: var(--fs-mobile);
    font-weight: var(--font-weight);
    letter-spacing: var(--letter-spacing);
  }

  @media screen and (min-width: 750px) {
    .fmcg-marquee-wall__text {
      font-size: var(--fs-desktop);
    }
  }

  .fmcg-marquee-wall__logo {
    height: 1em;
    width: auto;
    margin: 0 1rem;
    object-fit: contain;
    display: inline-block;
  }

  /* Per-Row Colors */
  .fmcg-marquee-wall__row-1 { color: {{ section.settings.color_1 }}; }
  .fmcg-marquee-wall__row-2 { color: {{ section.settings.color_2 }}; }
  .fmcg-marquee-wall__row-3 { color: {{ section.settings.color_3 }}; }
  .fmcg-marquee-wall__row-4 { color: {{ section.settings.color_4 }}; }

  /* Outline Style */
  .fmcg-marquee-wall--outline .fmcg-marquee-wall__text {
    -webkit-text-stroke: 1.5px currentColor;
    color: transparent;
  }
  .fmcg-marquee-wall--outline .fmcg-marquee-wall__logo {
    filter: drop-shadow(0 0 1px currentColor);
  }

{%- endstyle -%}

<div class="fmcg-marquee-wall-{{ section.id }} {% if section.settings.use_outline %}fmcg-marquee-wall--outline{% endif %}" id="FmcgMarqueeWall-{{ section.id }}">
  
  {%- for i in (1..4) -%}
    {%- capture row_text_key -%}text_{{ i }}{%- endcapture -%}
    {%- capture row_dir_key -%}dir_{{ i }}{%- endcapture -%}
    {%- capture row_logo_key -%}logo_{{ i }}{%- endcapture -%}
    
    {%- assign row_text = section.settings[row_text_key] -%}
    {%- assign row_logo = section.settings[row_logo_key] -%}
    {%- assign row_words = row_text | split: ',' -%}
    
    <div class="fmcg-marquee-wall__row fmcg-marquee-wall__row-{{ i }}" 
         data-direction="{{ section.settings[row_dir_key] }}"
         id="Row-{{ section.id }}-{{ i }}">
      {%- comment -%}Render many items to ensure seamless loop{%- endcomment -%}
      {%- for j in (1..15) -%}
        {%- for word in row_words -%}
          <div class="fmcg-marquee-wall__item">
            <span class="fmcg-marquee-wall__text">{{ word | strip }}</span>
            {%- if row_logo != blank -%}
              {{ row_logo | image_url: width: 400 | image_tag: class: 'fmcg-marquee-wall__logo', loading: 'lazy' }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  {%- endfor -%}

</div>

<script>
  (function() {
    const section = document.getElementById('FmcgMarqueeWall-{{ section.id }}');
    if (!section) return;

    const rows = section.querySelectorAll('.fmcg-marquee-wall__row');
    const intensity = {{ section.settings.scroll_speed | default: 0.8 }};
    let lastScrollY = window.scrollY;
    let ticking = false;

    function upgradeMarquee() {
      const scrolled = window.scrollY;
      
      rows.forEach((row, index) => {
        const direction = row.dataset.direction === 'left' ? -1 : 1;
        // Optimization: Use translate3d for hardware acceleration
        // Using modulo 2000 to keep the offset in a manageable range for the repeated items
        const offset = (scrolled * intensity * direction) % 3000;
        row.style.transform = `translate3d(${offset}px, 0, 0)`;
      });
      
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(upgradeMarquee);
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    
    // Initial call
    upgradeMarquee();

    // Re-patching on Shopify Theme Editor events
    document.addEventListener('shopify:section:load', upgradeMarquee);
  })();
</script>

{% schema %}
{
  "name": "FMCG Marquee Wall",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Extreme Typography"
    },
    { "type": "font_picker", "id": "font_family", "label": "Font Family", "default": "assistant_n4" },
    { "type": "range", "id": "fs_desktop", "label": "Desktop Size (rem)", "min": 2, "max": 20, "step": 0.5, "default": 8 },
    { "type": "range", "id": "fs_mobile", "label": "Mobile Size (rem)", "min": 1, "max": 10, "step": 0.5, "default": 3.5 },
    { "type": "select", "id": "fw", "label": "Font Weight", "options": [{"value":"400","label":"Normal"},{"value":"700","label":"Bold"},{"value":"900","label":"Black 900 (Extra Bold)"}], "default": "900" },
    { "type": "range", "id": "ls", "label": "Letter Spacing (px)", "min": -10, "max": 30, "step": 1, "default": -2 },
    { "type": "select", "id": "text_transform", "label": "Text Transform", "options": [{"value":"none","label":"None"},{"value":"uppercase","label":"UPPERCASE"}], "default": "uppercase" },
    { "type": "range", "id": "row_gap", "label": "Vertical Row Gap", "min": 0, "max": 100, "step": 4, "default": 20 },
    { "type": "select", "id": "section_height", "label": "Min Section Height", "options": [{"value":"50vh","label":"Small"},{"value":"100vh","label":"Full Screen"}], "default": "100vh" },
    {
      "type": "header",
      "content": "Global Styles"
    },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "checkbox", "id": "use_outline", "label": "Enable Outline (Ghost) Mode", "default": false },
    { "type": "range", "id": "scroll_speed", "label": "Scroll Animation Intensity", "min": 0.1, "max": 3.0, "step": 0.1, "default": 1.0 },
    {
      "type": "header",
      "content": "Row 1 Configuration"
    },
    { "type": "textarea", "id": "text_1", "label": "Row 1 Text (comma separated)", "default": "ORGANIC, HEALTH, WEALTH, TASTE" },
    { "type": "image_picker", "id": "logo_1", "label": "Row 1 Logo" },
    { "type": "color", "id": "color_1", "label": "Row 1 Color", "default": "#000000" },
    { "type": "select", "id": "dir_1", "label": "Row 1 Direction", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    {
      "type": "header",
      "content": "Row 2 Configuration"
    },
    { "type": "textarea", "id": "text_2", "label": "Row 2 Text", "default": "CRUNCH, SIP, SAVOR, SNACK" },
    { "type": "image_picker", "id": "logo_2", "label": "Row 2 Logo" },
    { "type": "color", "id": "color_2", "label": "Row 2 Color", "default": "#000000" },
    { "type": "select", "id": "dir_2", "label": "Row 2 Direction", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "right" },
    {
      "type": "header",
      "content": "Row 3 Configuration"
    },
    { "type": "textarea", "id": "text_3", "label": "Row 3 Text", "default": "NATURAL, PURE, CLEAN, BOLD" },
    { "type": "image_picker", "id": "logo_3", "label": "Row 3 Logo" },
    { "type": "color", "id": "color_3", "label": "Row 3 Color", "default": "#000000" },
    { "type": "select", "id": "dir_3", "label": "Row 3 Direction", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    {
      "type": "header",
      "content": "Row 4 Configuration"
    },
    { "type": "textarea", "id": "text_4", "label": "Row 4 Text", "default": "DELICIOUS, ICONIC, FRESH, GOOD" },
    { "type": "image_picker", "id": "logo_4", "label": "Row 4 Logo" },
    { "type": "color", "id": "color_4", "label": "Row 4 Color", "default": "#000000" },
    { "type": "select", "id": "dir_4", "label": "Row 4 Direction", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "right" }
  ],
  "presets": [
    {
      "name": "FMCG Marquee Wall"
    }
  ]
}
{% endschema %}
