        { "type": "word", "settings": { "text": "YUM", "color": "#f2a900", "row_number": "2" } },
        { "type": "word", "settings": { "text": "SUSTAIN", "color": "#4b8b20", "row_number": "2" } },
        { "type": "word", "settings": { "text": "SAVOR", "color": "#f2a900", "row_number": "3" } },
        { "type": "word", "settings": { "text": "INNOVATE", "color": "#4b8b20", "row_number": "3" } },
        { "type": "word", "settings": { "text": "CRUNCH", "color": "#0077c8", "row_number": "4" } },
        { "type": "word", "settings": { "text": "SNACK", "color": "#f2a900", "row_number": "4" } }
      ]
    }
  ]
}
