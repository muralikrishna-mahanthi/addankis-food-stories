{%- style -%}
  {%- if section.settings.font_family != blank -%}
    {{ section.settings.font_family | font_face: display: 'swap' }}
  {%- endif -%}

  .fmcg-marquee-wall-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --fs-desktop: {{ section.settings.fs_desktop }}rem;
    --fs-mobile: {{ section.settings.fs_mobile | divided_by: 10.0 }}rem;
    --font-weight: {{ section.settings.fw }};
    --letter-spacing: {{ section.settings.ls }}px;
    --line-height: {{ section.settings.line_height | divided_by: 100.0 }};
    --row-gap: {{ section.settings.row_gap | default: 0 }}px;
    --item-gap: {{ section.settings.item_gap | divided_by: 10.0 }}rem;
    --image-scale: {{ section.settings.image_scale | divided_by: 100.0 }}em;
    --image-radius: {{ section.settings.image_radius | divided_by: 100.0 }}em;
    --section-min-height: {{ section.settings.section_height | default: '100vh' }};

    background-color: var(--bg-color);
    width: 100%;
    min-height: var(--section-min-height);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    padding: 6rem 0;
    position: relative;
    user-select: none;
    {% if section.settings.font_family != blank %}
      font-family: {{ section.settings.font_family.family }}, {{ section.settings.font_family.fallback_families }};
    {% endif %}
  }

  .fmcg-marquee-wall__row {
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: var(--item-gap);
    margin-bottom: var(--row-gap);
    will-change: transform;
    text-transform: {{ section.settings.text_transform }};
    pointer-events: none;
    width: fit-content;
    backface-visibility: hidden;
    transform-style: preserve-3d;
  }

  .fmcg-marquee-wall__row:last-child { margin-bottom: 0; }

  .fmcg-marquee-wall__row-items,
  .fmcg-marquee-wall__group {
    display: flex;
    align-items: center;
    gap: var(--item-gap);
  }

  .fmcg-marquee-wall__item {
    display: flex;
    align-items: center;
    gap: var(--item-gap);
    font-size: var(--fs-mobile);
  }

  @media screen and (min-width: 750px) {
    .fmcg-marquee-wall__item {
      font-size: var(--fs-desktop);
    }
  }

  .fmcg-marquee-wall__text {
    font-weight: var(--font-weight);
    letter-spacing: var(--letter-spacing);
    line-height: var(--line-height);
  }

  .fmcg-marquee-wall__img {
    height: var(--image-scale) !important;
    width: auto !important;
    max-width: none !important;
    margin: 0;
    object-fit: cover;
    border-radius: var(--image-radius);
    display: block !important;
  }

{%- endstyle -%}

<div class="fmcg-marquee-wall-{{ section.id }}" id="FmcgMarqueeWall-{{ section.id }}">
  
  {%- for i in (1..4) -%}
    {%- capture row_dir_key -%}dir_{{ i }}{%- endcapture -%}
    
    <div class="fmcg-marquee-wall__row fmcg-marquee-wall__row-{{ i }}" 
         data-direction="{{ section.settings[row_dir_key] }}"
         id="Row-{{ section.id }}-{{ i }}">
      
      {%- capture row_content -%}
        {%- for block in section.blocks -%}
          {%- assign row_num = block.settings.row_number | plus: 0 -%}
          {%- if row_num == i -%}
            <div class="fmcg-marquee-wall__item" {{ block.shopify_attributes }}>
              
              <span class="fmcg-marquee-wall__text" style="color: {{ block.settings.color }};">
                {{ block.settings.text | strip }}
              </span>
              
              {%- if block.settings.inline_image != blank -%}
                {{ block.settings.inline_image | image_url: height: 800 | image_tag: class: 'fmcg-marquee-wall__img', loading: 'lazy' }}
              {%- endif -%}
              
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- if row_content != blank -%}
        <div class="fmcg-marquee-wall__row-items">
          {%- for j in (1..4) -%}
            <div class="fmcg-marquee-wall__group">{{ row_content }}</div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="fmcg-marquee-wall__item">
          <span class="fmcg-marquee-wall__text" style="opacity:0.3;">Add 'Word' blocks to Row {{ i }}</span>
        </div>
      {%- endif -%}
    </div>
  {%- endfor -%}

</div>

<script>
  (function() {
    const section = document.getElementById('FmcgMarqueeWall-{{ section.id }}');
    if (!section) return;

    const rowEls = section.querySelectorAll('.fmcg-marquee-wall__row');
    const intensity = {{ section.settings.scroll_speed | divided_by: 10.0 | default: 1.0 }};
    const autoSpeed = {{ section.settings.auto_speed | default: 30 }} / 60; 
    const lerpFactor = {{ section.settings.lerp_factor | divided_by: 100.0 | default: 0.1 }};
    
    let targetScrollY = window.scrollY;
    let currentScrollValue = window.scrollY;
    let lastScrollValue = window.scrollY;
    
    const rows = [...rowEls].map(row => {
      const group = row.querySelector('.fmcg-marquee-wall__group');
      return {
        el: row,
        groupEl: group,
        width: group ? group.offsetWidth : 3000,
        dir: row.dataset.direction === 'left' ? -1 : 1,
        pos: Math.random() * 1000 
      };
    });

    if (typeof ResizeObserver !== 'undefined') {
      const ro = new ResizeObserver((entries) => {
        entries.forEach(entry => {
          const row = rows.find(r => r.groupEl === entry.target);
          if (row && entry.target.offsetWidth > 0) {
            row.width = entry.target.offsetWidth;
          }
        });
      });
      rows.forEach(r => {
        if (r.groupEl) ro.observe(r.groupEl);
      });
    }
    
    function updatePositions() {
      currentScrollValue += (targetScrollY - currentScrollValue) * lerpFactor;
      const scrollDelta = currentScrollValue - lastScrollValue;
      
      rows.forEach((r) => {
        r.pos += (autoSpeed * r.dir) + (scrollDelta * intensity * r.dir);
        
        const wrapWidth = r.width;
        if (wrapWidth > 0) {
          r.pos = ((r.pos % wrapWidth) + wrapWidth) % wrapWidth;
          r.el.style.transform = `translate3d(${-r.pos}px, 0, 0)`;
        }
      });
      
      lastScrollValue = currentScrollValue;
      requestAnimationFrame(updatePositions);
    }

    const onScroll = () => {
      targetScrollY = window.scrollY;
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    requestAnimationFrame(updatePositions);

    document.addEventListener('shopify:section:load', (e) => {
      if(e.target.contains(section)){
        targetScrollY = window.scrollY;
        currentScrollValue = window.scrollY;
        lastScrollValue = window.scrollY;
      }
    });

  })();
</script>

{% schema %}
{
  "name": "FMCG Marquee Wall",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Extreme Typography"
    },
    { "type": "font_picker", "id": "font_family", "label": "Font Family", "default": "assistant_n4" },
    { "type": "range", "id": "fs_desktop", "label": "Desktop Size (rem)", "min": 2, "max": 50, "step": 1, "default": 8 },
    { "type": "range", "id": "fs_mobile", "label": "Mobile Size (rem)", "min": 10, "max": 300, "step": 5, "default": 35, "info": "10 = 1.0rem, 35 = 3.5rem" },
    { "type": "select", "id": "fw", "label": "Font Weight", "options": [{"value":"100","label":"100 - Thin"},{"value":"200","label":"200 - Extra Light"},{"value":"300","label":"300 - Light"},{"value":"400","label":"400 - Normal"},{"value":"500","label":"500 - Medium"},{"value":"600","label":"600 - Semi Bold"},{"value":"700","label":"700 - Bold"},{"value":"800","label":"800 - Extra Bold"},{"value":"900","label":"900 - Black"}], "default": "900" },
    { "type": "range", "id": "ls", "label": "Letter Spacing (px)", "min": -10, "max": 30, "step": 1, "default": -2 },
    { "type": "select", "id": "text_transform", "label": "Text Transform", "options": [{"value":"none","label":"None"},{"value":"uppercase","label":"UPPERCASE"}], "default": "uppercase" },
    { "type": "range", "id": "line_height", "label": "Typography Line-Height", "min": 50, "max": 200, "step": 10, "default": 90, "info": "50 = 0.5, 90 = 0.9. Tighten to pack lines closer." },
    {
      "type": "header",
      "content": "Layout & Dynamic Spacing"
    },
    { "type": "range", "id": "row_gap", "label": "Vertical Row Gap", "min": 0, "max": 100, "step": 2, "default": 0, "info": "Space beneath each horizontal row." },
    { "type": "range", "id": "item_gap", "label": "Horizontal Gap", "min": 0, "max": 100, "step": 5, "default": 5, "info": "0 = 0rem, 5 = 0.5rem. Packing distance." },
    { "type": "range", "id": "image_scale", "label": "Image Height Ratio", "min": 50, "max": 150, "step": 5, "default": 75, "info": "75 = 0.75. Matches Uppercase Cap-height natively." },
    { "type": "range", "id": "image_radius", "label": "Image Border Radius", "min": 0, "max": 100, "step": 5, "default": 20, "info": "20 = 0.2em" },
    {
      "type": "header",
      "content": "Animation Physics"
    },
    { "type": "range", "id": "scroll_speed", "label": "Scroll Intensity", "min": 0, "max": 50, "step": 1, "default": 15, "info": "15 = 1.5x. Violent acceleration/reversal mapped." },
    { "type": "range", "id": "auto_speed", "label": "Base Speed", "min": 0, "max": 300, "step": 5, "default": 40, "info": "Linear glide speed when not scrolling." },
    { "type": "range", "id": "lerp_factor", "label": "LERP Smoothness", "min": 1, "max": 50, "step": 1, "default": 6, "info": "6 = 0.06. Momentum fade deceleration rate." },
    {
      "type": "header",
      "content": "Row Alignment Vectors"
    },
    { "type": "select", "id": "dir_1", "label": "Row 1", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "select", "id": "dir_2", "label": "Row 2", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "right" },
    { "type": "select", "id": "dir_3", "label": "Row 3", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "select", "id": "dir_4", "label": "Row 4", "options": [{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "right" },
    {
      "type": "header",
      "content": "Background"
    },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "select", "id": "section_height", "label": "Min Section Height", "options": [{"value":"50vh","label":"Small"},{"value":"100vh","label":"Full Screen"}], "default": "100vh" }
  ],
  "blocks": [
    {
      "type": "word",
      "name": "Custom Word",
      "settings": [
        { "type": "text", "id": "text", "label": "Word", "default": "AHHH" },
        { "type": "color", "id": "color", "label": "Word Color", "default": "#0077c8" },
        { "type": "image_picker", "id": "inline_image", "label": "Inline Photo", "info": "Displays as a matching-size photo identically adjacent to this word." },
        { "type": "select", "id": "row_number", "label": "Row Allocation", "options": [{"value":"1","label":"Row 1"},{"value":"2","label":"Row 2"},{"value":"3","label":"Row 3"},{"value":"4","label":"Row 4"}], "default": "1" }
