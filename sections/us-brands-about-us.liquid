    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#1a1a1a" },
    { "type": "range", "id": "left_heading_size", "label": "Left Heading Size", "min": 2, "max": 8, "step": 0.5, "unit": "rem", "default": 4.5 },
    { "type": "header", "content": "Timeline Animation" },
    { "type": "color", "id": "line_light_color", "label": "Line/Dot Inactive Color", "default": "#e5e5e5" },
    { "type": "color", "id": "line_active_color", "label": "Line/Dot Active Color", "default": "#6394FF" },
    { "type": "range", "id": "dot_size", "label": "Timeline Dot size", "min": 6, "max": 30, "step": 2, "unit": "px", "default": 16 },
    { "type": "range", "id": "point_size", "label": "Point Text Size", "min": 1, "max": 4, "step": 0.1, "unit": "rem", "default": 1.8 },
    { "type": "header", "content": "Layout Spacing" },
    { "type": "range", "id": "container_width", "label": "Container Width", "min": 1000, "max": 1600, "step": 50, "default": 1400 },
    { "type": "range", "id": "pt_desktop", "label": "Top Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pb_desktop", "label": "Bottom Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pt_mobile", "label": "Top Padding (Mobile)", "min": 0, "max": 100, "step": 5, "default": 50 },
    { "type": "range", "id": "pb_mobile", "label": "Bottom Padding (Mobile)", "min": 0, "max": 100, "step": 5, "default": 50 }
  ],
  "blocks": [
    {
      "type": "left_heading",
      "name": "Left Heading",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading Text", "default": "Meaning behind the brand" }
      ]
    },
    {
      "type": "left_image",
      "name": "Left Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "right_point",
      "name": "Story Point (Right)",
      "settings": [
        { "type": "text", "id": "text", "label": "Point Text", "default": "Inspired by the symbolism of the swan" }
      ]
    }
  ],
  "presets": [
    {
      "name": "US Brands About Us",
      "blocks": [
        { "type": "left_heading", "settings": { "title": "Meaning behind the brand" } },
        { "type": "right_point", "settings": { "text": "Inspired by the symbolism of the swan" } },
        { "type": "right_point", "settings": { "text": "A commitment to crystalline purity." } },
        { "type": "right_point", "settings": { "text": "Luxury clinical wellness at its peak." } }
      ]
    }
  ]
}
{% endschema %}
