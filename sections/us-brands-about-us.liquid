{%- style -%}
  /* Section Base Styles */
  #UsBrandsAbout-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_desktop }}px 0 {{ section.settings.pb_desktop }}px;
    position: relative;
    /* Large min-height to provide scroll "runway" */
    min-height: 250vh; 
  }

  @media screen and (max-width: 749px) {
    #UsBrandsAbout-{{ section.id }} {
      padding: {{ section.settings.pt_mobile }}px 0 {{ section.settings.pb_mobile }}px;
      min-height: auto; /* Standard scroll for mobile */
    }
  }

  .us-brands-about__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    flex-direction: row;
    position: relative;
    align-items: flex-start;
  }

  /* Split Logic - Both are Sticky for 'Stationary' feel */
  .us-brands-about__left,
  .us-brands-about__right {
    position: sticky;
    top: 25rem; /* Centered in viewport */
    height: auto;
  }

  .us-brands-about__left {
    flex: 0 0 {{ section.settings.split_ratio }}%;
    padding-right: 6rem;
  }

  .us-brands-about__right {
    flex: 1;
    padding-left: 6rem;
    border-left: 2px solid {{ section.settings.line_light_color }};
  }

  @media screen and (max-width: 749px) {
    .us-brands-about__container {
      flex-direction: column;
      padding: 0 2rem;
    }
    .us-brands-about__left,
    .us-brands-about__right {
      position: relative;
      top: 0;
      flex: 0 0 100%;
      padding: 0;
      border: none;
    }
    .us-brands-about__right {
      padding-top: 4rem;
    }
  }

  /* Point Styling - Stacked Vertically */
  .us-brands-about__point-list {
    display: flex;
    flex-direction: column;
    gap: 8rem; /* Regular spacing on desktop */
  }

  @media screen and (max-width: 749px) {
    .us-brands-about__point-list {
      gap: 3rem;
    }
  }

  .us-brands-about__point {
    position: relative;
    opacity: 0.2; /* Ghosted initial state */
    transform: translateY(10px);
    transition: transform 0.6s ease, opacity 0.4s ease;
  }

  /* Dot Style - Anchored to Static Line */
  .us-brands-about__dot {
    position: absolute;
    left: -6.1rem;
    top: 0.5rem;
    transform: translateX(-50%);
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    background: {{ section.settings.line_light_color }};
    border-radius: 50%;
    z-index: 3;
    transition: background 0.4s ease, transform 0.4s ease;
  }

  .us-brands-about__point.is-active .us-brands-about__dot {
    background: {{ section.settings.line_active_color }};
    transform: translateX(-50%) scale(1.3);
  }

  .us-brands-about__point-text {
    font-size: {{ section.settings.point_size }}rem;
    font-weight: 600;
    line-height: 1.3;
    color: {{ section.settings.text_color }};
    max-width: 600px;
    transition: color 0.4s ease;
  }

  /* Progress Line Mask */
  .us-brands-about__progress-line {
    position: absolute;
    left: -2px;
    top: 0;
    width: 2px;
    height: 0;
    background: {{ section.settings.line_active_color }};
    z-index: 2;
    transition: height 0.1s linear;
  }
{%- endstyle -%}

<section id="UsBrandsAbout-{{ section.id }}" class="us-brands-about">
  <div class="us-brands-about__container">
    
    <!-- Left Side: Sticky Visuals -->
    <div class="us-brands-about__left">
      {%- for block in section.blocks -%}
        {%- if block.type == 'left_heading' -%}
          <div class="us-brands-about__left-item" {{ block.shopify_attributes }}>
            <h2 class="us-brands-about__left-heading">{{ block.settings.title }}</h2>
          </div>
        {%- elsif block.type == 'left_image' -%}
          <div class="us-brands-about__left-item" {{ block.shopify_attributes }}>
            <div class="us-brands-about__left-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Right Side: Sticky Container with Point List -->
    <div class="us-brands-about__right">
      <div class="us-brands-about__progress-line" id="ProgressLine-{{ section.id }}"></div>
      
      <div class="us-brands-about__point-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'right_point' -%}
            <div class="us-brands-about__point js-about-point" 
                 data-index="{{ forloop.index0 }}"
                 {{ block.shopify_attributes }}>
              <div class="us-brands-about__dot"></div>
              <div class="us-brands-about__point-text">
                {{ block.settings.text }}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('UsBrandsAbout-{{ section.id }}');
    if (!section) return;

    const progressLine = section.querySelector('#ProgressLine-{{ section.id }}');
    const points = section.querySelectorAll('.js-about-point');
    const container = section.querySelector('.us-brands-about__container');

    const updateStickyStack = () => {
      // For mobile, we use standard visibility
      if (window.innerWidth < 750) {
        points.forEach(point => {
          const rect = point.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.8) {
            point.style.opacity = '1';
            point.classList.add('is-active');
          }
        });
        return;
      }

      // Desktop Sticky Logic
      const sectionRect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      
      // Calculate Scroll Progress through the section (0 to 1)
      const scrollStart = sectionRect.top;
      const totalScrollArea = section.offsetHeight - viewportHeight;
      let progress = (-scrollStart) / totalScrollArea;
      progress = Math.max(0, Math.min(1, progress));

      // 1. Update Global Progress Line
      progressLine.style.height = (progress * 100) + '%';

      // 2. Map Progress to Individual Points
      const pointCount = points.length;
      points.forEach((point, i) => {
        // Each point gets a 'stage' of the progress (e.g. 0-0.33, 0.33-0.66, etc)
        const step = 1 / pointCount;
        const start = i * step;
        const end = (i + 1) * step;

        // One-Way Persistence: If we've passed the start, stay visible
        if (progress >= start) {
          // Inner progress for that specific point's fade (short window for snap feel)
          const pointProgress = (progress - start) / (step * 0.5); 
          const targetOpacity = Math.max(parseFloat(point.style.opacity) || 0.2, Math.min(1, pointProgress));
          
          point.style.opacity = targetOpacity;
          
          if (targetOpacity >= 0.95) {
            point.classList.add('is-active');
            point.style.transform = 'translateY(0)';
          }
        }
      });
    };

    window.addEventListener('scroll', updateStickyStack);
    window.addEventListener('resize', updateStickyStack);
    updateStickyStack(); // Init
  })();
</script>

{% schema %}
{
  "name": "US Brands About Us",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "range", "id": "split_ratio", "label": "Split Ratio (Left Side %)", "min": 30, "max": 70, "step": 5, "default": 40 },
