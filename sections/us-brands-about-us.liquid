{% schema %}
{
  "name": "US Brands About Us",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "range", "id": "split_ratio", "label": "Split Ratio (Left Side %)", "min": 30, "max": 70, "step": 5, "default": 40 },
    { "type": "range", "id": "runway_height", "label": "Scroll Depth Intensity", "min": 100, "max": 500, "step": 50, "unit": "vh", "default": 300 },
    { "type": "header", "content": "Visuals" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#1a1a1a" },
    { "type": "header", "content": "Timeline Animation" },
    { "type": "color", "id": "line_light_color", "label": "Line/Dot Inactive Color", "default": "#e5e5e5" },
    { "type": "color", "id": "line_active_color", "label": "Line/Dot Active Color", "default": "#6394FF" },
    { "type": "range", "id": "dot_size", "label": "Timeline Dot size", "min": 6, "max": 40, "step": 2, "unit": "px", "default": 16 },
    { "type": "header", "content": "Layout Spacing" },
    { "type": "range", "id": "container_width", "label": "Container Width", "min": 1000, "max": 1600, "step": 50, "default": 1400 },
    { "type": "range", "id": "pt_desktop", "label": "Top Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pb_desktop", "label": "Bottom Padding (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 }
  ],
  "blocks": [
    {
      "type": "left_heading",
      "name": "Left Heading",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading Text", "default": "Meaning behind the brand" },
        { "type": "header", "content": "Typography" },
        { "type": "font_picker", "id": "heading_font", "label": "Font Family", "default": "assistant_n4" },
        { "type": "range", "id": "heading_size", "label": "Font Size", "min": 1, "max": 10, "step": 0.1, "unit": "rem", "default": 4.5 },
        { "type": "color", "id": "heading_color", "label": "Font Color", "default": "#1a1a1a" },
        { "type": "select", "id": "heading_weight", "label": "Font Weight", "options": [
          { "value": "300", "label": "Light" },
          { "value": "400", "label": "Regular" },
          { "value": "500", "label": "Medium" },
          { "value": "600", "label": "Semi-Bold" },
          { "value": "700", "label": "Bold" },
          { "value": "800", "label": "Extra-Bold" },
          { "value": "900", "label": "Black" }
        ], "default": "700" },
        { "type": "select", "id": "heading_style", "label": "Font Style", "options": [
          { "value": "normal", "label": "Normal" },
          { "value": "italic", "label": "Italic" }
        ], "default": "normal" },
        { "type": "range", "id": "heading_line_height", "label": "Line Height", "min": 0.8, "max": 2, "step": 0.1, "default": 1.1 },
        { "type": "range", "id": "heading_letter_spacing", "label": "Letter Spacing", "min": -5, "max": 10, "step": 0.2, "unit": "px", "default": 0 },
        { "type": "header", "content": "Alignment & Spacing" },
        { "type": "select", "id": "heading_alignment", "label": "Text Alignment", "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ], "default": "left" },
        { "type": "range", "id": "heading_pt", "label": "Padding Top", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0 },
        { "type": "range", "id": "heading_pb", "label": "Padding Bottom", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0 },
        { "type": "range", "id": "heading_pl", "label": "Padding Left", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0 },
        { "type": "range", "id": "heading_pr", "label": "Padding Right", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0 }
      ]
    },
    {
      "type": "left_image",
      "name": "Left Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "right_point",
      "name": "Right Story Point",
      "settings": [
        { "type": "text", "id": "text", "label": "Point Text", "default": "Inspired by the symbolism of the swan" },
        { "type": "header", "content": "Typography" },
        { "type": "font_picker", "id": "rp_font", "label": "Font Family", "default": "assistant_n4" },
        { "type": "range", "id": "rp_size", "label": "Font Size", "min": 1, "max": 4, "step": 0.1, "unit": "rem", "default": 2.2 },
        { "type": "color", "id": "rp_color", "label": "Font Color", "default": "#1a1a1a" },
        { "type": "select", "id": "rp_weight", "label": "Font Weight", "options": [
          { "value": "300", "label": "Light" },
          { "value": "400", "label": "Regular" },
          { "value": "500", "label": "Medium" },
          { "value": "600", "label": "Semi-Bold" },
          { "value": "700", "label": "Bold" },
          { "value": "800", "label": "Extra-Bold" },
          { "value": "900", "label": "Black" }
        ], "default": "700" },
        { "type": "select", "id": "rp_style", "label": "Font Style", "options": [
          { "value": "normal", "label": "Normal" },
          { "value": "italic", "label": "Italic" }
        ], "default": "normal" },
        { "type": "range", "id": "rp_lh", "label": "Line Height", "min": 0.8, "max": 2, "step": 0.1, "default": 1.25 },
        { "type": "range", "id": "rp_ls", "label": "Letter Spacing", "min": -5, "max": 10, "step": 0.2, "unit": "px", "default": 0 },
        { "type": "header", "content": "Alignment & Spacing" },
        { "type": "select", "id": "rp_align", "label": "Text Alignment", "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ], "default": "left" },
        { "type": "range", "id": "rp_pt", "label": "Padding Top", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0 },
        { "type": "range", "id": "rp_pb", "label": "Padding Bottom", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0 },
        { "type": "range", "id": "rp_pl", "label": "Padding Left", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0 },
        { "type": "range", "id": "rp_pr", "label": "Padding Right", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 0 }
      ]
    }
  ],
  "presets": [
    {
      "name": "US Brands About Us",
      "blocks": [
        { "type": "left_heading", "settings": { "title": "Meaning behind the brand" } },
        { "type": "right_point", "settings": { "text": "Inspired by the symbolism of the swan" } },
        { "type": "right_point", "settings": { "text": "A commitment to crystalline purity." } },
        { "type": "right_point", "settings": { "text": "Luxury clinical wellness at its peak." } }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'left_heading' -%}
      {%- assign heading_font = block.settings.heading_font -%}
      {%- if heading_font != blank -%}
        {{ heading_font | font_face: font_display: 'swap' }}
      {%- endif -%}
    {%- elsif block.type == 'right_point' -%}
      {%- assign rp_font = block.settings.rp_font -%}
      {%- if rp_font != blank -%}
        {{ rp_font | font_face: font_display: 'swap' }}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  /* Section Base Styles */
  #UsBrandsAbout-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_desktop }}px 0 {{ section.settings.pb_desktop }}px;
    position: relative;
    height: {{ section.settings.runway_height }}vh;
  }

  @media screen and (max-width: 749px) {
    #UsBrandsAbout-{{ section.id }} {
      height: auto;
      min-height: auto;
      padding: 60px 0;
    }
  }

  .us-brands-about__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    flex-direction: row;
    position: relative;
    height: 100%;
    align-items: flex-start;
  }

  .us-brands-about__left,
  .us-brands-about__right {
    position: sticky;
    top: 20vh;
    height: auto;
    max-height: 80vh;
  }

  .us-brands-about__left {
    flex: 0 0 {{ section.settings.split_ratio }}%;
    padding-right: 8rem;
  }

  .us-brands-about__right {
    flex: 1;
    padding-left: 8rem;
    border-left: 2px solid {{ section.settings.line_light_color }};
  }

  @media screen and (max-width: 749px) {
    .us-brands-about__container {
      flex-direction: column;
      padding: 0 2rem;
      height: auto;
    }
    .us-brands-about__left,
    .us-brands-about__right {
      position: relative;
      top: 0;
      flex: 0 0 100%;
      padding: 0;
      border: none;
      max-height: none;
    }
    .us-brands-about__right {
      padding-top: 4rem;
    }
  }

  .us-brands-about__point-list {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  .us-brands-about__point {
    position: relative;
    opacity: 0;
    transform: translateY(15px);
    transition: transform 0.6s ease, opacity 0.5s ease;
  }

  .us-brands-about__dot {
    position: absolute;
    left: -8.1rem;
    top: 0.5rem;
    transform: translateX(-50%);
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    background: {{ section.settings.line_light_color }};
    border-radius: 50%;
    z-index: 3;
    transition: background 0.4s ease, transform 0.4s ease;
  }

  .us-brands-about__point.is-active .us-brands-about__dot {
    background: {{ section.settings.line_active_color }};
    transform: translateX(-50%) scale(1.3);
  }

  .us-brands-about__point-text {
    max-width: 600px;
  }

  .us-brands-about__progress-line {
    position: absolute;
    left: -2px;
    top: 0;
    width: 2px;
    height: 0;
    background: {{ section.settings.line_active_color }};
    z-index: 2;
  }
{%- endstyle -%}

<section id="UsBrandsAbout-{{ section.id }}" class="us-brands-about">
  <div class="us-brands-about__container">

    <!-- Left Side: Sticky Visuals -->
    <div class="us-brands-about__left">
      {%- for block in section.blocks -%}
        {%- if block.type == 'left_heading' -%}
          <div class="us-brands-about__left-item" {{ block.shopify_attributes }}>
            {%- liquid
               assign h_font = block.settings.heading_font
               assign h_size = block.settings.heading_size | default: 4.5
               assign h_color = block.settings.heading_color | default: '#1a1a1a'
               assign h_weight = block.settings.heading_weight | default: '700'
               assign h_style = block.settings.heading_style | default: 'normal'
               assign h_align = block.settings.heading_alignment | default: 'left'
               assign h_lh = block.settings.heading_line_height | default: 1.1
               assign h_ls = block.settings.heading_letter_spacing | default: 0
               assign h_pt = block.settings.heading_pt | default: 0
               assign h_pb = block.settings.heading_pb | default: 0
               assign h_pl = block.settings.heading_pl | default: 0
               assign h_pr = block.settings.heading_pr | default: 0
            -%}
            <h2 class="us-brands-about__left-heading" style="
              {% if h_font != blank %}font-family: {{ h_font.family }}, {{ h_font.fallback_families }};{% endif %}
              font-size: {{ h_size }}rem;
              color: {{ h_color }};
              font-weight: {{ h_weight }};
              font-style: {{ h_style }};
              text-align: {{ h_align }};
              line-height: {{ h_lh }};
              letter-spacing: {{ h_ls }}px;
              padding: {{ h_pt }}px {{ h_pr }}px {{ h_pb }}px {{ h_pl }}px;
              margin: 0;
            ">
              {{ block.settings.title }}
            </h2>
          </div>
        {%- elsif block.type == 'left_image' -%}
          <div class="us-brands-about__left-item" {{ block.shopify_attributes }}>
            <div class="us-brands-about__left-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Right Side: Sticky Point List -->
    <div class="us-brands-about__right">
      <div class="us-brands-about__progress-line" id="ProgressLine-{{ section.id }}"></div>

      <div class="us-brands-about__point-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'right_point' -%}
            <div class="us-brands-about__point js-about-point" {{ block.shopify_attributes }}>
              <div class="us-brands-about__dot"></div>
              <div class="us-brands-about__point-text" style="
                {%- if block.settings.rp_font != blank -%}font-family: {{ block.settings.rp_font.family }}, {{ block.settings.rp_font.fallback_families }};{%- endif -%}
                font-size: {{ block.settings.rp_size | default: 2.2 }}rem;
                color: {{ block.settings.rp_color | default: '#1a1a1a' }};
                font-weight: {{ block.settings.rp_weight | default: '700' }};
                font-style: {{ block.settings.rp_style | default: 'normal' }};
                text-align: {{ block.settings.rp_align | default: 'left' }};
                line-height: {{ block.settings.rp_lh | default: 1.25 }};
                letter-spacing: {{ block.settings.rp_ls | default: 0 }}px;
                padding: {{ block.settings.rp_pt | default: 0 }}px {{ block.settings.rp_pr | default: 0 }}px {{ block.settings.rp_pb | default: 0 }}px {{ block.settings.rp_pl | default: 0 }}px;
              ">
                {{ block.settings.text }}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('UsBrandsAbout-{{ section.id }}');
    if (!section) return;

    const progressLine = section.querySelector('#ProgressLine-{{ section.id }}');
    const points = section.querySelectorAll('.js-about-point');
    if (!points.length) return;

    const updateScrollytelling = () => {
      if (window.innerWidth < 750) {
        points.forEach(point => {
          const rect = point.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.8) {
            point.style.opacity = '1';
            point.style.transform = 'translateY(0)';
            point.classList.add('is-active');
          }
        });
        return;
      }

      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      const totalScroll = section.offsetHeight - viewportHeight;
      const currentScroll = -rect.top;
      let progress = currentScroll / totalScroll;
      progress = Math.max(0, Math.min(1, progress));

      const pointCount = points.length;
      const firstDot = points[0].querySelector('.us-brands-about__dot');
      const lastDot = points[pointCount - 1].querySelector('.us-brands-about__dot');
      const startLinePos = firstDot.offsetTop + (firstDot.offsetHeight / 2);
      const endLinePos = lastDot.offsetTop + (lastDot.offsetHeight / 2);
      const totalLineRange = endLinePos - startLinePos;

      points.forEach((point, i) => {
        const pointStart = i / pointCount;
        let pointProgress = (progress - (pointStart - 0.1)) / 0.2;
        let targetOpacity = Math.min(1, Math.max(0, pointProgress));
        point.style.opacity = targetOpacity;
        if (targetOpacity >= 0.8) {
          point.classList.add('is-active');
          point.style.transform = 'translateY(0)';
        } else {
          point.classList.remove('is-active');
          point.style.transform = `translateY(${Math.max(0, 15 - targetOpacity * 15)}px)`;
        }
      });

      const currentLineDepth = startLinePos + (progress * totalLineRange);
      progressLine.style.height = currentLineDepth + 'px';
    };

    window.addEventListener('scroll', updateScrollytelling);
    window.addEventListener('resize', updateScrollytelling);
    updateScrollytelling();
  })();
</script>
