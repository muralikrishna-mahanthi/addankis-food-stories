{%- style -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'left_heading' -%}
      {%- assign h_font_obj = block.settings.heading_font -%}
      {%- if h_font_obj != blank -%}
        {{ h_font_obj | font_face: font_display: 'swap' }}
      {%- endif -%}
    {%- elsif block.type == 'right_point' -%}
      {%- assign rp_font_obj = block.settings.rp_font -%}
      {%- if rp_font_obj != blank -%}
        {{ rp_font_obj | font_face: font_display: 'swap' }}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  /* ── Section wrapper ── */
  #UsBrandsAbout-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_desktop }}px 0 {{ section.settings.pb_desktop }}px;
    position: relative;
    height: {{ section.settings.runway_height }}vh;
  }
  @media screen and (max-width: 749px) {
    #UsBrandsAbout-{{ section.id }} {
      height: auto;
      padding: 60px 0;
    }
  }

  /* ── Outer container ── */
  .uba-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    height: 100%;
  }

  /* ── Left sticky panel ── */
  .uba-left-{{ section.id }} {
    flex: 0 0 {{ section.settings.split_ratio }}%;
    max-width: {{ section.settings.split_ratio }}%;
    position: sticky;
    top: 20vh;
    padding-right: 6rem;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* ── Right sticky panel: flex-row with timeline + content ── */
  .uba-right-{{ section.id }} {
    flex: 1;
    position: sticky;
    top: 20vh;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
  }

  /*
   * THE TIMELINE LINE
   * width: 2px, align-self: stretch = grows to match content height
   * position: relative = gives fill div a proper containing block
   * background = the GREY base line colour
   */
  .uba-line-{{ section.id }} {
    width: 2px;
    flex-shrink: 0;
    align-self: stretch;
    position: relative;
    background: {{ section.settings.line_light_color }};
    border-radius: 2px;
  }

  /*
   * THE DARK FILL
   * position: absolute inside position: relative parent = bulletproof
   * grows from height:0 to height:100% via JS
   */
  .uba-fill-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0;
    background: {{ section.settings.line_active_color }};
    border-radius: 2px;
    will-change: height;
  }

  /* ── Story points column ── */
  .uba-content-{{ section.id }} {
    flex: 1;
    padding-left: 4rem;
  }

  .uba-points-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  .uba-point-{{ section.id }} {
    position: relative;
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.5s ease, transform 0.6s ease;
  }

  /* dot sits in the 4rem gap between the line and text */
  .uba-dot-{{ section.id }} {
    position: absolute;
    left: -4.1rem;
    top: 0.5rem;
    transform: translateX(-50%);
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    background: {{ section.settings.line_light_color }};
    border-radius: 50%;
    z-index: 3;
    transition: background 0.4s ease, transform 0.4s ease;
  }
  .uba-point-{{ section.id }}.is-active .uba-dot-{{ section.id }} {
    background: {{ section.settings.line_active_color }};
    transform: translateX(-50%) scale(1.3);
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .uba-container-{{ section.id }} {
      flex-direction: column;
      padding: 0 2rem;
      height: auto;
    }
    .uba-left-{{ section.id }},
    .uba-right-{{ section.id }} {
      position: relative;
      top: 0;
      width: 100%;
      max-width: 100%;
      flex: 0 0 100%;
      padding: 0;
    }
    .uba-right-{{ section.id }} {
      padding-top: 3rem;
    }
    .uba-line-{{ section.id }} {
      display: none;
    }
    .uba-content-{{ section.id }} {
      padding-left: 0;
    }
    .uba-dot-{{ section.id }} {
      display: none;
    }
    .uba-point-{{ section.id }} {
      opacity: 1 !important;
      transform: none !important;
    }
  }
{%- endstyle -%}

<section id="UsBrandsAbout-{{ section.id }}" class="us-brands-about">
  <div class="uba-container-{{ section.id }}">

    <!-- ── LEFT PANEL ── -->
    <div class="uba-left-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'left_heading' -%}
          <div {{ block.shopify_attributes }}>
            {%- liquid
              assign h_font = block.settings.heading_font
              assign h_size = block.settings.heading_size | default: 4.5
              assign h_color = block.settings.heading_color | default: '#1a1a1a'
              assign h_weight = block.settings.heading_weight | default: '700'
              assign h_style = block.settings.heading_style | default: 'normal'
              assign h_align = block.settings.heading_alignment | default: 'left'
              assign h_lh = block.settings.heading_line_height | default: 1.1
              assign h_ls = block.settings.heading_letter_spacing | default: 0
              assign h_pt = block.settings.heading_pt | default: 0
              assign h_pb = block.settings.heading_pb | default: 0
              assign h_pl = block.settings.heading_pl | default: 0
              assign h_pr = block.settings.heading_pr | default: 0
            -%}
            <h2 style="{% if h_font != blank %}font-family:{{ h_font.family }},{{ h_font.fallback_families }};{% endif %}font-size:{{ h_size }}rem;color:{{ h_color }};font-weight:{{ h_weight }};font-style:{{ h_style }};text-align:{{ h_align }};line-height:{{ h_lh }};letter-spacing:{{ h_ls }}px;padding:{{ h_pt }}px {{ h_pr }}px {{ h_pb }}px {{ h_pl }}px;margin:0;">
              {{ block.settings.title }}
            </h2>
          </div>
        {%- elsif block.type == 'left_image' -%}
          {%- liquid
            assign img_align = block.settings.img_align | default: 'left'
            assign img_width = block.settings.img_width | default: 100
            assign img_maxh = block.settings.img_max_height | default: 500
            assign img_fit = block.settings.img_object_fit | default: 'cover'
            assign img_pt = block.settings.img_pt | default: 0
            assign img_pb = block.settings.img_pb | default: 0
            assign img_pl = block.settings.img_pl | default: 0
            assign img_pr = block.settings.img_pr | default: 0
          -%}
          <div {{ block.shopify_attributes }} style="text-align:{{ img_align }};padding:{{ img_pt }}px {{ img_pr }}px {{ img_pb }}px {{ img_pl }}px;">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', style: 'width:' | append: img_width | append: '%;max-width:100%;max-height:' | append: img_maxh | append: 'px;object-fit:' | append: img_fit | append: ';height:auto;display:inline-block;' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- ── RIGHT PANEL (flex-row: line + content) ── -->
    <div class="uba-right-{{ section.id }}">

      <!-- THE LINE (grey base + growing dark fill) -->
      <div class="uba-line-{{ section.id }}">
        <div class="uba-fill-{{ section.id }}" id="UbaFill-{{ section.id }}"></div>
      </div>

      <!-- STORY POINTS -->
      <div class="uba-content-{{ section.id }}">
        <div class="uba-points-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'right_point' -%}
              <div class="uba-point-{{ section.id }} js-uba-point-{{ section.id }}" {{ block.shopify_attributes }}>
                <div class="uba-dot-{{ section.id }}"></div>
                <div style="{% if block.settings.rp_font != blank %}font-family:{{ block.settings.rp_font.family }},{{ block.settings.rp_font.fallback_families }};{% endif %}font-size:{{ block.settings.rp_size | default: 2.2 }}rem;color:{{ block.settings.rp_color | default: '#1a1a1a' }};font-weight:{{ block.settings.rp_weight | default: '700' }};font-style:{{ block.settings.rp_style | default: 'normal' }};text-align:{{ block.settings.rp_align | default: 'left' }};line-height:{{ block.settings.rp_lh | default: 1.3 }};letter-spacing:{{ block.settings.rp_ls | default: 0 }}px;padding:{{ block.settings.rp_pt | default: 0 }}px {{ block.settings.rp_pr | default: 0 }}px {{ block.settings.rp_pb | default: 0 }}px {{ block.settings.rp_pl | default: 0 }}px;">
                  {{ block.settings.text }}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  var sectionEl = document.getElementById('UsBrandsAbout-{{ section.id }}');
  if (!sectionEl) return;
  var fillEl = document.getElementById('UbaFill-{{ section.id }}');
  var lineEl = sectionEl.querySelector('.uba-line-{{ section.id }}');
  var points = sectionEl.querySelectorAll('.js-uba-point-{{ section.id }}');
  if (!points.length) return;

  function onScroll() {
    /* Mobile: simple fade-in on viewport entry */
    if (window.innerWidth < 750) {
      points.forEach(function(p) {
        if (p.getBoundingClientRect().top < window.innerHeight * 0.85) {
          p.style.opacity = '1';
          p.style.transform = 'translateY(0)';
          p.classList.add('is-active');
        }
      });
      return;
    }

    var rect = sectionEl.getBoundingClientRect();
    var totalScroll = sectionEl.offsetHeight - window.innerHeight;
    if (totalScroll <= 0) return;
    var progress = Math.max(0, Math.min(1, -rect.top / totalScroll));

    /* Story points: staggered fade-in tied to scroll progress */
    points.forEach(function(p, i) {
      var start = i / points.length;
      var t = Math.min(1, Math.max(0, (progress - (start - 0.1)) / 0.2));
      p.style.opacity = t;
      if (t >= 0.8) {
        p.classList.add('is-active');
        p.style.transform = 'translateY(0)';
      } else {
        p.classList.remove('is-active');
        p.style.transform = 'translateY(' + ((1 - t) * 15) + 'px)';
      }
    });

    /* Timeline fill: progress × line height */
    if (fillEl && lineEl) {
      fillEl.style.height = Math.round(progress * lineEl.offsetHeight) + 'px';
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);
  onScroll();
})();
</script>

