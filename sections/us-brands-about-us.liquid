{%- style -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'left_heading' -%}
      {%- assign h_font_obj = block.settings.heading_font -%}
      {%- if h_font_obj != blank -%}
        {{ h_font_obj | font_face: font_display: 'swap' }}
      {%- endif -%}
    {%- elsif block.type == 'right_point' -%}
      {%- assign rp_font_obj = block.settings.rp_font -%}
      {%- if rp_font_obj != blank -%}
        {{ rp_font_obj | font_face: font_display: 'swap' }}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  #UsBrandsAbout-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_desktop }}px 0 {{ section.settings.pb_desktop }}px;
    position: relative;
    height: {{ section.settings.runway_height }}vh;
  }

  @media screen and (max-width: 749px) {
    #UsBrandsAbout-{{ section.id }} {
      height: auto;
      min-height: auto;
      padding: 60px 0;
    }
  }

  .us-brands-about__container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 4rem;
    display: flex;
    flex-direction: row;
    position: relative;
    height: 100%;
    align-items: flex-start;
  }

  .us-brands-about__left-{{ section.id }},
  .us-brands-about__right-{{ section.id }} {
    position: sticky;
    top: 20vh;
    height: auto;
    max-height: 80vh;
  }

  .us-brands-about__left-{{ section.id }} {
    flex: 0 0 {{ section.settings.split_ratio }}%;
    padding-right: 8rem;
  }

  .us-brands-about__right-{{ section.id }} {
    flex: 1;
    padding-left: 8rem;
    border-left: 2px solid {{ section.settings.line_light_color }};
  }

  @media screen and (max-width: 749px) {
    .us-brands-about__container-{{ section.id }} {
      flex-direction: column;
      padding: 0 2rem;
      height: auto;
    }
    .us-brands-about__left-{{ section.id }},
    .us-brands-about__right-{{ section.id }} {
      position: relative;
      top: 0;
      flex: 0 0 100%;
      padding: 0;
      border: none;
      max-height: none;
    }
    .us-brands-about__right-{{ section.id }} {
      padding-top: 4rem;
    }
  }

  .us-brands-about__point-list-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  .us-brands-about__point-{{ section.id }} {
    position: relative;
    opacity: 0;
    transform: translateY(15px);
    transition: transform 0.6s ease, opacity 0.5s ease;
  }

  .us-brands-about__dot-{{ section.id }} {
    position: absolute;
    left: -8.1rem;
    top: 0.5rem;
    transform: translateX(-50%);
    width: {{ section.settings.dot_size }}px;
    height: {{ section.settings.dot_size }}px;
    background: {{ section.settings.line_light_color }};
    border-radius: 50%;
    z-index: 3;
    transition: background 0.4s ease, transform 0.4s ease;
  }

  .us-brands-about__point-{{ section.id }}.is-active .us-brands-about__dot-{{ section.id }} {
    background: {{ section.settings.line_active_color }};
    transform: translateX(-50%) scale(1.3);
  }

  .us-brands-about__point-text-{{ section.id }} {
    max-width: 600px;
  }

  .us-brands-about__progress-line-{{ section.id }} {
    position: absolute;
    left: -2px;
    top: 0;
    width: 2px;
    height: 0;
    background: {{ section.settings.line_active_color }};
    z-index: 2;
    will-change: height;
  }
{%- endstyle -%}

<section id="UsBrandsAbout-{{ section.id }}" class="us-brands-about">
  <div class="us-brands-about__container-{{ section.id }}">

    <!-- Left Side -->
    <div class="us-brands-about__left-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'left_heading' -%}
          <div class="us-brands-about__left-item" {{ block.shopify_attributes }}>
            {%- liquid
               assign h_font = block.settings.heading_font
               assign h_size = block.settings.heading_size | default: 4.5
               assign h_color = block.settings.heading_color | default: '#1a1a1a'
               assign h_weight = block.settings.heading_weight | default: '700'
               assign h_style = block.settings.heading_style | default: 'normal'
               assign h_align = block.settings.heading_alignment | default: 'left'
               assign h_lh = block.settings.heading_line_height | default: 1.1
               assign h_ls = block.settings.heading_letter_spacing | default: 0
               assign h_pt = block.settings.heading_pt | default: 0
               assign h_pb = block.settings.heading_pb | default: 0
               assign h_pl = block.settings.heading_pl | default: 0
               assign h_pr = block.settings.heading_pr | default: 0
            -%}
            <h2 class="us-brands-about__left-heading" style="{% if h_font != blank %}font-family: {{ h_font.family }}, {{ h_font.fallback_families }};{% endif %}font-size:{{ h_size }}rem;color:{{ h_color }};font-weight:{{ h_weight }};font-style:{{ h_style }};text-align:{{ h_align }};line-height:{{ h_lh }};letter-spacing:{{ h_ls }}px;padding:{{ h_pt }}px {{ h_pr }}px {{ h_pb }}px {{ h_pl }}px;margin:0;">
              {{ block.settings.title }}
            </h2>
          </div>
        {%- elsif block.type == 'left_image' -%}
          <div class="us-brands-about__left-item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Right Side -->
    <div class="us-brands-about__right-{{ section.id }}">
      <div class="us-brands-about__progress-line-{{ section.id }}" id="ProgressLine-{{ section.id }}"></div>
      <div class="us-brands-about__point-list-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'right_point' -%}
            <div class="us-brands-about__point-{{ section.id }} js-about-point-{{ section.id }}" {{ block.shopify_attributes }}>
              <div class="us-brands-about__dot-{{ section.id }}"></div>
              <div class="us-brands-about__point-text-{{ section.id }}" style="{% if block.settings.rp_font != blank %}font-family:{{ block.settings.rp_font.family }},{{ block.settings.rp_font.fallback_families }};{% endif %}font-size:{{ block.settings.rp_size | default: 2.2 }}rem;color:{{ block.settings.rp_color | default: '#1a1a1a' }};font-weight:{{ block.settings.rp_weight | default: '700' }};font-style:{{ block.settings.rp_style | default: 'normal' }};text-align:{{ block.settings.rp_align | default: 'left' }};line-height:{{ block.settings.rp_lh | default: 1.25 }};letter-spacing:{{ block.settings.rp_ls | default: 0 }}px;padding:{{ block.settings.rp_pt | default: 0 }}px {{ block.settings.rp_pr | default: 0 }}px {{ block.settings.rp_pb | default: 0 }}px {{ block.settings.rp_pl | default: 0 }}px;">
                {{ block.settings.text }}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

<script>
(function() {
  var sectionEl = document.getElementById('UsBrandsAbout-{{ section.id }}');
  if (!sectionEl) return;
  var progressLine = document.getElementById('ProgressLine-{{ section.id }}');
  var points = sectionEl.querySelectorAll('.js-about-point-{{ section.id }}');
  if (!points.length) return;

  function update() {
    if (window.innerWidth < 750) {
      points.forEach(function(p) {
        var r = p.getBoundingClientRect();
        if (r.top < window.innerHeight * 0.8) {
          p.style.opacity = '1';
          p.style.transform = 'translateY(0)';
          p.classList.add('is-active');
        }
      });
      return;
    }

    var rect = sectionEl.getBoundingClientRect();
    var totalScroll = sectionEl.offsetHeight - window.innerHeight;
    var progress = Math.max(0, Math.min(1, -rect.top / totalScroll));

    var rightPanel = sectionEl.querySelector('.us-brands-about__right-{{ section.id }}');
    var fullHeight = rightPanel ? rightPanel.offsetHeight : 600;

    /* Story points reveal staggered by scroll progress */
    points.forEach(function(p, i) {
      var pStart = i / points.length;
      var opacity = Math.min(1, Math.max(0, (progress - (pStart - 0.1)) / 0.2));
      p.style.opacity = opacity;
      if (opacity >= 0.8) {
        p.classList.add('is-active');
        p.style.transform = 'translateY(0)';
      } else {
        p.classList.remove('is-active');
        p.style.transform = 'translateY(' + Math.max(0, 15 - opacity * 15) + 'px)';
      }
    });

    /* Line fills proportionally: 0% at section start → 100% at section end */
    if (progressLine) {
      progressLine.style.height = Math.round(progress * fullHeight) + 'px';
    }
  }

  window.addEventListener('scroll', update);
  window.addEventListener('resize', update);
  update();
})();
</script>

{% schema %}
{
  "name": "US Brands About Us",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "range", "id": "split_ratio", "label": "Split Ratio (Left %)", "min": 30, "max": 70, "step": 5, "default": 40 },
    { "type": "range", "id": "runway_height", "label": "Scroll Runway Height", "min": 100, "max": 500, "step": 50, "unit": "vh", "default": 300 },
    { "type": "range", "id": "container_width", "label": "Container Width", "min": 1000, "max": 1600, "step": 50, "default": 1400 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Default Text Color", "default": "#1a1a1a" },
    { "type": "color", "id": "line_light_color", "label": "Line Inactive Color", "default": "#e5e5e5" },
    { "type": "color", "id": "line_active_color", "label": "Line Active Color", "default": "#6394FF" },
    { "type": "range", "id": "dot_size", "label": "Dot Size", "min": 6, "max": 40, "step": 2, "unit": "px", "default": 16 },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "pt_desktop", "label": "Padding Top (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 },
    { "type": "range", "id": "pb_desktop", "label": "Padding Bottom (Desktop)", "min": 0, "max": 200, "step": 10, "default": 100 }
  ],
  "blocks": [
    {
      "type": "left_heading",
      "name": "Left Heading",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading Text", "default": "Meaning behind the brand" },
        { "type": "header", "content": "Typography" },
        { "type": "font_picker", "id": "heading_font", "label": "Font Family", "default": "assistant_n4" },
        { "type": "range", "id": "heading_size", "label": "Font Size (rem)", "min": 1, "max": 10, "step": 0.1, "unit": "rem", "default": 4.5 },
        { "type": "color", "id": "heading_color", "label": "Color", "default": "#1a1a1a" },
        { "type": "select", "id": "heading_weight", "label": "Weight", "default": "700", "options": [
          { "value": "300", "label": "Light" },
          { "value": "400", "label": "Regular" },
          { "value": "500", "label": "Medium" },
          { "value": "600", "label": "Semi Bold" },
          { "value": "700", "label": "Bold" },
          { "value": "800", "label": "Extra Bold" },
          { "value": "900", "label": "Black" }
        ]},
        { "type": "select", "id": "heading_style", "label": "Style", "default": "normal", "options": [
          { "value": "normal", "label": "Normal" },
          { "value": "italic", "label": "Italic" }
        ]},
        { "type": "range", "id": "heading_line_height", "label": "Line Height", "min": 0.8, "max": 2.5, "step": 0.1, "default": 1.1 },
        { "type": "range", "id": "heading_letter_spacing", "label": "Letter Spacing (px)", "min": -5, "max": 10, "step": 0.5, "default": 0 },
        { "type": "header", "content": "Alignment & Padding" },
        { "type": "select", "id": "heading_alignment", "label": "Alignment", "default": "left", "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ]},
        { "type": "range", "id": "heading_pt", "label": "Padding Top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
        { "type": "range", "id": "heading_pb", "label": "Padding Bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
        { "type": "range", "id": "heading_pl", "label": "Padding Left", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
        { "type": "range", "id": "heading_pr", "label": "Padding Right", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 }
      ]
    },
    {
      "type": "left_image",
      "name": "Left Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "right_point",
      "name": "Right Story Point",
      "settings": [
        { "type": "textarea", "id": "text", "label": "Point Text", "default": "Inspired by the symbolism of the swan" },
        { "type": "header", "content": "Text Style" },
        { "type": "font_picker", "id": "rp_font", "label": "Font Family", "default": "assistant_n4" },
        { "type": "range", "id": "rp_size", "label": "Font Size (rem)", "min": 1, "max": 4, "step": 0.1, "unit": "rem", "default": 2.2 },
        { "type": "color", "id": "rp_color", "label": "Font Color", "default": "#1a1a1a" },
        { "type": "select", "id": "rp_weight", "label": "Font Weight", "default": "700", "options": [
          { "value": "300", "label": "Light" },
          { "value": "400", "label": "Regular" },
          { "value": "500", "label": "Medium" },
          { "value": "600", "label": "Semi Bold" },
          { "value": "700", "label": "Bold" },
          { "value": "800", "label": "Extra Bold" },
          { "value": "900", "label": "Black" }
        ]},
        { "type": "select", "id": "rp_style", "label": "Font Style", "default": "normal", "options": [
          { "value": "normal", "label": "Normal" },
          { "value": "italic", "label": "Italic" }
        ]},
        { "type": "range", "id": "rp_lh", "label": "Line Height", "min": 0.8, "max": 2.5, "step": 0.1, "default": 1.3 },
        { "type": "range", "id": "rp_ls", "label": "Letter Spacing (px)", "min": -5, "max": 10, "step": 1, "unit": "px", "default": 0 },
        { "type": "header", "content": "Alignment & Padding" },
        { "type": "select", "id": "rp_align", "label": "Alignment", "default": "left", "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ]},
        { "type": "range", "id": "rp_pt", "label": "Padding Top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
        { "type": "range", "id": "rp_pb", "label": "Padding Bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
        { "type": "range", "id": "rp_pl", "label": "Padding Left", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
        { "type": "range", "id": "rp_pr", "label": "Padding Right", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 }
      ]
    }
  ],
  "presets": [
    {
      "name": "US Brands About Us",
      "blocks": [
        { "type": "left_heading" },
        { "type": "right_point" },
        { "type": "right_point" },
        { "type": "right_point" }
      ]
    }
  ]
}
{% endschema %}
