{%- style -%}
  /* ── DESKTOP ── */
  #VideoFirst-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: {{ section.settings.section_height }}vh;
    padding: {{ section.settings.pt }}px {{ section.settings.ph }}px {{ section.settings.pb }}px;
    box-sizing: border-box;
    overflow: hidden;
  }

  .vf-wrap-{{ section.id }} {
    width: 100%;
    max-width: {{ section.settings.video_max_width }}%;
    border-radius: {{ section.settings.video_border_radius }}px;
    overflow: hidden;
    flex-shrink: 0;
    {%- if section.settings.shadow_size > 0 -%}
      box-shadow: 0 {{ section.settings.shadow_size | times: 2 }}px {{ section.settings.shadow_size | times: 4 }}px rgba(0,0,0,{{ section.settings.shadow_opacity | divided_by: 100.0 }});
    {%- endif -%}
  }

  /* ── Aspect ratio container ── */
  .vf-ratio-{{ section.id }} {
    position: relative;
    width: 100%;
    {%- case section.settings.aspect_ratio -%}
      {%- when '16/9' -%} padding-top: 56.25%;
      {%- when '4/3' -%}  padding-top: 75%;
      {%- when '1/1' -%}  padding-top: 100%;
      {%- when '9/16' -%} padding-top: 177.78%;
      {%- when 'auto' -%} padding-top: 0;
    {%- endcase -%}
  }

  .vf-ratio-{{ section.id }} > video,
  .vf-ratio-{{ section.id }} > iframe {
    {%- if section.settings.aspect_ratio == 'auto' -%}
      position: static;
      width: 100%;
      height: auto;
      display: block;
    {%- else -%}
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    {%- endif -%}
    object-fit: {{ section.settings.video_object_fit }};
    border: none;
  }

  /* ── MOBILE ── */
  @media screen and (max-width: 749px) {
    #VideoFirst-{{ section.id }} {
      min-height: {{ section.settings.section_height_mobile }}vh;
      padding: {{ section.settings.pt_mobile }}px {{ section.settings.ph_mobile }}px {{ section.settings.pb_mobile }}px;
      background: {{ section.settings.bg_color_mobile }};
    }

    .vf-wrap-{{ section.id }} {
      max-width: {{ section.settings.video_max_width_mobile }}%;
      border-radius: {{ section.settings.video_border_radius_mobile }}px;
    }

    .vf-ratio-{{ section.id }} {
      {%- case section.settings.aspect_ratio_mobile -%}
        {%- when '16/9' -%} padding-top: 56.25%;
        {%- when '4/3' -%}  padding-top: 75%;
        {%- when '1/1' -%}  padding-top: 100%;
        {%- when '9/16' -%} padding-top: 177.78%;
        {%- when 'auto' -%} padding-top: 0;
      {%- endcase -%}
    }

    .vf-ratio-{{ section.id }} > video,
    .vf-ratio-{{ section.id }} > iframe {
      {%- if section.settings.aspect_ratio_mobile == 'auto' -%}
        position: static;
        height: auto;
      {%- else -%}
        position: absolute;
        height: 100%;
      {%- endif -%}
      object-fit: {{ section.settings.video_object_fit_mobile }};
    }

    /* Show/hide desktop vs mobile videos */
    .vf-desktop-{{ section.id }} { display: none !important; }
    .vf-mobile-{{ section.id }}  { display: block !important; }
  }

  @media screen and (min-width: 750px) {
    .vf-desktop-{{ section.id }} { display: block !important; }
    .vf-mobile-{{ section.id }}  { display: none !important; }
  }
{%- endstyle -%}

<section id="VideoFirst-{{ section.id }}" class="video-first-section">
  <div class="vf-wrap-{{ section.id }}">
    <div class="vf-ratio-{{ section.id }}">

      {%- comment -%} ── DESKTOP VIDEO ── {%- endcomment -%}
      <div class="vf-desktop-{{ section.id }}">
        {%- if section.settings.video != blank -%}
          {{- section.settings.video | video_tag:
              autoplay: section.settings.autoplay,
              loop: section.settings.loop_video,
              muted: section.settings.muted,
              controls: section.settings.show_controls,
              playsinline: true,
              preload: 'metadata',
              style: 'width:100%;height:100%;object-fit:' | append: section.settings.video_object_fit
          -}}
        {%- elsif section.settings.video_url != blank -%}
          {{- section.settings.video_url | external_video_tag:
              loading: 'lazy',
              allow: 'autoplay; fullscreen',
              title: 'Video'
          -}}
        {%- else -%}
          <div style="width:100%;min-height:300px;display:flex;align-items:center;justify-content:center;background:#111;color:#666;font-family:sans-serif;font-size:1rem;">
            Add a desktop video in the Theme Editor
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── MOBILE VIDEO ── {%- endcomment -%}
      <div class="vf-mobile-{{ section.id }}">
        {%- if section.settings.video_mobile != blank -%}
          {{- section.settings.video_mobile | video_tag:
              autoplay: section.settings.autoplay_mobile,
              loop: section.settings.loop_video_mobile,
              muted: section.settings.muted_mobile,
              controls: section.settings.show_controls_mobile,
              playsinline: true,
              preload: 'metadata',
              style: 'width:100%;height:100%;object-fit:' | append: section.settings.video_object_fit_mobile
          -}}
        {%- elsif section.settings.video_url_mobile != blank -%}
          {{- section.settings.video_url_mobile | external_video_tag:
              loading: 'lazy',
              allow: 'autoplay; fullscreen',
              title: 'Video Mobile'
          -}}
        {%- elsif section.settings.video != blank -%}
          {%- comment -%}Fall back to desktop video with mobile styles{%- endcomment -%}
          {{- section.settings.video | video_tag:
              autoplay: section.settings.autoplay_mobile,
              loop: section.settings.loop_video_mobile,
              muted: section.settings.muted_mobile,
              controls: section.settings.show_controls_mobile,
              playsinline: true,
              preload: 'metadata',
              style: 'width:100%;height:100%;object-fit:' | append: section.settings.video_object_fit_mobile
          -}}
        {%- elsif section.settings.video_url != blank -%}
          {{- section.settings.video_url | external_video_tag:
              loading: 'lazy',
              allow: 'autoplay; fullscreen',
              title: 'Video'
          -}}
        {%- else -%}
          <div style="width:100%;min-height:200px;display:flex;align-items:center;justify-content:center;background:#111;color:#666;font-family:sans-serif;font-size:0.9rem;">
            Add a mobile video in the Theme Editor (or desktop video will be used)
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video First",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "── DESKTOP ──────────────────────"
    },
    {
      "type": "header",
      "content": "Desktop Video Source"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Desktop Video (upload)"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Desktop Video URL (YouTube / Vimeo)",
      "accept": ["youtube", "vimeo"],
      "info": "Used if no uploaded video is selected above."
    },
    {
      "type": "header",
      "content": "Desktop Playback"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Muted",
      "default": true,
      "info": "Required for autoplay in most browsers."
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show Controls",
      "default": false
    },
    {
      "type": "header",
      "content": "Desktop Video Display"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect Ratio",
      "default": "16/9",
      "options": [
        { "value": "16/9",  "label": "16:9  — Landscape (default)" },
        { "value": "4/3",   "label": "4:3   — Classic" },
        { "value": "1/1",   "label": "1:1   — Square" },
        { "value": "9/16",  "label": "9:16  — Portrait / Vertical" },
        { "value": "auto",  "label": "Auto  — native size" }
      ]
    },
    {
      "type": "select",
      "id": "video_object_fit",
      "label": "Video Fit",
      "default": "cover",
      "options": [
        { "value": "cover",   "label": "Cover (fill, may crop)" },
        { "value": "contain", "label": "Contain (show full video)" },
        { "value": "fill",    "label": "Fill (stretch)" }
      ]
    },
    {
      "type": "range",
      "id": "video_max_width",
      "label": "Max Width (%)",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_size",
      "label": "Shadow Depth",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Shadow Opacity (%)",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 20
    },
    {
      "type": "header",
      "content": "Desktop Section Layout"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section Height (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 100
    },
    {
      "type": "range",
      "id": "pt",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "pb",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "ph",
      "label": "Padding Sides",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "── MOBILE ───────────────────────"
    },
    {
      "type": "header",
      "content": "Mobile Video Source"
    },
    {
      "type": "video",
      "id": "video_mobile",
      "label": "Mobile Video (upload)",
      "info": "If blank, the desktop video will be used with mobile settings."
    },
    {
      "type": "video_url",
      "id": "video_url_mobile",
      "label": "Mobile Video URL (YouTube / Vimeo)",
      "accept": ["youtube", "vimeo"],
      "info": "Used if no uploaded mobile video is selected above."
    },
    {
      "type": "header",
      "content": "Mobile Playback"
    },
    {
      "type": "checkbox",
      "id": "autoplay_mobile",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop_video_mobile",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted_mobile",
      "label": "Muted",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls_mobile",
      "label": "Show Controls",
      "default": false
    },
    {
      "type": "header",
      "content": "Mobile Video Display"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Aspect Ratio (Mobile)",
      "default": "9/16",
      "options": [
        { "value": "16/9",  "label": "16:9  — Landscape" },
        { "value": "4/3",   "label": "4:3   — Classic" },
        { "value": "1/1",   "label": "1:1   — Square" },
        { "value": "9/16",  "label": "9:16  — Portrait / Vertical" },
        { "value": "auto",  "label": "Auto  — native size" }
      ]
    },
    {
      "type": "select",
      "id": "video_object_fit_mobile",
      "label": "Video Fit (Mobile)",
      "default": "cover",
      "options": [
        { "value": "cover",   "label": "Cover (fill, may crop)" },
        { "value": "contain", "label": "Contain (show full video)" },
        { "value": "fill",    "label": "Fill (stretch)" }
      ]
    },
    {
      "type": "range",
      "id": "video_max_width_mobile",
      "label": "Max Width (Mobile %)",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "video_border_radius_mobile",
      "label": "Border Radius (Mobile)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Section Layout"
    },
    {
      "type": "color",
      "id": "bg_color_mobile",
      "label": "Background Color (Mobile)",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "label": "Section Height (Mobile vh)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    },
    {
      "type": "range",
      "id": "pt_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "pb_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "ph_mobile",
      "label": "Padding Sides (Mobile)",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Video First"
    }
  ]
}
{% endschema %}
