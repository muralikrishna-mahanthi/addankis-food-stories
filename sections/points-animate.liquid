{%- style -%}
  {%- liquid
    assign heading_font = section.settings.heading_font
    assign text_font = section.settings.text_font
  -%}

  {{ heading_font | font_face: font_display: 'swap' }}
  {{ text_font | font_face: font_display: 'swap' }}

  #FmcgBuiltFor-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    overflow: hidden;
    font-family: {{ text_font.family }}, {{ text_font.fallback_families }};
  }

  .fbf-container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 4rem;
    position: relative;
  }

  .fbf-header {
    text-align: center;
    margin-bottom: 12rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .fbf-header.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .fbf-heading {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    max-width: 900px;
    margin: 0 auto;
  }

  .fbf-timeline {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 0;
  }

  .fbf-line-wrapper {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 6px;
    transform: translateX(-50%);
    background: {{ section.settings.line_base_color }};
    z-index: 1;
  }

  .fbf-line-active {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: {{ section.settings.line_active_color }};
    transition: height 0.1s linear;
  }

  .fbf-points-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12rem;
    z-index: 2;
  }

  .fbf-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    width: 100%;
  }

  .fbf-point {
    width: 44%;
    position: relative;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1), opacity 1s ease;
  }

  .fbf-point-left {
    text-align: center;
    transform: translateX(-100vw);
  }

  .fbf-point-right {
    text-align: center;
    transform: translateX(100vw);
  }

  .fbf-row.is-visible .fbf-point {
    opacity: 1;
    transform: translateX(0);
  }

  .fbf-content {
    padding: 2rem 0;
  }

  .fbf-title {
    margin: 0 0 1.5rem 0;
    font-size: 2.4rem;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    line-height: 1.3;
  }

  .fbf-desc {
    margin: 0;
    font-size: 2rem;
    line-height: 1.5;
    color: {{ section.settings.text_color }};
    font-weight: 700;
    text-align: center;
  }

  @media screen and (max-width: 768px) {
    .fbf-container {
      padding: 0 2rem;
    }
    .fbf-line-wrapper {
      left: 20px;
      width: 4px;
    }
    .fbf-row {
      flex-direction: column;
      gap: 6rem;
      padding-left: 45px;
    }
    .fbf-point {
      width: 100%;
      text-align: center !important;
      transform: translateX(60px) !important;
    }
    .fbf-heading {
      font-size: 3rem;
    }
    .fbf-desc {
        font-size: 1.8rem;
    }
  }
{%- endstyle -%}

<section id="FmcgBuiltFor-{{ section.id }}" class="fbf-section">
  <div class="fbf-container">
    <div class="fbf-header js-fbf-animate">
      <h2 class="fbf-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="fbf-timeline">
      <div class="fbf-line-wrapper">
        <div class="fbf-line-active js-fbf-line"></div>
      </div>

      <div class="fbf-points-list">
        {%- for block in section.blocks -%}
          {%- if forloop.index0 % 2 == 0 -%}
            <div class="fbf-row js-fbf-animate">
              
              <!-- Left Item -->
              <div class="fbf-point fbf-point-left" {{ block.shopify_attributes }}>
                <div class="fbf-content">
                  {%- if block.settings.title != blank -%}
                    <h3 class="fbf-title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <div class="fbf-desc">{{ block.settings.description }}</div>
                  {%- endif -%}
                </div>
              </div>

              <!-- Right Item -->
              {%- assign next_idx = forloop.index0 | plus: 1 -%}
              {%- assign next_block = section.blocks[next_idx] -%}
              {%- if next_block != blank -%}
                <div class="fbf-point fbf-point-right" {{ next_block.shopify_attributes }}>
                  <div class="fbf-content">
                    {%- if next_block.settings.title != blank -%}
                      <h3 class="fbf-title">{{ next_block.settings.title }}</h3>
                    {%- endif -%}
                    {%- if next_block.settings.description != blank -%}
                      <div class="fbf-desc">{{ next_block.settings.description }}</div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  function initFmcgBuiltFor() {
    const section = document.querySelector('#FmcgBuiltFor-{{ section.id }}');
    if (!section || section.dataset.initialized) return;
    section.dataset.initialized = "true";

    const animateEls = section.querySelectorAll('.js-fbf-animate');
    const lineActive = section.querySelector('.js-fbf-line');
    
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.05, rootMargin: "0px 0px -50px 0px" });

    animateEls.forEach(el => obs.observe(el));

    function updateFbfScroll() {
        const rect = section.getBoundingClientRect();
        const vh = window.innerHeight;
        const sh = section.offsetHeight;
        const trigger = vh * 0.8;
        let p = 0;
        if (rect.top < trigger) {
            p = (trigger - rect.top) / (sh - vh * 0.2);
        }
        if (lineActive) lineActive.style.height = (Math.max(0, Math.min(1, p)) * 100) + '%';
    }

    window.addEventListener('scroll', updateFbfScroll, { passive: true });
    updateFbfScroll();

    setTimeout(() => {
        animateEls.forEach(el => {
            if (el.getBoundingClientRect().top < window.innerHeight) el.classList.add('is-visible');
        });
    }, 500);
  }

  document.addEventListener('DOMContentLoaded', initFmcgBuiltFor);
  document.addEventListener('shopify:section:load', (e) => {
    if (e.target.id.includes('{{ section.id }}')) initFmcgBuiltFor();
  });
</script>

