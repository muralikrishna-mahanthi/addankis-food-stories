{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-products {
    overflow: hidden;
    width: 100%;
  }

  /* Scrolling Logos Styles */
  .home-products__logos-wrapper {
    display: flex;
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
    padding: {{ section.settings.logo_padding }}px 0;
    margin-bottom: 20px;
  }

  .home-products__logos-track {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 40px;
    padding-right: 40px;
    animation: scrollLogos {{ section.settings.logo_scroll_speed }}s linear infinite;
  }

  {%- if section.settings.pause_on_hover -%}
  .home-products__logos-wrapper:hover .home-products__logos-track {
    animation-play-state: paused;
  }
  {%- endif -%}

  .home-products__logo-item {
    height: {{ section.settings.logo_height }}px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  @keyframes scrollLogos {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  /* Image Rows Styles */
  .home-products__image-row {
    width: 100%;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .home-products__image-row:last-child {
    margin-bottom: 0;
  }

  .home-products__image-track {
    display: flex;
    gap: 20px;
    width: max-content;
    padding: 0 20px;
  }

  .home-products__image-item {
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    background-color: #f4f4f4;
  }
  
  .home-products__image-item img {
    height: 100%;
    width: auto;
    object-fit: cover;
    display: block;
  }
{%- endstyle -%}

<div class="home-products section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  
  {%- assign logo_block = section.blocks | where: 'type', 'scrolling_logos' | first -%}
  {%- if logo_block -%}
    <!-- Scrolling Logos at the Top -->
    <div class="home-products__logos-wrapper" {{ logo_block.shopify_attributes }}>
      {%- capture logos_html -%}
        {%- for i in (1..12) -%}
          {%- assign logo_key = 'logo_' | append: i -%}
          {%- if logo_block.settings[logo_key] != blank -%}
            {{ logo_block.settings[logo_key] | image_url: height: 100 | image_tag: class: 'home-products__logo-item' }}
          {%- endif -%}
        {%- endfor -%}
        {%- if logo_block.settings.logo_1 == blank -%}
          <div class="home-products__logo-item" style="width: 100px; background: #ddd; height: {{ section.settings.logo_height }}px;"></div>
          <div class="home-products__logo-item" style="width: 100px; background: #ccc; height: {{ section.settings.logo_height }}px;"></div>
          <div class="home-products__logo-item" style="width: 100px; background: #ddd; height: {{ section.settings.logo_height }}px;"></div>
        {%- endif -%}
      {%- endcapture -%}

      <div class="home-products__logos-track">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
    </div>
  {%- endif -%}

  <!-- Image Rows Below -->
  {%- for block in section.blocks -%}
    {%- if block.type == 'image_row' -%}
      <div class="home-products__image-row" {{ block.shopify_attributes }}>
        <div class="home-products__image-track" {% cycle '', 'style="padding-left: 60px;"' %}>
          {%- for i in (1..4) -%}
            {%- assign img_key = 'image_' | append: i -%}
            {%- if block.settings[img_key] != blank or forloop.index <= 4 -%}
              <div class="home-products__image-item" style="height: {{ block.settings.row_height }}px;">
                {%- if block.settings[img_key] != blank -%}
                  {{ block.settings[img_key] | image_url: height: 800 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  <div style="width: {{ block.settings.row_height | times: 1.2 }}px; height: 100%; display: flex; align-items: center; justify-content: center; background: #e0e0e0; color: #666;">
                    Image {{ i }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

</div>

{% schema %}
{
  "name": "Home Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#FFF7B0"
    },
    {
      "type": "header",
      "content": "Logos Container Settings"
    },
    {
      "type": "range",
      "id": "logo_scroll_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Logo Scroll Speed",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause Scroll on Hover",
      "default": true
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Logo Height",
      "default": 40
    },
    {
      "type": "range",
      "id": "logo_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Logos Container Padding (Top/Bottom)",
      "default": 20
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "scrolling_logos",
      "name": "Scrolling Logos",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "logo_1", "label": "Logo 1" },
        { "type": "image_picker", "id": "logo_2", "label": "Logo 2" },
        { "type": "image_picker", "id": "logo_3", "label": "Logo 3" },
        { "type": "image_picker", "id": "logo_4", "label": "Logo 4" },
        { "type": "image_picker", "id": "logo_5", "label": "Logo 5" },
        { "type": "image_picker", "id": "logo_6", "label": "Logo 6" },
        { "type": "image_picker", "id": "logo_7", "label": "Logo 7" },
        { "type": "image_picker", "id": "logo_8", "label": "Logo 8" },
        { "type": "image_picker", "id": "logo_9", "label": "Logo 9" },
        { "type": "image_picker", "id": "logo_10", "label": "Logo 10" },
        { "type": "image_picker", "id": "logo_11", "label": "Logo 11" },
        { "type": "image_picker", "id": "logo_12", "label": "Logo 12" }
      ]
    },
    {
      "type": "image_row",
      "name": "Image Row",
      "settings": [
        {
          "type": "range",
          "id": "row_height",
          "min": 100,
          "max": 600,
          "step": 10,
          "unit": "px",
          "label": "Row Height",
          "default": 300
        },
        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "image_picker", "id": "image_3", "label": "Image 3" },
        { "type": "image_picker", "id": "image_4", "label": "Image 4" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Products",
      "blocks": [
        { "type": "scrolling_logos" },
        { "type": "image_row" },
        { "type": "image_row" }
      ]
    }
  ]
}
{% endschema %}
