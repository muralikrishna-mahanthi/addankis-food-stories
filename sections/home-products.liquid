{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-products {
    overflow: hidden;
    width: 100%;
  }

  /* Scrolling Logos Styles */
  .home-products__logos-wrapper {
    display: flex;
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
    padding: {{ section.settings.logo_padding }}px 0;
    margin-bottom: 20px;
  }

  .home-products__logos-track {
    display: inline-flex;
    align-items: center;
    gap: 40px;
    padding-right: 40px;
  }

  .home-products__logo-item {
    height: {{ section.settings.logo_height }}px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  /* Image Rows Styles */
  .home-products__image-row {
    width: 100%;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .home-products__image-row:last-child {
    margin-bottom: 0;
  }

  .home-products__image-track {
    display: flex;
    gap: 20px;
    width: max-content;
    padding: 0 20px;
  }

  .home-products__image-item {
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    background-color: #f4f4f4; /* Placeholder background */
  }
  
  .home-products__image-item img {
    height: 100%;
    width: auto;
    object-fit: cover;
    display: block;
  }
{%- endstyle -%}

<div class="home-products section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  
  {%- assign logo_blocks = section.blocks | where: 'type', 'logo' -%}
  {%- if logo_blocks.size > 0 -%}
    <!-- Scrolling Logos at the Top -->
    <div class="home-products__logos-wrapper">
      <div class="home-products__logos-track">
        {%- for block in logo_blocks -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: height: 100 | image_tag: class: 'home-products__logo-item' }}
          {%- else -%}
            <div class="home-products__logo-item" style="width: 100px; background: #ddd; height: {{ section.settings.logo_height }}px;"></div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <!-- Duplicate track for seamless scrolling if needed later -->
      <div class="home-products__logos-track duplicate" aria-hidden="true">
        {%- for block in logo_blocks -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: height: 100 | image_tag: class: 'home-products__logo-item' }}
          {%- else -%}
            <div class="home-products__logo-item" style="width: 100px; background: #ddd; height: {{ section.settings.logo_height }}px;"></div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <!-- Image Row 1 -->
  <div class="home-products__image-row home-products__image-row--1">
    <div class="home-products__image-track">
      {%- for block in section.blocks -%}
        {%- if block.type == 'image' and block.settings.row == '1' -%}
          <div class="home-products__image-item" style="height: {{ block.settings.height }}px;" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: height: 800 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div style="width: {{ block.settings.height | times: 1.2 }}px; height: 100%; display: flex; align-items: center; justify-content: center; background: #e0e0e0; color: #666;">
                Row 1 Image
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Image Row 2 -->
  <div class="home-products__image-row home-products__image-row--2">
    <div class="home-products__image-track" style="padding-left: 60px;"> <!-- Slight offset for visual staggering -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'image' and block.settings.row == '2' -%}
          <div class="home-products__image-item" style="height: {{ block.settings.height }}px;" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: height: 800 | image_tag: loading: 'lazy' }}
            {%- else -%}
              <div style="width: {{ block.settings.height | times: 1.2 }}px; height: 100%; display: flex; align-items: center; justify-content: center; background: #e0e0e0; color: #666;">
                Row 2 Image
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Home Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#FFF7B0"
    },
    {
      "type": "header",
      "content": "Logos Container Settings"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Logo Height",
      "default": 40
    },
    {
      "type": "range",
      "id": "logo_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Logos Container Padding (Top/Bottom)",
      "default": 20
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        }
      ]
    },
    {
      "type": "image",
      "name": "Product Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "row",
          "label": "Row Assignment",
          "options": [
            {
              "value": "1",
              "label": "Row 1 (Top)"
            },
            {
              "value": "2",
              "label": "Row 2 (Bottom)"
            }
          ],
          "default": "1"
        },
        {
          "type": "range",
          "id": "height",
          "min": 100,
          "max": 600,
          "step": 10,
          "unit": "px",
          "label": "Image Height",
          "default": 250
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Products",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "image", "settings": { "row": "1", "height": 300 } },
        { "type": "image", "settings": { "row": "1", "height": 300 } },
        { "type": "image", "settings": { "row": "1", "height": 300 } },
        { "type": "image", "settings": { "row": "2", "height": 280 } },
        { "type": "image", "settings": { "row": "2", "height": 280 } },
        { "type": "image", "settings": { "row": "2", "height": 280 } }
      ]
    }
  ]
}
{% endschema %}
