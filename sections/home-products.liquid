{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-products {
    overflow: hidden;
    width: 100%;
  }

  /* Scrolling Logos Styles */
  .home-products__logos-wrapper {
    display: flex;
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
    padding: {{ section.settings.logo_padding }}px 0;
    margin-bottom: {{ section.settings.logo_margin_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .home-products__logos-wrapper {
      margin-bottom: {{ section.settings.mobile_logo_margin }}px;
    }
  }

  .home-products__logos-track {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 40px;
    padding-right: 40px;
    animation: scrollLogos {{ section.settings.logo_scroll_speed }}s linear infinite;
  }

  @media screen and (max-width: 749px) {
    .home-products__logos-track {
      gap: {{ section.settings.mobile_logo_gap }}px;
      padding-right: {{ section.settings.mobile_logo_gap }}px;
    }
  }

  {%- if section.settings.pause_on_hover -%}
  .home-products__logos-wrapper:hover .home-products__logos-track {
    animation-play-state: paused;
  }
  {%- endif -%}

  .home-products__logo-item {
    height: {{ section.settings.logo_height }}px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  @keyframes scrollLogos {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  /* Image Rows Styles */
  .home-products__image-row {
    width: 100%;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .home-products__image-row:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .home-products__image-row {
      margin-bottom: var(--mobile-row-margin, 20px) !important;
    }
  }

  .home-products__image-track {
    display: flex;
    gap: 20px;
    width: max-content;
    padding: 0 20px;
    transition: transform 2.5s cubic-bezier(0.1, 0.9, 0.2, 1);
    will-change: transform;
  }

  .home-products__image-item {
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    background-color: #ffffff; /* White frame */
  }
  
  .home-products__image-item__inner {
    width: 100%;
    height: 100%;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
  }

  .home-products__image-item img {
    height: 100%;
    width: auto;
    object-fit: cover;
    display: block;
    transform: scale(1.2); /* Default start scale for zoom out effect */
    will-change: transform;
    transition: transform 2.5s cubic-bezier(0.1, 0.9, 0.2, 1);
  }

  @media screen and (max-width: 749px) {
    .home-products__image-track {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr);
      width: 100% !important;
      padding: 0 15px !important;
      gap: var(--mobile-image-gap, 10px) !important;
      transform: none !important;
    }
    .home-products__image-item {
      height: auto !important;
      aspect-ratio: 1 / 1;
      padding: 8px;
    }
    .home-products__image-item img {
      transform: scale(1) !important;
      transition: none !important;
    }
  }
{%- endstyle -%}

<div class="home-products section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  
  {%- assign logo_block = section.blocks | where: 'type', 'scrolling_logos' | first -%}
  {%- if logo_block -%}
    <!-- Scrolling Logos at the Top -->
    <div class="home-products__logos-wrapper" {{ logo_block.shopify_attributes }}>
      {%- capture logos_html -%}
        {%- for i in (1..12) -%}
          {%- assign logo_key = 'logo_' | append: i -%}
          {%- if logo_block.settings[logo_key] != blank -%}
            {{ logo_block.settings[logo_key] | image_url: height: 100 | image_tag: class: 'home-products__logo-item' }}
          {%- endif -%}
        {%- endfor -%}
        {%- if logo_block.settings.logo_1 == blank -%}
          <div class="home-products__logo-item" style="width: 100px; background: #ddd; height: {{ section.settings.logo_height }}px;"></div>
          <div class="home-products__logo-item" style="width: 100px; background: #ccc; height: {{ section.settings.logo_height }}px;"></div>
          <div class="home-products__logo-item" style="width: 100px; background: #ddd; height: {{ section.settings.logo_height }}px;"></div>
        {%- endif -%}
      {%- endcapture -%}

      <div class="home-products__logos-track">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
      <div class="home-products__logos-track" aria-hidden="true">{{ logos_html }}</div>
    </div>
  {%- endif -%}

  <!-- Image Rows Below -->
  {%- for block in section.blocks -%}
    {%- if block.type == 'image_row' -%}
      <div class="home-products__image-row home-products__image-row--parallax" 
           data-speed="{{ block.settings.animation_speed }}" 
           style="--mobile-row-margin: {{ block.settings.mobile_row_margin }}px;"
           {{ block.shopify_attributes }}>
        <div class="home-products__image-track" style="gap: {{ block.settings.image_gap }}px; --mobile-image-gap: {{ block.settings.mobile_image_gap }}px;">
          {%- for i in (1..4) -%}
            {%- assign img_key = 'image_' | append: i -%}
            {%- if block.settings[img_key] != blank or forloop.index <= 4 -%}
              <div class="home-products__image-item" style="height: {{ block.settings.row_height }}px;">
                <div class="home-products__image-item__inner">
                  {%- if block.settings[img_key] != blank -%}
                    {{ block.settings[img_key] | image_url: height: 800 | image_tag: loading: 'lazy', class: 'home-products__parallax-img' }}
                  {%- else -%}
                    <div style="width: {{ block.settings.row_height | times: 1.2 }}px; height: 100%; display: flex; align-items: center; justify-content: center; background: #e0e0e0; color: #666;" class="home-products__parallax-img">
                      Image {{ i }}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const rows = document.querySelectorAll('.home-products__image-row--parallax');
    if (rows.length === 0) return;

    let ticking = false;

    function onScroll() {
      if (window.innerWidth < 750) return; // Disable animation on mobile

      const windowHeight = window.innerHeight;
      
      rows.forEach((row, index) => {
        const rect = row.getBoundingClientRect();
        
        // Only animate when row is in or near viewport
        if (rect.top <= windowHeight && rect.bottom >= 0) {
          // Progress from 0 (just entered bottom) to 1 (leaving top)
          let progress = (windowHeight - rect.top) / (windowHeight + rect.height);
          progress = Math.max(0, Math.min(1, progress));
          
          // Horizontal Parallax
          // Center the parallax around the middle of the screen (progress 0.5)
          const baseTravel = 60; // Base total travel distance
          const speedMultiplier = parseFloat(row.dataset.speed) || 5;
          const totalTravel = baseTravel * speedMultiplier;
          
          let translateX = 0;
          if (index % 2 === 0) {
             // Row 1 (Even): Start shifted right (positive), move left (negative)
             translateX = (0.5 - progress) * totalTravel;
          } else {
             // Row 2 (Odd): Start shifted left (negative), move right (positive)
             translateX = (progress - 0.5) * totalTravel;
          }

          const track = row.querySelector('.home-products__image-track');
          if (track) {
            track.style.transform = `translateX(${translateX}px)`;
          }

          // Image Zoom Out Effect
          // Scale from 1.25 down to 1.0 at center of viewport
          let scaleProgress = (windowHeight - rect.top) / (windowHeight / 1.5);
          scaleProgress = Math.max(0, Math.min(1, scaleProgress));
          const scale = 1.25 - (scaleProgress * 0.25);

          const imgs = row.querySelectorAll('.home-products__parallax-img');
          imgs.forEach(img => {
            img.style.transform = `scale(${scale})`;
          });
        }
      });
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    });

    // Initial trigger
    onScroll();
  });
</script>

{% schema %}
{
  "name": "Home Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#FFF7B0"
    },
    {
      "type": "header",
      "content": "Logos Container Settings"
    },
    {
      "type": "range",
      "id": "logo_scroll_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Logo Scroll Speed",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause Scroll on Hover",
      "default": true
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Logo Height",
      "default": 40
    },
    {
      "type": "range",
      "id": "logo_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Logos Container Padding (Top/Bottom)",
      "default": 20
    },
    {
      "type": "range",
      "id": "logo_margin_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Logos Margin Bottom (Desktop)",
      "default": 20
    },
    {
      "type": "header",
      "content": "Logos Mobile Settings"
    },
    {
      "type": "range",
      "id": "mobile_logo_gap",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile Logo Gap",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_logo_margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile Logo Margin Bottom",
      "default": 20
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "scrolling_logos",
      "name": "Scrolling Logos",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "logo_1", "label": "Logo 1" },
        { "type": "image_picker", "id": "logo_2", "label": "Logo 2" },
        { "type": "image_picker", "id": "logo_3", "label": "Logo 3" },
        { "type": "image_picker", "id": "logo_4", "label": "Logo 4" },
        { "type": "image_picker", "id": "logo_5", "label": "Logo 5" },
        { "type": "image_picker", "id": "logo_6", "label": "Logo 6" },
        { "type": "image_picker", "id": "logo_7", "label": "Logo 7" },
        { "type": "image_picker", "id": "logo_8", "label": "Logo 8" },
        { "type": "image_picker", "id": "logo_9", "label": "Logo 9" },
        { "type": "image_picker", "id": "logo_10", "label": "Logo 10" },
        { "type": "image_picker", "id": "logo_11", "label": "Logo 11" },
        { "type": "image_picker", "id": "logo_12", "label": "Logo 12" }
      ]
    },
    {
      "type": "image_row",
      "name": "Image Row",
      "settings": [
        {
          "type": "header",
