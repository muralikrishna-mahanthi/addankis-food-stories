{%- style -%}
  {%- if section.settings.sh_font_desk != blank -%}
    {{ section.settings.sh_font_desk | font_face: font_display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.h_font_desk != blank -%}
    {{ section.settings.h_font_desk | font_face: font_display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.d_font_desk != blank -%}
    {{ section.settings.d_font_desk | font_face: font_display: 'swap' }}
  {%- endif -%}

  .cfu-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.pt_desktop }}px;
    padding-bottom: {{ section.settings.pb_desktop }}px;
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .cfu-container-{{ section.id }} {
    width: 100%;
    max-width: 1400px;
    padding: 0 4rem;
    display: flex;
    gap: 4rem;
    {% if section.settings.desktop_alignment == 'center' %}
      flex-direction: column;
      align-items: center;
      text-align: center;
    {% else %}
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    {% endif %}
  }

  .cfu-text-area-{{ section.id }} {
    max-width: 600px;
  }

  .cfu-subheading-{{ section.id }} {
    {% if section.settings.sh_font_desk != blank %}
      font-family: {{ section.settings.sh_font_desk.family }}, {{ section.settings.sh_font_desk.fallback_families }};
    {% endif %}
    font-weight: {{ section.settings.sh_weight_desk }};
    color: {{ section.settings.sh_color }};
    font-size: {{ section.settings.sh_size_desk }}rem;
    margin-bottom: {{ section.settings.sh_mb }}px;
    margin-top: 0;
    display: block;
  }

  .cfu-heading-{{ section.id }} {
    {% if section.settings.h_font_desk != blank %}
      font-family: {{ section.settings.h_font_desk.family }}, {{ section.settings.h_font_desk.fallback_families }};
    {% endif %}
    font-weight: {{ section.settings.h_weight_desk }};
    color: {{ section.settings.h_color }};
    font-size: {{ section.settings.h_size_desk }}rem;
    margin-bottom: {{ section.settings.h_mb }}px;
    margin-top: 0;
    text-transform: {{ section.settings.h_transform }};
    line-height: 1.1;
  }

  .cfu-desc-{{ section.id }} {
    {% if section.settings.d_font_desk != blank %}
      font-family: {{ section.settings.d_font_desk.family }}, {{ section.settings.d_font_desk.fallback_families }};
    {% endif %}
    font-weight: {{ section.settings.d_weight_desk }};
    color: {{ section.settings.d_color }};
    font-size: {{ section.settings.d_size_desk }}rem;
    margin: 0;
    line-height: 1.4;
  }

  .cfu-socials-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ section.settings.icon_gap }}px;
    {% if section.settings.desktop_alignment == 'center' %}
      justify-content: center;
      margin-top: 4rem;
    {% else %}
      justify-content: flex-end;
      max-width: 50%;
    {% endif %}
  }

  .cfu-icon-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    background-color: {{ section.settings.icon_bg }};
    color: {{ section.settings.icon_fill }};
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .cfu-icon-{{ section.id }} svg {
    width: {{ section.settings.icon_svg_scale }}%;
    height: {{ section.settings.icon_svg_scale }}%;
    fill: currentColor;
  }

  /* Specific fix for SVG strokes where fill doesn't apply cleanly */
  .cfu-icon-{{ section.id }}[data-platform="instagram"] svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
  }

  .cfu-icon-{{ section.id }}:hover {
    background-color: {{ section.settings.icon_bg_hover }};
    color: {{ section.settings.icon_fill_hover }};
    transform: scale(1.05);
  }

  @media screen and (max-width: 749px) {
    .cfu-section-{{ section.id }} {
      padding-top: {{ section.settings.pt_mobile }}px;
      padding-bottom: {{ section.settings.pb_mobile }}px;
    }
    .cfu-container-{{ section.id }} {
      flex-direction: column;
      padding: 0 2rem;
      align-items: flex-start;
      text-align: left;
      gap: 3rem;
    }
    .cfu-text-area-{{ section.id }} {
      max-width: 100%;
    }
    .cfu-socials-{{ section.id }} {
      max-width: 100%;
      justify-content: flex-start;
      margin-top: 0;
    }
    .cfu-subheading-{{ section.id }} {
      font-size: {{ section.settings.sh_size_mob }}rem;
    }
    .cfu-heading-{{ section.id }} {
      font-size: {{ section.settings.h_size_mob }}rem;
    }
    .cfu-desc-{{ section.id }} {
      font-size: {{ section.settings.d_size_mob }}rem;
    }

    {% if section.settings.desktop_alignment == 'center' %}
      .cfu-container-{{ section.id }} {
        align-items: center;
        text-align: center;
      }
      .cfu-socials-{{ section.id }} {
        justify-content: center;
      }
    {% endif %}
  }
{%- endstyle -%}

<div class="cfu-section-{{ section.id }}">
  <div class="cfu-container-{{ section.id }}">
    
    <div class="cfu-text-area-{{ section.id }}">
      {% if section.settings.subheading != blank %}
        <span class="cfu-subheading-{{ section.id }}">{{ section.settings.subheading }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="cfu-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.desc != blank %}
        <p class="cfu-desc-{{ section.id }}">{{ section.settings.desc }}</p>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="cfu-socials-{{ section.id }}">
        {% for block in section.blocks %}
          <a href="{{ block.settings.link | default: '#' }}" class="cfu-icon-{{ section.id }}" data-platform="{{ block.settings.platform }}" target="_blank" rel="noopener noreferrer" {{ block.shopify_attributes }}>
            <span class="visually-hidden">{{ block.settings.platform }}</span>
            {% case block.settings.platform %}
              {% when 'instagram' %}
                <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              {% when 'facebook' %}
                <svg viewBox="0 0 24 24"><path d="M22.675 0h-21.35C.593 0 0 .593 0 1.325v21.351C0 23.406.593 24 1.325 24h11.495v-9.294H9.691V11.41h3.129V8.797c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.296h-3.12V24h6.116c.73 0 1.323-.593 1.323-1.325V1.325C24 .593 23.407 0 22.675 0z"/></svg>
              {% when 'tiktok' %}
                <svg viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.01.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.22-2.31.78-4.66 2.53-6.23 1.45-1.31 3.42-2.01 5.4-1.97v4c-1.58.11-3.21.91-4.2 2.12-.99 1.25-1.22 3.03-.54 4.46.68 1.41 2.21 2.4 3.79 2.39 1.57-.01 2.99-1.02 3.55-2.45.61-1.56.52-6.52.52-6.52v-13h3.81z"/></svg>
              {% when 'x' %}
                <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              {% when 'youtube' %}
                <svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.377.55a3.016 3.016 0 0 0-2.122 2.136C0 8.07 0 12 0 12s0 3.93.501 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.55 9.377.55 9.377.55s7.505 0 9.377-.55a3.016 3.016 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              {% when 'linkedin' %}
                <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            {% endcase %}
          </a>
        {% endfor %}
      </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Custom Follow Us",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f4f4f4" },
    { "type": "range", "id": "pt_desktop", "label": "Padding Top (Desktop)", "min": 0, "max": 100, "step": 5, "default": 60 },
    { "type": "range", "id": "pb_desktop", "label": "Padding Bottom (Desktop)", "min": 0, "max": 100, "step": 5, "default": 60 },
    { "type": "range", "id": "pt_mobile", "label": "Padding Top (Mobile)", "min": 0, "max": 100, "step": 5, "default": 40 },
    { "type": "range", "id": "pb_mobile", "label": "Padding Bottom (Mobile)", "min": 0, "max": 100, "step": 5, "default": 40 },
    { "type": "select", "id": "desktop_alignment", "label": "Content Focus (Desktop)", "default": "split", "options": [
      { "value": "split", "label": "Split (Left Text, Right Socials)" },
      { "value": "center", "label": "Centered Everything" }
    ]},

    { "type": "header", "content": "Subheading" },
    { "type": "text", "id": "subheading", "label": "Subheading Text", "default": "Stay connected" },
    { "type": "font_picker", "id": "sh_font_desk", "label": "Font Family (Desktop)", "default": "assistant_n4" },
    { "type": "range", "id": "sh_size_desk", "label": "Size (Desktop)", "min": 1, "max": 5, "step": 0.1, "default": 1.6, "unit": "rem" },
    { "type": "select", "id": "sh_weight_desk", "label": "Weight", "default": "600", "options": [{"value":"300","label":"Light"},{"value":"400","label":"Normal"},{"value":"500","label":"Medium"},{"value":"600","label":"Semi Bold"},{"value":"700","label":"Bold"},{"value":"800","label":"Extra Bold"},{"value":"900","label":"Black"}] },
    { "type": "color", "id": "sh_color", "label": "Color", "default": "#8B4513" },
    { "type": "range", "id": "sh_size_mob", "label": "Size (Mobile)", "min": 1, "max": 5, "step": 0.1, "default": 1.4, "unit": "rem" },
    { "type": "range", "id": "sh_mb", "label": "Margin Bottom", "min": 0, "max": 50, "step": 2, "default": 16, "unit": "px" },

    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading", "label": "Heading Text", "default": "FOLLOW LAY'S" },
    { "type": "font_picker", "id": "h_font_desk", "label": "Font Family (Desktop)", "default": "assistant_n4" },
    { "type": "range", "id": "h_size_desk", "label": "Size (Desktop)", "min": 2, "max": 10, "step": 0.2, "default": 4.5, "unit": "rem" },
    { "type": "select", "id": "h_weight_desk", "label": "Weight", "default": "900", "options": [{"value":"300","label":"Light"},{"value":"400","label":"Normal"},{"value":"500","label":"Medium"},{"value":"600","label":"Semi Bold"},{"value":"700","label":"Bold"},{"value":"800","label":"Extra Bold"},{"value":"900","label":"Black"}] },
    { "type": "color", "id": "h_color", "label": "Color", "default": "#C87C10" },
    { "type": "range", "id": "h_size_mob", "label": "Size (Mobile)", "min": 2, "max": 8, "step": 0.2, "default": 3.2, "unit": "rem" },
    { "type": "range", "id": "h_mb", "label": "Margin Bottom", "min": 0, "max": 50, "step": 2, "default": 24, "unit": "px" },
    { "type": "select", "id": "h_transform", "label": "Text Transform", "default": "uppercase", "options": [{"value":"none","label":"None"},{"value":"uppercase","label":"Uppercase"}] },

    { "type": "header", "content": "Description" },
    { "type": "textarea", "id": "desc", "label": "Description Text", "default": "Stay in the know on the latest products, recipes, and inspo." },
    { "type": "font_picker", "id": "d_font_desk", "label": "Font Family (Desktop)", "default": "assistant_n4" },
    { "type": "range", "id": "d_size_desk", "label": "Size (Desktop)", "min": 1, "max": 4, "step": 0.1, "default": 1.6, "unit": "rem" },
    { "type": "select", "id": "d_weight_desk", "label": "Weight", "default": "500", "options": [{"value":"300","label":"Light"},{"value":"400","label":"Normal"},{"value":"500","label":"Medium"},{"value":"600","label":"Semi Bold"},{"value":"700","label":"Bold"},{"value":"800","label":"Extra Bold"},{"value":"900","label":"Black"}] },
    { "type": "color", "id": "d_color", "label": "Color", "default": "#1a1a1a" },
    { "type": "range", "id": "d_size_mob", "label": "Size (Mobile)", "min": 1, "max": 4, "step": 0.1, "default": 1.4, "unit": "rem" },
    
    { "type": "header", "content": "Social Icons Style" },
    { "type": "range", "id": "icon_size", "label": "Icon Wrapper Size", "min": 40, "max": 100, "step": 2, "default": 64, "unit": "px" },
    { "type": "range", "id": "icon_svg_scale", "label": "Icon Internal Size", "min": 50, "max": 100, "step": 5, "default": 50, "unit": "%" },
    { "type": "color", "id": "icon_bg", "label": "Icon Background", "default": "#ffffff" },
    { "type": "color", "id": "icon_fill", "label": "Icon Color", "default": "#1a1a1a" },
    { "type": "color", "id": "icon_bg_hover", "label": "Icon Background (Hover)", "default": "#1a1a1a" },
    { "type": "color", "id": "icon_fill_hover", "label": "Icon Color (Hover)", "default": "#ffffff" },
    { "type": "range", "id": "icon_gap", "label": "Gap between icons", "min": 5, "max": 50, "step": 1, "default": 20, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "social_icon",
      "name": "Social Icon",
      "settings": [
        { "type": "select", "id": "platform", "label": "Platform", "options": [
          {"value": "instagram", "label": "Instagram"},
          {"value": "facebook", "label": "Facebook"},
          {"value": "tiktok", "label": "TikTok"},
          {"value": "x", "label": "X (Twitter)"},
          {"value": "youtube", "label": "YouTube"},
          {"value": "linkedin", "label": "LinkedIn"}
        ]},
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "Custom Follow Us",
      "blocks": [
        { "type": "social_icon", "settings": { "platform": "instagram" } },
        { "type": "social_icon", "settings": { "platform": "facebook" } },
        { "type": "social_icon", "settings": { "platform": "tiktok" } },
        { "type": "social_icon", "settings": { "platform": "x" } },
        { "type": "social_icon", "settings": { "platform": "youtube" } }
      ]
    }
  ]
}
{% endschema %}
