{%- style -%}
  .wwsf-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .wwsf-container-{{ section.id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 5%;
  }

  /* Subheading */
  .wwsf-sub-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    color: {{ section.settings.sub_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: {{ section.settings.sub_size_mob }}px;
    font-weight: {{ section.settings.sub_weight }};
    margin-bottom: 20px;
  }

  .wwsf-sub-{{ section.id }}::before {
    content: "";
    width: 30px;
    height: 1.5px;
    background-color: {{ section.settings.sub_color }};
  }

  /* Heading */
  .wwsf-h-{{ section.id }} {
    color: {{ section.settings.h_color }};
    font-size: {{ section.settings.h_size_mob }}px;
    font-weight: {{ section.settings.h_weight }};
    line-height: 1.2;
    margin-bottom: 40px;
    max-width: 900px;
  }

  .wwsf-h-{{ section.id }} em, 
  .wwsf-h-{{ section.id }} i {
    color: {{ section.settings.sub_color }};
    font-style: italic;
  }

  /* Grid / Wrapper */
  .wwsf-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    background: {{ section.settings.box_bg }};
    border-radius: {{ section.settings.box_radius }}px;
    border: 1px solid {{ section.settings.border_color }};
    /* Remove overflow hidden to avoid cutting off box-shadows if added later, but useful for borders */
  }

  /* Cards */
  .wwsf-card-{{ section.id }} {
    padding: {{ section.settings.card_padding_mob }}px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .wwsf-card-{{ section.id }}:last-child {
    border-bottom: none;
  }

  .wwsf-icon-{{ section.id }} {
    width: {{ section.settings.icon_width }}px;
    height: auto;
    margin-bottom: {{ section.settings.m_icon_h }}px;
    object-fit: contain;
  }

  .wwsf-card-h-{{ section.id }} {
    color: {{ section.settings.card_h_color }};
    font-size: {{ section.settings.card_h_size_mob }}px;
    font-weight: {{ section.settings.card_h_weight }};
    margin-bottom: {{ section.settings.m_h_p }}px;
    line-height: 1.3;
  }

  .wwsf-card-p-{{ section.id }} {
    color: {{ section.settings.card_p_color }};
    font-size: {{ section.settings.card_p_size_mob }}px;
    font-weight: {{ section.settings.card_p_weight }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (min-width: 768px) {
    .wwsf-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
    .wwsf-sub-{{ section.id }} { font-size: {{ section.settings.sub_size }}px; }
    .wwsf-h-{{ section.id }} { 
      font-size: {{ section.settings.h_size }}px; 
      margin-bottom: 60px;
    }
    .wwsf-card-{{ section.id }} { padding: {{ section.settings.card_padding }}px; }
    .wwsf-card-h-{{ section.id }} { font-size: {{ section.settings.card_h_size }}px; }
    .wwsf-card-p-{{ section.id }} { font-size: {{ section.settings.card_p_size }}px; }
  }

  @media screen and (min-width: 992px) {
    .wwsf-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.blocks.size | default: 4 }}, 1fr);
    }
    .wwsf-card-{{ section.id }} {
      border-bottom: none;
      border-right: 1px solid {{ section.settings.border_color }};
    }
    .wwsf-card-{{ section.id }}:last-child {
      border-right: none;
    }
  }

  /* Font Handling */
  {% if section.settings.h_font.family %}
    {{ section.settings.h_font | font_face: font_display: 'swap' }}
    .wwsf-h-{{ section.id }} { font-family: {{ section.settings.h_font.family }}, {{ section.settings.h_font.fallback_families }}; }
  {% endif %}
  {% if section.settings.sub_font.family %}
    {{ section.settings.sub_font | font_face: font_display: 'swap' }}
    .wwsf-sub-{{ section.id }} { font-family: {{ section.settings.sub_font.family }}, {{ section.settings.sub_font.fallback_families }}; }
  {% endif %}
  {% if section.settings.card_h_font.family %}
    {{ section.settings.card_h_font | font_face: font_display: 'swap' }}
    .wwsf-card-h-{{ section.id }} { font-family: {{ section.settings.card_h_font.family }}, {{ section.settings.card_h_font.fallback_families }}; }
  {% endif %}
  {% if section.settings.card_p_font.family %}
    {{ section.settings.card_p_font | font_face: font_display: 'swap' }}
    .wwsf-card-p-{{ section.id }} { font-family: {{ section.settings.card_p_font.family }}, {{ section.settings.card_p_font.fallback_families }}; }
  {% endif %}

{%- endstyle -%}

<div class="wwsf-{{ section.id }}">
  <div class="wwsf-container-{{ section.id }}">
    {% if section.settings.subheading != blank %}
      <div class="wwsf-sub-{{ section.id }}">{{ section.settings.subheading }}</div>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="wwsf-h-{{ section.id }}">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="wwsf-grid-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="wwsf-card-{{ section.id }}" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <img src="{{ block.settings.icon | image_url: width: 200 }}" class="wwsf-icon-{{ section.id }}" alt="{{ block.settings.title | escape }}" loading="lazy">
          {% endif %}
          
          {% if block.settings.title != blank %}
            <h3 class="wwsf-card-h-{{ section.id }}">{{ block.settings.title }}</h3>
          {% endif %}
          
          {% if block.settings.text != blank %}
            <div class="wwsf-card-p-{{ section.id }}">{{ block.settings.text }}</div>
          {% endif %}
        </div>
      {% else %}
        <!-- Placeholder content if no blocks added -->
        {% for i in (1..4) %}
          <div class="wwsf-card-{{ section.id }}">
            <h3 class="wwsf-card-h-{{ section.id }}">Value {{ i }}</h3>
            <div class="wwsf-card-p-{{ section.id }}">Add some text describing this value in the theme editor.</div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</div>

