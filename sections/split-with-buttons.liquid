{%- style -%}
  {{ section.settings.heading_font | font_face: display: 'swap' }}
  {{ section.settings.btn_font | font_face: display: 'swap' }}

  .split-buttons-{{ section.id }} {
    display: flex;
    width: 100%;
    min-height: auto; 
    align-items: stretch;
  }

  .split-buttons__left {
    flex: 0 0 50%;
    width: 50%;
    background-color: {{ section.settings.left_bg_color }};
    display: flex;
    align-items: center;
    justify-content: flex-start;
    position: relative;
    padding: 6rem;
    overflow: hidden;
  }

  /* Image logic for Left Side */
  .split-buttons__left-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  /* Text logic for Left Side */
  .split-buttons__left-content {
    position: relative;
    z-index: 2;
    max-width: 600px;
    width: 100%;
    text-align: left;
  }

  .split-buttons__heading {
    margin: 0 0 2rem 0;
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    font-size: clamp(2.5rem, 4vw, {{ section.settings.heading_size }}rem);
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    line-height: 1.1;
    {%- if section.settings.heading_uppercase -%}text-transform: uppercase;{%- endif -%}
  }
  
  .split-buttons__text {
    font-size: 1.6rem;
    color: {{ section.settings.heading_color | color_modify: 'alpha', 0.8 }};
    line-height: 1.6;
  }

  .split-buttons__right {
    flex: 0 0 50%;
    width: 50%;
    background-color: {{ section.settings.right_bg_color }};
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: {{ section.settings.btn_container_padding_y }}px {{ section.settings.btn_container_padding_x }}px;
  }

  .split-buttons__button-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    max-width: 450px;
  }

  .split-buttons__btn {
    display: flex;
    align-items: center;
    justify-content: space-between; /* text left, icon right */
    text-decoration: none;
    text-align: left;
    width: 100%;
    transition: all 0.3s ease;
    
    font-family: {{ section.settings.btn_font.family }}, {{ section.settings.btn_font.fallback_families }};
    font-size: {{ section.settings.btn_size }}rem;
    font-weight: {{ section.settings.btn_weight }};
    color: {{ section.settings.btn_text_color }};
    background-color: {{ section.settings.btn_bg_color }};
    border: 1px solid {{ section.settings.btn_border_color }};
    border-radius: {{ section.settings.btn_border_radius }}px;
    padding: {{ section.settings.btn_padding_y }}px {{ section.settings.btn_padding_x }}px;
  }

  .split-buttons__btn-text {
    flex-grow: 1;
  }

  .split-buttons__btn-icon {
    flex-shrink: 0;
    margin-left: 2rem;
    transition: transform 0.3s ease;
  }

  .split-buttons__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 15px rgba(0,0,0,0.05);
    background-color: {{ section.settings.btn_bg_hover_color | default: section.settings.btn_border_color }};
    color: {{ section.settings.btn_text_hover_color | default: '#ffffff' }};
  }

  .split-buttons__btn:hover .split-buttons__btn-icon {
    transform: translateX(4px);
  }

  @media screen and (max-width: 768px) {
    .split-buttons-{{ section.id }} {
      flex-direction: column;
    }
    .split-buttons__left, .split-buttons__right {
      flex: 0 0 100%;
      width: 100%;
      padding: 4rem 2rem;
      min-height: 250px;
    }
  }
{%- endstyle -%}

<section class="split-buttons-{{ section.id }}" id="SplitButtons-{{ section.id }}">
  <!-- Left Half -->
  <div class="split-buttons__left">
    {%- if section.settings.left_content_type == 'image' -%}
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'split-buttons__left-image', loading: 'lazy' }}
      {%- else -%}
        <div style="background: #EFEFEF; width: 100%; height: 100%; position: absolute; display:flex; align-items:center; justify-content:center; color:#999;">Image Placeholder</div>
      {%- endif -%}
    {%- else -%}
      <div class="split-buttons__left-content">
        {%- if section.settings.heading != blank -%}
          <h2 class="split-buttons__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="split-buttons__text">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <!-- Right Half -->
  <div class="split-buttons__right">
    <div class="split-buttons__button-wrapper">
      
      {%- if section.settings.btn_1_text != blank -%}
        <a href="{{ section.settings.btn_1_link | default: '#' }}" class="split-buttons__btn">
          <span class="split-buttons__btn-text">{{ section.settings.btn_1_text }}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="split-buttons__btn-icon"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.btn_2_text != blank -%}
        <a href="{{ section.settings.btn_2_link | default: '#' }}" class="split-buttons__btn">
          <span class="split-buttons__btn-text">{{ section.settings.btn_2_text }}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="split-buttons__btn-icon"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.btn_3_text != blank -%}
        <a href="{{ section.settings.btn_3_link | default: '#' }}" class="split-buttons__btn">
          <span class="split-buttons__btn-text">{{ section.settings.btn_3_text }}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="split-buttons__btn-icon"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.btn_4_text != blank -%}
        <a href="{{ section.settings.btn_4_link | default: '#' }}" class="split-buttons__btn">
          <span class="split-buttons__btn-text">{{ section.settings.btn_4_text }}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="split-buttons__btn-icon"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Split With Buttons",
  "tag": "section",
  "class": "section split-with-buttons",
  "settings": [
    {
      "type": "header",
      "content": "Split Background Colors",
      "info": "Set both sides to the same color to create a unified continuous background effect."
    },
    {
      "type": "color",
      "id": "left_bg_color",
      "label": "Left Side Background Color",
      "default": "#125191"
    },
    {
      "type": "color",
      "id": "right_bg_color",
      "label": "Right Side Background Color",
      "default": "#125191"
    },

    {
      "type": "header",
      "content": "Left Section Content"
    },
    {
      "type": "select",
      "id": "left_content_type",
      "label": "Left Content Type",
      "options": [
        { "value": "text", "label": "Heading & Description" },
        { "value": "image", "label": "Image Only" }
      ],
      "default": "text"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (used if 'Image Only' selected)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DISCOVER MORE\nABOUT US"
    },
    { "type": "font_picker", "id": "heading_font", "label": "Heading Font", "default": "sans-serif" },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 2,
      "max": 8,
      "step": 0.5,
      "default": 4.5,
      "unit": "rem"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        {"value": "100", "label": "100 - Thin"},
        {"value": "400", "label": "400 - Normal"},
        {"value": "600", "label": "600 - Semi Bold"},
        {"value": "700", "label": "700 - Bold"},
        {"value": "800", "label": "800 - Extra Bold"},
        {"value": "900", "label": "900 - Bolder"}
      ],
      "default": "800"
    },
    {
      "type": "checkbox",
      "id": "heading_uppercase",
      "label": "Force Heading to Uppercase",
      "default": true
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#A0C4E7"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p></p>"
    },

    {
      "type": "header",
      "content": "Right Section Spacing Constraints"
    },
    {
      "type": "range",
      "id": "btn_container_padding_x",
      "label": "Right Side Horizontal Padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "btn_container_padding_y",
      "label": "Right Side Vertical Padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "default": 60,
      "unit": "px"
    },

    {
      "type": "header",
      "content": "Global Button Design"
    },
    { "type": "font_picker", "id": "btn_font", "label": "Button Font", "default": "sans-serif" },
    {
      "type": "range",
      "id": "btn_size",
      "label": "Button Font Size",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.6,
      "unit": "rem"
    },
    {
      "type": "select",
      "id": "btn_weight",
      "label": "Button Font Weight",
      "options": [
        {"value": "400", "label": "400 - Normal"},
        {"value": "500", "label": "500 - Medium"},
        {"value": "600", "label": "600 - Semi Bold"},
        {"value": "700", "label": "700 - Bold"},
        {"value": "800", "label": "800 - Extra Bold"}
      ],
      "default": "600"
    },
    { "type": "color", "id": "btn_text_color", "label": "Button Text Color", "default": "#125191" },
    { "type": "color", "id": "btn_bg_color", "label": "Button Background Color", "default": "#B7D4F0" },
    { "type": "color", "id": "btn_border_color", "label": "Button Border Color", "default": "transparent" },
    
    { "type": "color", "id": "btn_text_hover_color", "label": "Button Hover Text Color", "default": "#ffffff" },
    { "type": "color", "id": "btn_bg_hover_color", "label": "Button Hover Background Color", "default": "#0F4174" },

    { "type": "range", "id": "btn_border_radius", "label": "Button Border Radius (Pill Shape)", "min": 0, "max": 100, "step": 1, "default": 50, "unit": "px" },
    { "type": "range", "id": "btn_padding_x", "label": "Button Inner Padding (Horizontal)", "min": 10, "max": 100, "step": 2, "default": 30, "unit": "px" },
    { "type": "range", "id": "btn_padding_y", "label": "Button Inner Padding (Vertical)", "min": 5, "max": 50, "step": 1, "default": 15, "unit": "px" },

    {
      "type": "header",
      "content": "Button 1"
    },
    { "type": "text", "id": "btn_1_text", "label": "Button 1 Label", "default": "Careers" },
    { "type": "url", "id": "btn_1_link", "label": "Button 1 Link" },

    {
      "type": "header",
      "content": "Button 2"
    },
    { "type": "text", "id": "btn_2_text", "label": "Button 2 Label", "default": "Global Code of Conduct" },
    { "type": "url", "id": "btn_2_link", "label": "Button 2 Link" },

    {
      "type": "header",
      "content": "Button 3"
    },
    { "type": "text", "id": "btn_3_text", "label": "Button 3 Label", "default": "Leadership" },
    { "type": "url", "id": "btn_3_link", "label": "Button 3 Link" },

    {
      "type": "header",
      "content": "Button 4"
    },
    { "type": "text", "id": "btn_4_text", "label": "Button 4 Label", "default": "Awards" },
    { "type": "url", "id": "btn_4_link", "label": "Button 4 Link" }
  ],
  "presets": [
    {
      "name": "Split With Buttons"
    }
  ]
}
{% endschema %}
