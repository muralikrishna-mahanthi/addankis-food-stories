{%- style -%}
  .brands-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .brands-container-{{ section.id }} {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .brands-header-{{ section.id }} {
    margin-bottom: 40px;
    text-align: {{ section.settings.header_alignment }};
  }

  .brands-heading-{{ section.id }} {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
  }

  .brands-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: {{ section.settings.gap }}px;
  }

  @media screen and (min-width: 750px) {
    .brands-grid-{{ section.id }} {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: {{ section.settings.row_height }}px;
    }
  }

  .brand-item-{{ section.id }} {
    position: relative;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease;
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    .brand-item-{{ section.id }} {
      aspect-ratio: 1/1;
    }
  }

  {%- for block in section.blocks -%}
    @media screen and (min-width: 750px) {
      .brand-item--{{ block.id }} {
        grid-column: span {{ block.settings.column_span }};
        grid-row: span {{ block.settings.row_span }};
      }
    }
  {%- endfor -%}

  .brand-link-{{ section.id }} {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    position: relative;
  }

  .brand-item-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-overlay-{{ section.id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, 
      {{ section.settings.overlay_color | color_modify: 'alpha', section.settings.overlay_opacity }} 0%, 
      transparent 50%
    );
    display: flex;
    align-items: flex-end;
    padding: 24px;
    transition: background 0.3s ease;
  }

  .brand-title-{{ section.id }} {
    margin: 0;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.block_heading_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
{%- endstyle -%}

<div class="brands-section-{{ section.id }}">
  <div class="brands-container-{{ section.id }}">
    {%- if section.settings.section_title != blank -%}
      <div class="brands-header-{{ section.id }}">
        <h2 class="brands-heading-{{ section.id }}">{{ section.settings.section_title }}</h2>
      </div>
    {%- endif -%}

    <div class="brands-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="brand-item-{{ section.id }} brand-item--{{ block.id }}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="brand-link-{{ section.id }}">
          {%- else -%}
            <div class="brand-link-{{ section.id }}">
          {%- endif -%}
            
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1500 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

            <div class="brand-overlay-{{ section.id }}">
              <h3 class="brand-title-{{ section.id }}">{{ block.settings.heading }}</h3>
            </div>

          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Explore Brands Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Heading",
      "default": "Explore Collaborated Brands"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading Size",
      "default": 32
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Grid Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Total Grid Columns",
      "default": 3
    },
    {
      "type": "range",
      "id": "row_height",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Base Row Height",
      "default": 300
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Gap between items",
      "default": 16
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Image Border Radius",
      "default": 32
    },
    {
      "type": "header",
      "content": "Overlay & Typography"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Shadow Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay Opacity",
      "default": 0.5
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "block_heading_size",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Block Title Size",
      "default": 24
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Brand Name",
          "default": "Brand Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand Link"
        },
        {
          "type": "header",
          "content": "Grid Spacing Control"
        },
        {
          "type": "range",
          "id": "column_span",
          "min": 1,
          "max": 4,
          "step": 1,
          "label": "Width (Columns Span)",
          "default": 1
        },
        {
          "type": "range",
          "id": "row_span",
          "min": 1,
          "max": 4,
          "step": 1,
          "label": "Height (Rows Span)",
          "default": 1
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Explore Brands Grid",
      "blocks": [
        { "type": "brand", "settings": { "column_span": 1, "row_span": 1 } },
        { "type": "brand", "settings": { "column_span": 1, "row_span": 1 } },
        { "type": "brand", "settings": { "column_span": 1, "row_span": 2 } },
        { "type": "brand", "settings": { "column_span": 2, "row_span": 1 } }
      ]
    }
  ]
}
{% endschema %}
