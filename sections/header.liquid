<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link
  rel="stylesheet"
  href="{{ 'component-cart-notification.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }

  /* PEPSICO PREMIUM BRANDED HEADER STYLES */
  :root {
    --header-shrink-ratio: 0.8;
  }

  .header-wrapper {
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: 100;
  }

  {%- if section.settings.enable_transparent_header and template.name == 'index' -%}
    .header-wrapper:not(.scrolled-past-header) {
      position: absolute;
      width: 100%;
      background: transparent !important;
      border-bottom: none !important;
    }
    .header-wrapper:not(.scrolled-past-header) .header__menu-item,
    .header-wrapper:not(.scrolled-past-header) .header__active-menu-item,
    .header-wrapper:not(.scrolled-past-header) .header__icon {
      color: {{ section.settings.transparent_text_color }} !important;
    }
    .header-wrapper:not(.scrolled-past-header) .header__heading-logo {
      filter: {% if section.settings.transparent_text_color == '#ffffff' %}brightness(0) invert(1){% else %}none{% endif %};
    }
  {%- endif -%}

  /* Sticky State (Scrolled) */
  .scrolled-past-header {
    background: {{ section.settings.sticky_bg_color | alpha: 0.9 }} !important;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
  }

  .header {
    display: grid !important;
    grid-template-columns: 1fr auto 1fr !important;
    align-items: center !important;
    transition: padding 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .scrolled-past-header .header {
    padding-top: 1rem !important;
    padding-bottom: 1rem !important;
  }

  .header__heading { grid-area: auto !important; justify-self: start !important; transition: transform 0.5s ease; }
  .header__inline-menu { grid-area: auto !important; justify-self: center !important; }
  .header__icons { 
    grid-area: auto !important; 
    justify-self: end !important; 
    display: flex !important;
    align-items: center !important;
    gap: 1.5rem !important;
  }

  /* Bold Icons Styling */
  .header__icon svg {
    width: 2.8rem !important;
    height: 2.8rem !important;
    stroke-width: 2.5px !important;
  }

  /* Shrink Logo on sticky */
  .scrolled-past-header .header__heading-logo {
    transform: scale(var(--header-shrink-ratio));
  }

  .header__menu-item {
    position: relative;
    transition: all 0.3s ease;
    padding: 0.5rem 1.5rem;
    font-weight: 700;
  }

  .header__menu-item::after {
    content: '';
    position: absolute;
    bottom: 0px;
    left: 50%;
    width: 0;
    height: 3px;
    background: currentColor;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    transform: translateX(-50%);
  }

  .header__menu-item:hover::after {
    width: 70%;
  }

  .header__icon {
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .header__icon:hover {
    transform: scale(1.2) translateY(-2px);
  }

  /* PEPSICO SLIDE-OUT SEARCH OVERLAY */
  .header-search-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.sticky_bg_color | default: '#ffffff' }};
    z-index: 200;
    display: flex;
    align-items: center;
    padding: 0 3rem;
    opacity: 0;
    pointer-events: none;
    transform: translateX(20px);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .header-search-overlay.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  .header-search-overlay__form {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .header-search-overlay__input {
    width: 100%;
    border: none;
    background: transparent;
    font-size: 2rem;
    font-weight: 700;
    padding: 1rem 0;
    color: inherit;
    outline: none;
  }

  .header-search-overlay__close {
    padding: 2rem;
    cursor: pointer;
    font-weight: 900;
    font-size: 1.5rem;
  }

</style>

{%- style -%}
  .header {
    padding: {{ section.settings.padding_top | times: 1 | round: 0 }}px 3rem {{ section.settings.padding_bottom | times: 1 | round: 0 }}px 3rem;
  }

  .section-header {
    position: sticky; /* This is for fixing a Safari z-index issue. PR #2147 */
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
    z-index: 100;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign header_tag = 'div'
  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif
%}

<{{ header_tag }}
  {% if header_tag == 'sticky-header' %}
    data-sticky-type="{{ section.settings.sticky_header_type }}"
  {% endif %}
  class="header-wrapper color-{{ section.settings.color_scheme }} gradient"
>
  <!-- Search Overlay (Pepsico style) -->
  <div class="header-search-overlay" id="PepsiSearchOverlay">
    <div class="header-search-overlay__form">
      <form action="{{ routes.search_url }}" method="get" role="search" class="search">
        <input class="header-search-overlay__input" type="search" name="q" value="" placeholder="Search our story..." aria-label="Search">
      </form>
    </div>
    <div class="header-search-overlay__close" onclick="closePepsiSearch()">✕</div>
  </div>

  <header class="header page-width">
    
    <!-- Logo Left -->
    <div class="header__heading">
      <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper">
             {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
             {{ settings.logo | image_url: width: 600 | image_tag: class: 'header__heading-logo', widths: '200, 400, 600', height: settings.logo_width, width: settings.logo_width, alt: logo_alt, preload: true }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Menu Center -->
    {%- if section.settings.menu != blank -%}
      {%- if section.settings.menu_type_desktop == 'dropdown' -%}
        {% render 'header-dropdown-menu' %}
      {%- elsif section.settings.menu_type_desktop != 'drawer' -%}
        {% render 'header-mega-menu' %}
      {%- endif -%}
    {%- endif -%}

    <!-- Icons Right -->
    <div class="header__icons">
      <!-- World Icon -->
      <a href="{{ section.settings.world_map_url | default: '#' }}" class="header__icon link focus-inset">
        <span class="svg-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </span>
      </a>

      <!-- Premium Search Trigger -->
      <button type="button" class="header__icon link focus-inset" onclick="openPepsiSearch()">
        <span class="svg-wrapper">
          <svg class="icon icon-search" aria-hidden="true" focusable="false" role="presentation"><use href="#icon-search"></use></svg>
        </span>
      </button>

      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__icon link focus-inset"><span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span></a>
      {%- endif -%}

      {%- unless template.name == 'index' -%}
        <a href="{{ routes.cart_url }}" class="header__icon link focus-inset" id="cart-icon-bubble">
          {% if cart == empty %}<span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
          {% else %}<span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>{% endif %}
          {%- if cart != empty -%}<div class="cart-count-bubble">{%- if cart.item_count < 100 -%}<span aria-hidden="true">{{ cart.item_count }}</span>{%- endif -%}</div>{%- endif -%}
        </a>
      {%- endunless -%}
    </div>
  </header>
</{{ header_tag }}>

<script>
  function openPepsiSearch() {
    document.getElementById('PepsiSearchOverlay').classList.add('is-active');
    document.querySelector('.header-search-overlay__input').focus();
  }
  function closePepsiSearch() {
    document.getElementById('PepsiSearchOverlay').classList.remove('is-active');
  }

  class StickyHeader extends HTMLElement {
    constructor() { super(); }
    connectedCallback() {
      this.headerWrapper = this.closest('.header-wrapper');
      this.onScrollHandler = this.onScroll.bind(this);
      window.addEventListener('scroll', this.onScrollHandler, false);
      this.onScroll();
    }
    onScroll() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      if (scrollTop > 50) {
        this.headerWrapper.classList.add('scrolled-past-header');
      } else {
        this.headerWrapper.classList.remove('scrolled-past-header');
      }
    }
  }
  customElements.define('sticky-header', StickyHeader);
</script>

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "settings": [
    {
      "type": "header",
      "content": "PepsiCo Styling"
    },
    { "type": "checkbox", "id": "enable_transparent_header", "label": "Transparent Header (Home Page)", "default": true },
    { "type": "color", "id": "transparent_text_color", "label": "Transparent Header Text Color", "default": "#ffffff" },
    { "type": "color", "id": "sticky_bg_color", "label": "Sticky Header Background", "default": "#ffffff" },
    { "type": "url", "id": "world_map_url", "label": "World Map URL" },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "select",
      "id": "menu_type_desktop",
      "options": [
        { "value": "dropdown", "label": "t:sections.header.settings.menu_type_desktop.options__1.label" },
        { "value": "mega", "label": "t:sections.header.settings.menu_type_desktop.options__2.label" }
      ],
      "default": "dropdown",
      "label": "t:sections.header.settings.menu_type_desktop.label"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "always", "label": "Always" }
      ],
      "default": "always",
      "label": "Sticky behavior"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    { "type": "range", "id": "margin_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Margin Bottom", "default": 0 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 40, "step": 4, "unit": "px", "label": "Padding Top", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 40, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 24 }
  ]
}
{% endschema %}
