{%- style -%}
  {%- if section.settings.heading_font != blank -%}
    {{ section.settings.heading_font | font_face: display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.subheading_font != blank -%}
    {{ section.settings.subheading_font | font_face: display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.description_font != blank -%}
    {{ section.settings.description_font | font_face: display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.card_heading_font != blank -%}
    {{ section.settings.card_heading_font | font_face: display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.card_text_font != blank -%}
    {{ section.settings.card_text_font | font_face: display: 'swap' }}
  {%- endif -%}

  .strategy-scroller-{{ section.id }} {
    position: relative;
    /* Height determines how 'long' the horizontal scroll feels */
    height: 400vh; 
    background: {{ section.settings.bg_color }};
  }

  .strategy-scroller__sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh; /* Better for mobile browser bars */
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: {{ section.settings.track_pb_desktop }}vh; /* Desktop push from bottom edge */
  }

  .strategy-scroller__header {
    padding: 0 4rem;
    margin-bottom: 4rem;
    z-index: 10;
    text-align: {{ section.settings.header_alignment }};
  }

  .strategy-scroller__subheading {
    font-size: {{ section.settings.subheading_size_desktop }}rem;
    {% if section.settings.subheading_font != blank %}
    font-family: {{ section.settings.subheading_font.family }}, {{ section.settings.subheading_font.fallback_families }};
    {% endif %}
    font-weight: {{ section.settings.subheading_weight }};
    color: {{ section.settings.subheading_color }};
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
  }

  .strategy-scroller__heading {
    font-size: {{ section.settings.heading_size_desktop }}rem;
    {% if section.settings.heading_font != blank %}
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    {% endif %}
    font-weight: {{ section.settings.heading_weight }};
    line-height: 0.9;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    margin: 0;
  }

  .strategy-scroller__description {
    font-size: {{ section.settings.description_size_desktop }}rem;
    {% if section.settings.description_font != blank %}
    font-family: {{ section.settings.description_font.family }}, {{ section.settings.description_font.fallback_families }};
    {% endif %}
    font-weight: {{ section.settings.description_weight }};
    color: {{ section.settings.description_color }};
    margin-top: 2rem;
    line-height: 1.5;
    max-width: 800px;
    {%- if section.settings.header_alignment == 'center' -%}
      margin-left: auto;
      margin-right: auto;
    {%- elsif section.settings.header_alignment == 'right' -%}
      margin-left: auto;
    {%- endif -%}
  }

  .strategy-scroller__track-wrapper {
    width: 100%;
    overflow: visible;
  }

  .strategy-scroller__track {
    display: flex;
    padding-left: {{ section.settings.track_pl }}rem;
    padding-right: {{ section.settings.track_pr }}rem;
    will-change: transform;
    gap: {{ section.settings.card_gap }}rem;
  }

  .strategy-scroller__card {
    flex-shrink: 0;
    width: 70vw;
    max-width: 600px;
    height: 60vh;
    position: relative;
    border-radius: 2rem;
    overflow: hidden;
    background: #1a1a1a;
    transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .strategy-scroller__card-media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .strategy-scroller__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
    transition: transform 1s ease;
  }

  .strategy-scroller__card:hover .strategy-scroller__card-media img {
    transform: scale(1.1);
  }

  .strategy-scroller__card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: {{ section.settings.card_pt }}rem {{ section.settings.card_px }}rem {{ section.settings.card_pb }}rem;
    z-index: 5;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    color: #ffffff;
  }

  .strategy-scroller__card-step {
    font-size: {{ section.settings.card_heading_size_desktop }}rem;
    {% if section.settings.card_heading_font != blank %}
    font-family: {{ section.settings.card_heading_font.family }}, {{ section.settings.card_heading_font.fallback_families }};
    {% endif %}
    font-weight: {{ section.settings.card_heading_weight }};
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
    line-height: 1.1;
    color: {{ section.settings.card_heading_color }};
  }

  .strategy-scroller__card-text {
    font-size: {{ section.settings.card_text_size_desktop }}rem;
    {% if section.settings.card_text_font != blank %}
    font-family: {{ section.settings.card_text_font.family }}, {{ section.settings.card_text_font.fallback_families }};
    {% endif %}
    font-weight: {{ section.settings.card_text_weight }};
    color: {{ section.settings.card_text_color }};
    line-height: 1.4;
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .strategy-scroller__card {
      width: 85vw;
      height: 50vh;
    }
    .strategy-scroller__subheading {
      font-size: {{ section.settings.subheading_size_mobile }}rem;
    }
    .strategy-scroller__heading {
      font-size: {{ section.settings.heading_size_mobile }}rem;
    }
    .strategy-scroller__description {
      font-size: {{ section.settings.description_size_mobile }}rem;
    }
    .strategy-scroller__card-step {
      font-size: {{ section.settings.card_heading_size_mobile }}rem;
    }
    .strategy-scroller__card-text {
      font-size: {{ section.settings.card_text_size_mobile }}rem;
    }
    .strategy-scroller__sticky {
      padding-bottom: {{ section.settings.track_pb_mobile }}vh;
    }
  }
{%- endstyle -%}

<div class="strategy-scroller-{{ section.id }} strategy-scroller" id="StrategyScroller-{{ section.id }}">
  <div class="strategy-scroller__sticky">
    
    <div class="strategy-scroller__header">
      {%- if section.settings.subheading != blank -%}
        <span class="strategy-scroller__subheading">{{ section.settings.subheading }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="strategy-scroller__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="strategy-scroller__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="strategy-scroller__track-wrapper">
      <div class="strategy-scroller__track" id="StrategyTrack-{{ section.id }}">
        
        {%- for block in section.blocks -%}
          <div class="strategy-scroller__card" {{ block.shopify_attributes }}>
            <div class="strategy-scroller__card-media">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.title }}
              {%- else -%}
                {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="strategy-scroller__card-info">
              {%- if block.settings.title != blank -%}
                <h3 class="strategy-scroller__card-step">{{ block.settings.title }}</h3>
              {%- else -%}
                <h3 class="strategy-scroller__card-step">Pillar 0{{ forloop.index }}</h3>
              {%- endif -%}
              <p class="strategy-scroller__card-text">{{ block.settings.text }}</p>
            </div>
          </div>
        {%- endfor -%}

      </div>
    </div>

  </div>
</div>

<script>
  (function() {
    const scroller = document.getElementById('StrategyScroller-{{ section.id }}');
    const track = document.getElementById('StrategyTrack-{{ section.id }}');
    if (!scroller || !track) return;

    function handleScroll() {
      const scrollY = window.scrollY;
      const offsetTop = scroller.offsetTop;
      const height = scroller.offsetHeight;
      const stickyHeight = window.innerHeight;
      
      // Calculate progress (0 to 1) through the 400vh section
      let progress = (scrollY - offsetTop) / (height - stickyHeight);
      progress = Math.max(0, Math.min(1, progress));

      // Calculate translation
      // Total translation is track width minus viewport width
      const trackWidth = track.scrollWidth;
      const viewportWidth = window.innerWidth;
      const maxTranslate = trackWidth - viewportWidth + 100; // Extra padding
      
      const translate = progress * maxTranslate;
      track.style.transform = `translate3d(${-translate}px, 0, 0)`;
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    
    // Initial call
    handleScroll();

    document.addEventListener('shopify:section:load', () => {
      handleScroll();
    });
  })();
</script>

