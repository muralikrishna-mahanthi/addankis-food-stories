{%- style -%}
  .mission-hero-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    min-height: {{ section.settings.section_height }}vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 20px;
    padding-right: 20px;
    position: relative;
    overflow: hidden;
  }

  {% if section.settings.subheading_font != blank %}
    {{ section.settings.subheading_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.heading_font != blank %}
    {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.text_font != blank %}
    {{ section.settings.text_font | font_face: font_display: 'swap' }}
  {% endif %}
  {% if section.settings.btn_font != blank %}
    {{ section.settings.btn_font | font_face: font_display: 'swap' }}
  {% endif %}

  .mission-hero-{{ section.id }} .subheading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    {% if section.settings.subheading_font != blank %}
      font-family: {{ section.settings.subheading_font.family }}, {{ section.settings.subheading_font.fallback_families }};
      font-weight: {{ section.settings.subheading_font.weight }};
      font-style: {{ section.settings.subheading_font.style }};
    {% else %}
      font-family: inherit;
      font-weight: {{ section.settings.subheading_weight }};
    {% endif %}
    font-size: {{ section.settings.subheading_size_mobile }}px;
    color: {{ section.settings.subheading_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 30px;
  }

  .mission-hero-{{ section.id }} .subheading::before,
  .mission-hero-{{ section.id }} .subheading::after {
    content: "";
    height: 1px;
    width: 30px;
    background-color: {{ section.settings.subheading_line_color }};
  }

  .mission-hero-{{ section.id }} .heading {
    {% if section.settings.heading_font != blank %}
      font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
      font-weight: {{ section.settings.heading_font.weight }};
      font-style: {{ section.settings.heading_font.style }};
    {% else %}
      font-family: inherit;
      font-weight: {{ section.settings.heading_weight }};
    {% endif %}
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color }};
    line-height: 1.2;
    margin: 0 0 30px 0;
    max-width: 900px;
  }

  .mission-hero-{{ section.id }} .heading em,
  .mission-hero-{{ section.id }} .heading i {
    color: {{ section.settings.heading_highlight_color }};
    font-style: italic;
  }

  .mission-hero-{{ section.id }} .description {
    {% if section.settings.text_font != blank %}
      font-family: {{ section.settings.text_font.family }}, {{ section.settings.text_font.fallback_families }};
      font-weight: {{ section.settings.text_font.weight }};
      font-style: {{ section.settings.text_font.style }};
    {% else %}
      font-family: inherit;
      font-weight: {{ section.settings.text_weight }};
    {% endif %}
    font-size: {{ section.settings.text_size_mobile }}px;
    color: {{ section.settings.text_color }};
    max-width: 650px;
    line-height: 1.6;
    margin: 0 0 40px 0;
  }

  .mission-hero-{{ section.id }} .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    {% if section.settings.btn_font != blank %}
      font-family: {{ section.settings.btn_font.family }}, {{ section.settings.btn_font.fallback_families }};
      font-weight: {{ section.settings.btn_font.weight }};
      font-style: {{ section.settings.btn_font.style }};
    {% else %}
      font-family: inherit;
      font-weight: {{ section.settings.btn_weight }};
    {% endif %}
    font-size: {{ section.settings.btn_size_mobile }}px;
    color: {{ section.settings.btn_text_color }};
    background-color: {{ section.settings.btn_bg_color }};
    border: 1px solid {{ section.settings.btn_border_color }};
    padding: 12px 30px;
    border-radius: {{ section.settings.btn_border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
  }

  .mission-hero-{{ section.id }} .btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .mission-hero-{{ section.id }} .btn strong,
  .mission-hero-{{ section.id }} .btn b {
    color: {{ section.settings.btn_highlight_color }};
    font-weight: inherit;
    margin-right: 6px;
  }

  @media screen and (min-width: 768px) {
    .mission-hero-{{ section.id }} .subheading {
      font-size: {{ section.settings.subheading_size }}px;
      margin-bottom: 40px;
    }
    .mission-hero-{{ section.id }} .subheading::before,
    .mission-hero-{{ section.id }} .subheading::after {
      width: 40px;
    }
    .mission-hero-{{ section.id }} .heading {
      font-size: {{ section.settings.heading_size }}px;
      margin: 0 0 40px 0;
    }
    .mission-hero-{{ section.id }} .description {
      font-size: {{ section.settings.text_size }}px;
      margin: 0 0 50px 0;
    }
    .mission-hero-{{ section.id }} .btn {
      font-size: {{ section.settings.btn_size }}px;
      padding: 15px 40px;
    }
  }
{%- endstyle -%}

<div class="mission-hero-{{ section.id }}">
  {% if section.settings.subheading != blank %}
    <div class="subheading">{{ section.settings.subheading }}</div>
  {% endif %}

  {% if section.settings.heading != blank %}
    <h2 class="heading">{{ section.settings.heading }}</h2>
  {% endif %}

  {% if section.settings.text != blank %}
    <div class="description">{{ section.settings.text }}</div>
  {% endif %}

  {% if section.settings.btn_text != blank %}
    <a {% if section.settings.btn_link != blank %}href="{{ section.settings.btn_link }}"{% else %}role="link" aria-disabled="true"{% endif %} class="btn">
      {{ section.settings.btn_text }}
    </a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Mission Hero",
  "enabled_on": {
    "templates": ["*"],
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a3628"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Minimum Height",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "OUR PURPOSE & DIRECTION"
    },
    {
      "type": "font_picker",
      "id": "subheading_font",
      "label": "Font Family"
    },
    {
      "type": "select",
      "id": "subheading_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600",
      "info": "Used if font picker doesn't apply specific weight"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Desktop Font Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "subheading_size_mobile",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Mobile Font Size",
      "default": 10
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Text Color",
      "default": "#e68d45"
    },
    {
      "type": "color",
      "id": "subheading_line_color",
      "label": "Line Color",
      "default": "#e68d45"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading Text",
      "default": "Where <em>Indian Flavours</em> Meet Global Ambition",
      "info": "Use italic text to apply the highlight color."
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Font Family"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 30,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Desktop Font Size",
      "default": 72
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Mobile Font Size",
      "default": 42
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_highlight_color",
      "label": "Highlight Color (Italic text)",
      "default": "#e68d45"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Rooted in tradition, driven by innovation — Addanki's Food Stories is reshaping how India's FMCG ecosystem nourishes millions of households."
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Font Family"
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Desktop Font Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Mobile Font Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#cfdbd4"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "inline_richtext",
      "id": "btn_text",
      "label": "Button Text",
      "default": "<strong>₹1000 Cr</strong> ECOSYSTEM VISION",
      "info": "Use bold text for the highlighted part."
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "font_picker",
      "id": "btn_font",
      "label": "Font Family"
    },
    {
      "type": "select",
      "id": "btn_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "btn_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Desktop Font Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "btn_size_mobile",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Mobile Font Size",
      "default": 10
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "btn_highlight_color",
      "label": "Highlight Color (Bold text)",
      "default": "#e68d45"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Background Color",
      "default": "rgba(43, 64, 53, 0.5)"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Border Color",
      "default": "rgba(230, 141, 69, 0.3)"
    },
    {
      "type": "range",
      "id": "btn_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Border Radius",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Mission Hero"
    }
  ]
}
{% endschema %}
