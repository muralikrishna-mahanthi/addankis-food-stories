{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* COMPLETE MARGIN RESET */
  /* Target the footer section wrapper regardless of the long dynamic ID string */
  [id*="footer"] {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    display: block !important;
  }

  /* Target any section that might be pushing the footer down */
  .shopify-section {
    margin-bottom: 0 !important;
  }

  /* Ensure the footer background starts exactly at the top of the section wrapper */
  .footer {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: 0 !important;
    background-color: {{ section.settings.bg_color | default: '#002e50' }};
    color: {{ section.settings.text_color | default: '#ffffff' }};
    border-top: none !important;
  }

  @media screen and (min-width: 750px) {
    .footer {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Layout Styling */
  .footer-logo-img {
    max-width: {{ section.settings.logo_width }}px;
    height: auto;
    display: block;
    margin-bottom: 2rem;
  }

  .footer__content-top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 60px;
  }

  .footer-logo-col { flex: 0 0 100%; }
  @media screen and (min-width: 768px) { .footer-logo-col { flex: 0 0 {{ section.settings.logo_width }}px; } }

  .footer-menu-cols {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    flex: 1;
    justify-content: flex-end;
  }

  .footer-col { flex: 0 0 calc(50% - 20px); min-width: 150px; }
  @media screen and (min-width: 1024px) { .footer-col { flex: 1; max-width: 250px; } }

  .footer-block__heading {
    font-family: {{ section.settings.link_font.family }}, {{ section.settings.link_font.fallback_families }};
    font-size: {{ section.settings.link_size }}px;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: inherit;
  }

  .footer-list { list-style: none; padding: 0; margin: 0; }
  .footer-list-item { margin-bottom: 10px; }
  .footer-list-link {
    font-family: {{ section.settings.link_font.family }}, {{ section.settings.link_font.fallback_families }};
    font-size: {{ section.settings.link_size }}px;
    font-weight: {{ section.settings.link_weight }};
    color: inherit;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: opacity 0.2s ease;
  }

  .footer-list-link:hover { opacity: 0.7; }
  .footer-external-icon { width: 14px; height: 14px; flex-shrink: 0; stroke: currentColor; stroke-width: 2.5; fill: none; }
  .footer__content-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 30px; }
  .footer__content-bottom-wrapper { display: flex; flex-direction: column; gap: 20px; align-items: center; }
  @media screen and (min-width: 990px) { .footer__content-bottom-wrapper { flex-direction: row; justify-content: space-between; } }

  .footer__list-social { display: flex; gap: 1.5rem; list-style: none; padding: 0; margin: 0; }
  .footer__list-social .list-social__link { color: inherit; padding: 0; transition: transform 0.2s ease; }
  .footer__list-social .list-social__link:hover { transform: scale(1.1); }
  .footer__list-social svg { width: 20px; height: 20px; }

  .footer__legal { display: flex; flex-wrap: wrap; gap: 1.5rem; justify-content: center; align-items: center; font-family: var(--font-body-family); font-size: 1.3rem; }
  .footer-copyright { font-weight: 700; margin-right: 10px; }
  .footer-legal-link { color: inherit; text-decoration: none; font-weight: 600; }
  .footer-legal-link:hover { text-decoration: underline; }

  .footer-portal {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #ffffff 0%, #0076a9 100%);
    opacity: 0.8;
    display: none;
  }
  @media screen and (min-width: 1200px) { .footer-portal { display: block; } }

{%- endstyle -%}

<footer class="footer">
  <div class="page-width">
    
    <div class="footer__content-top">
      <div class="footer-logo-col">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | img_url: '400x' }}" 
               alt="{{ shop.name }}" 
               class="footer-logo-img"
               loading="lazy">
        {%- else -%}
          <h2 style="color:inherit; margin:0;">{{ shop.name }}</h2>
        {%- endif -%}
      </div>

      <div class="footer-menu-cols">
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_list' -%}
            <div class="footer-col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <div class="footer-block__heading">{{ block.settings.heading | escape }}</div>
              {%- endif -%}
              
              {%- if block.settings.menu != blank -%}
                <ul class="footer-list">
                  {%- for link in block.settings.menu.links -%}
                    <li class="footer-list-item">
                      <a href="{{ link.url }}" class="footer-list-link">
                        {{ link.title | escape }}
                        {%- if block.settings.show_external_icon -%}
                          <svg class="footer-external-icon" viewBox="0 0 24 24"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
                        {%- endif -%}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="footer__content-bottom">
      <div class="footer__content-bottom-wrapper">
        <div class="footer__social-col">
          {%- if section.settings.show_social -%}
            {%- render 'social-icons', class: 'footer__list-social' -%}
          {%- endif -%}
        </div>
        <div class="footer__legal">
          <span class="footer-copyright">{{ section.settings.copyright_text | default: "© PepsiCo 2026" }}</span>
          {%- if section.settings.sub_menu != blank -%}
            {%- for link in section.settings.sub_menu.links -%}
              <a href="{{ link.url }}" class="footer-legal-link">{{ link.title | escape }}</a>
            {%- endfor -%}
          {%- endif -%}
        </div>
        <div class="footer__portal-col">
          <div class="footer-portal"></div>
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "link_list",
      "name": "Link List",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "checkbox",
          "id": "show_external_icon",
          "label": "Show External Icon (↗)",
          "default": false
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Footer Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#002e50"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Branding"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 400,
      "step": 5,
      "unit": "px",
      "label": "Logo Width",
      "default": 180
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "link_font",
      "label": "Link Font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "link_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Link Size",
      "default": 16
    },
    {
      "type": "select",
      "id": "link_weight",
      "label": "Link Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "header",
      "content": "Sub-footer"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Media Icons",
      "default": true
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© PepsiCo 2026"
    },
    {
      "type": "link_list",
      "id": "sub_menu",
      "label": "Legal Links Menu"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list" },
      { "type": "link_list" }
    ]
  }
}
{% endschema %}
