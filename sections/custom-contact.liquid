{%- style -%}
  .custom-contact-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .custom-contact-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 5%;
  }

  .contact-heading-{{ section.id }} {
    line-height: 1.2;
  }

  .contact-text-{{ section.id }} {
    line-height: 1.6;
  }
  
  .contact-text-{{ section.id }} a {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  
  .contact-text-{{ section.id }} a:hover {
    text-decoration: underline;
    opacity: 0.8;
  }

  .contact-text-{{ section.id }} p {
    margin: 0;
  }

  .contact-map-{{ section.id }} {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }
  
  .contact-map-{{ section.id }} iframe {
    width: 100%;
    display: block;
    border: none;
  }

  @media screen and (min-width: 768px) {
    .custom-contact-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
{%- endstyle -%}

<div class="custom-contact-{{ section.id }}">
  <div class="custom-contact-container-{{ section.id }}">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'heading' %}
          {%- style -%}
            {% if block.settings.font.family %}
              {{ block.settings.font | font_face: font_display: 'swap' }}
              .block-{{ block.id }} { font-family: {{ block.settings.font.family }}, {{ block.settings.font.fallback_families }}; }
            {% endif %}
            .block-{{ block.id }} {
              color: {{ block.settings.color }};
              font-size: {{ block.settings.size_mob }}px;
              font-weight: {{ block.settings.weight }};
              margin-bottom: {{ block.settings.margin_bottom }}px;
              margin-top: {{ block.settings.margin_top }}px;
            }
            @media screen and (min-width: 768px) {
              .block-{{ block.id }} { font-size: {{ block.settings.size }}px; }
            }
          {%- endstyle -%}
          <h2 class="contact-heading-{{ section.id }} block-{{ block.id }}" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </h2>

        {% when 'text' %}
          {%- style -%}
            {% if block.settings.font.family %}
              {{ block.settings.font | font_face: font_display: 'swap' }}
              .block-{{ block.id }} { font-family: {{ block.settings.font.family }}, {{ block.settings.font.fallback_families }}; }
            {% endif %}
            .block-{{ block.id }} {
              color: {{ block.settings.color }};
              font-size: {{ block.settings.size_mob }}px;
              font-weight: {{ block.settings.weight }};
              margin-bottom: {{ block.settings.margin_bottom }}px;
              margin-top: {{ block.settings.margin_top }}px;
            }
            @media screen and (min-width: 768px) {
              .block-{{ block.id }} { font-size: {{ block.settings.size }}px; }
            }
          {%- endstyle -%}
          <div class="contact-text-{{ section.id }} block-{{ block.id }}" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>

        {% when 'map' %}
          {%- style -%}
            .block-{{ block.id }} { margin-top: {{ block.settings.margin_top }}px; }
            .block-{{ block.id }} iframe { height: {{ block.settings.height_mob }}px !important; }
            @media screen and (min-width: 768px) {
              .block-{{ block.id }} iframe { height: {{ block.settings.height }}px !important; }
            }
          {%- endstyle -%}
          <div class="contact-map-{{ section.id }} block-{{ block.id }}" {{ block.shopify_attributes }}>
            {% if block.settings.iframe_code != blank %}
              {{ block.settings.iframe_code }}
            {% else %}
              <div style="background:#f4f4f4; height: {{ block.settings.height }}px; display:flex; align-items:center; justify-content:center; color:#999; border-radius: 8px;">
                <p>Paste Google Maps Iframe HTML code in settings</p>
              </div>
            {% endif %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</div>

