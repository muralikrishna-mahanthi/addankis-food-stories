{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.desc_font | font_face: font_display: 'swap' }}
  {{ section.settings.name_font | font_face: font_display: 'swap' }}
  {{ section.settings.role_font | font_face: font_display: 'swap' }}

  .leadership-header-{{ section.id }} {
    text-align: {{ section.settings.text_alignment }};
    max-width: var(--page-width, 1200px);
    margin: 0 auto 40px;
    padding: 0 1.5rem;
  }

  .leadership-heading-{{ section.id }} {
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    font-size: {{ section.settings.heading_size_mobile }}px;
    color: {{ section.settings.heading_color }};
    font-weight: {{ section.settings.heading_weight }};
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .leadership-heading-{{ section.id }} {
      font-size: {{ section.settings.heading_size }}px;
    }
  }

  .leadership-desc-{{ section.id }} {
    font-family: {{ section.settings.desc_font.family }}, {{ section.settings.desc_font.fallback_families }};
    font-size: {{ section.settings.desc_size_mobile }}px;
    color: {{ section.settings.desc_color }};
    font-weight: {{ section.settings.desc_weight }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (min-width: 750px) {
    .leadership-desc-{{ section.id }} {
      font-size: {{ section.settings.desc_size }}px;
    }
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .leadership-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .leadership-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
      column-gap: 40px;
      row-gap: 60px;
    }
  }

  @media screen and (min-width: 990px) {
    .leadership-grid-{{ section.id }} {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  .leadership-profile-{{ section.id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: transform 0.3s ease;
    height: 100%;
    align-items: flex-start;
    text-align: left;
  }

  .leadership-profile-{{ section.id }}:hover {
    transform: translateY(-5px);
  }

  .leadership-profile__image-wrap-{{ section.id }} {
    background-color: {{ section.settings.image_bg_color }};
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    margin-bottom: 24px;
    aspect-ratio: 350 / 250;
    position: relative;
    width: 100%;
    max-width: 350px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .leadership-profile__image-wrap-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .leadership-profile-{{ section.id }}:hover .leadership-profile__image-wrap-{{ section.id }} img {
    transform: scale(1.03);
  }

  .leadership-profile__name-{{ section.id }} {
    font-family: {{ section.settings.name_font.family }}, {{ section.settings.name_font.fallback_families }};
    font-size: {{ section.settings.name_size_mobile }}px;
    color: {{ section.settings.name_color }};
    font-weight: {{ section.settings.name_weight }};
    margin: 0 0 10px 0;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .leadership-profile__name-{{ section.id }} {
      font-size: {{ section.settings.name_size }}px;
    }
  }

  .leadership-profile__role-{{ section.id }} {
    font-family: {{ section.settings.role_font.family }}, {{ section.settings.role_font.fallback_families }};
    font-size: {{ section.settings.role_size_mobile }}px;
    color: {{ section.settings.role_color }};
    font-weight: {{ section.settings.role_weight }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (min-width: 750px) {
    .leadership-profile__role-{{ section.id }} {
      font-size: {{ section.settings.role_size }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  {%- if section.settings.section_heading != blank or section.settings.section_description != blank -%}
    <div class="leadership-header-{{ section.id }}">
      {%- if section.settings.section_heading != blank -%}
        <h2 class="leadership-heading-{{ section.id }}">{{ section.settings.section_heading }}</h2>
      {%- endif -%}
      {%- if section.settings.section_description != blank -%}
        <div class="leadership-desc-{{ section.id }}">{{ section.settings.section_description }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="leadership-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- if block.settings.link != blank -%}
        <a href="{{ block.settings.link }}" class="leadership-profile-{{ section.id }}" {{ block.shopify_attributes }}>
      {%- else -%}
        <div class="leadership-profile-{{ section.id }}" {{ block.shopify_attributes }}>
      {%- endif -%}

        <div class="leadership-profile__image-wrap-{{ section.id }}">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        
        <h3 class="leadership-profile__name-{{ section.id }}">{{ block.settings.name }}</h3>
        <p class="leadership-profile__role-{{ section.id }}">{{ block.settings.role }}</p>

      {%- if block.settings.link != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

