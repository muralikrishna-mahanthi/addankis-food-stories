{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .fmcg-leadership {
    background-color: {{ section.settings.bg_color }};
    width: 100%;
  }

  .fmcg-leadership__header {
    max-width: 800px;
    margin: 0 auto 5rem;
    text-align: center;
    padding: 0 1.5rem;
  }

  .fmcg-leadership__title {
    font-size: 3.5rem;
    font-weight: 900;
    margin-bottom: 1.5rem;
    color: {{ section.settings.title_color }};
    text-transform: uppercase;
    letter-spacing: -1px;
  }

  .fmcg-leadership__subtitle {
    font-size: 1.2rem;
    color: {{ section.settings.subtitle_color }};
    line-height: 1.6;
  }

  .fmcg-leadership__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .fmcg-leadership__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .fmcg-leadership__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  .fmcg-leadership-card {
    background: {{ section.settings.card_bg }};
    border-radius: 2rem;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: 1px solid rgba(0,0,0,0.05);
    opacity: 0;
    transform: translateY(30px);
  }

  .fmcg-leadership-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .fmcg-leadership-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    border-color: {{ section.settings.accent_color }};
  }

  .fmcg-leadership-card__image-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 1.5rem;
    overflow: hidden;
    margin-bottom: 2rem;
    position: relative;
  }

  .fmcg-leadership-card__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .fmcg-leadership-card:hover .fmcg-leadership-card__image-wrapper img {
    transform: scale(1.08);
  }

  .fmcg-leadership-card__role {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
  }

  .fmcg-leadership-card__name {
    font-size: 1.8rem;
    font-weight: 900;
    margin-bottom: 1.5rem;
    color: {{ section.settings.card_title_color }};
  }

  .fmcg-leadership-card__bio {
    font-size: 1rem;
    line-height: 1.6;
    color: {{ section.settings.card_text_color }};
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .fmcg-leadership-card__responsibilities {
    border-top: 1px solid rgba(0,0,0,0.05);
    padding-top: 1.5rem;
    margin-top: 1.5rem;
  }

  .fmcg-leadership-card__resp-title {
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
    color: {{ section.settings.card_title_color | alpha: 0.6 }};
  }

  .fmcg-leadership-card__resp-list {
    padding-left: 1.2rem;
    margin: 0;
    list-style-type: disc;
    font-size: 0.9rem;
    color: {{ section.settings.card_text_color }};
  }

  .fmcg-leadership-card__resp-list li {
    margin-bottom: 0.5rem;
  }

  .fmcg-leadership-card__read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    cursor: pointer;
    font-size: 0.9rem;
    transition: gap 0.3s;
  }

  .fmcg-leadership-card__read-more:hover {
    gap: 0.8rem;
  }

{%- endstyle -%}

<div class="fmcg-leadership section-{{ section.id }}-padding">
  <div class="fmcg-leadership__header">
    {%- if section.settings.title != blank -%}
      <h2 class="fmcg-leadership__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="fmcg-leadership__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  <div class="fmcg-leadership__grid">
    {%- for block in section.blocks -%}
      <div class="fmcg-leadership-card" {{ block.shopify_attributes }} style="transition-delay: {{ forloop.index | times: 150 }}ms;">
        <div class="fmcg-leadership-card__image-wrapper">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        <div class="fmcg-leadership-card__role">{{ block.settings.role }}</div>
        <h3 class="fmcg-leadership-card__name">{{ block.settings.name }}</h3>
        
        <div class="fmcg-leadership-card__bio">
          {{ block.settings.bio }}
        </div>

        {%- if block.settings.responsibilities != blank -%}
          <div class="fmcg-leadership-card__responsibilities">
            <div class="fmcg-leadership-card__resp-title">Key Responsibilities</div>
            <div class="fmcg-leadership-card__resp-list">
              {{ block.settings.responsibilities }}
            </div>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  (function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fmcg-leadership-card').forEach(card => {
      observer.observe(card);
    });
  })();
</script>

{% schema %}
{
  "name": "FMCG Leadership",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    { "type": "text", "id": "title", "label": "Heading", "default": "Our Leadership" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "The experienced team driving the vision of Addanki’s Food Stories." },
    { "type": "range", "id": "columns_desktop", "min": 2, "max": 4, "step": 1, "label": "Columns (Desktop)", "default": 2 },
    {
      "type": "header",
      "content": "Theme Colors"
    },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f9f9f9" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#ffffff" },
    { "type": "color", "id": "title_color", "label": "Title Color", "default": "#000000" },
    { "type": "color", "id": "subtitle_color", "label": "Subtitle Color", "default": "#666666" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#3b82f6" },
    { "type": "color", "id": "card_title_color", "label": "Card Name Color", "default": "#000000" },
    { "type": "color", "id": "card_text_color", "label": "Card Text Color", "default": "#333333" },
    {
      "type": "header",
      "content": "Spacing"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top Padding", "default": 100 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom Padding", "default": 100 }
  ],
  "blocks": [
    {
      "type": "founder",
      "name": "Founder/Leader",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Profile Photo" },
        { "type": "text", "id": "name", "label": "Name", "default": "Shivaji Addanki" },
        { "type": "text", "id": "role", "label": "Role/Title", "default": "Founder & CMO" },
        { "type": "richtext", "id": "bio", "label": "Biography", "default": "<p>Experience in sales and distribution development across South India.</p>" },
        { "type": "richtext", "id": "responsibilities", "label": "Responsibilities (Bullet points)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FMCG Leadership",
      "blocks": [
        { "type": "founder", "settings": { "name": "Shivaji Addanki", "role": "Founder & CMO" } },
        { "type": "founder", "settings": { "name": "Sevyamana Taliyakula", "role": "Co-Founder - CEO" } },
        { "type": "founder", "settings": { "name": "Rajkumar Muppidi", "role": "COO" } },
        { "type": "founder", "settings": { "name": "Nithish Reddy", "role": "CFO" } }
      ]
    }
  ]
}
{% endschema %}
