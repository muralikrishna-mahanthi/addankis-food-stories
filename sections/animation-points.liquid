{%- style -%}
  {%- liquid
    assign heading_font = section.settings.heading_font
    assign text_font = section.settings.text_font
  -%}

  {{ heading_font | font_face: font_display: 'swap' }}
  {{ text_font | font_face: font_display: 'swap' }}

  #AnimationPoints-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    overflow: hidden;
    font-family: {{ text_font.family }}, {{ text_font.fallback_families }};
  }

  .ap-container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 4rem;
    position: relative;
  }

  .ap-header {
    text-align: center;
    margin-bottom: 10rem;
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .ap-header.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ap-heading {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
  }

  .ap-timeline {
    position: relative;
    max-width: 1000px;
    margin: 0 auto;
    padding: 60px 0;
  }

  .ap-line-wrapper {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
    background: {{ section.settings.line_base_color }};
    border-radius: 2px;
  }

  .ap-line-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: {{ section.settings.line_active_color }};
    transition: height 0.1s linear;
    box-shadow: 0 0 10px {{ section.settings.line_active_color | color_modify: 'alpha', 0.4 }};
  }

  .ap-points-list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12rem;
  }

  .ap-point-item {
    position: relative;
    width: 50%;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transition: all 1.2s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .ap-point-item:nth-child(odd) {
    align-self: flex-start;
    padding-right: 8rem;
    text-align: right;
    transform: translateX(-60px);
  }

  .ap-point-item:nth-child(even) {
    align-self: flex-end;
    padding-left: 8rem;
    text-align: left;
    transform: translateX(60px);
  }

  .ap-point-item.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  .ap-point-dot {
    position: absolute;
    top: 2rem;
    width: 20px;
    height: 20px;
    background: {{ section.settings.bg_color }};
    border: 4px solid {{ section.settings.line_base_color }};
    border-radius: 50%;
    z-index: 5;
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .ap-point-item:nth-child(odd) .ap-point-dot {
    right: -11px;
  }

  .ap-point-item:nth-child(even) .ap-point-dot {
    left: -11px;
  }

  .ap-point-item.is-active .ap-point-dot {
    background: {{ section.settings.line_active_color }};
    border-color: {{ section.settings.line_active_color }};
    transform: scale(1.4);
    box-shadow: 0 0 20px {{ section.settings.line_active_color | color_modify: 'alpha', 0.6 }};
  }

  .ap-point-block {
    background: {{ section.settings.block_bg_color }};
    padding: 4rem;
    border-radius: 2rem;
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(15px);
    transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .ap-point-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
    pointer-events: none;
  }

  .ap-point-item:hover .ap-point-block {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
  }

  .ap-point-title {
    margin: 0 0 1.5rem 0;
    font-size: 2.8rem;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    letter-spacing: -0.02em;
  }

  .ap-point-desc {
    margin: 0;
    font-size: 1.8rem;
    line-height: 1.7;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.8 }};
    font-weight: 400;
  }

  @media screen and (max-width: 768px) {
    .ap-container {
      padding: 0 2rem;
    }
    .ap-line-wrapper {
      left: 2rem;
    }
    .ap-point-item {
      width: 100%;
      align-self: flex-start !important;
      padding-left: 5rem !important;
      padding-right: 0 !important;
      text-align: left !important;
      transform: translateX(40px) !important;
    }
    .ap-point-item:nth-child(odd) .ap-point-dot,
    .ap-point-item:nth-child(even) .ap-point-dot {
      left: -11px !important;
      right: auto !important;
    }
    .ap-heading {
      font-size: 3.6rem;
    }
    .ap-point-block {
        padding: 2.5rem;
    }
    .ap-point-title {
        font-size: 2.2rem;
    }
    .ap-point-desc {
        font-size: 1.6rem;
    }
  }
{%- endstyle -%}

<section id="AnimationPoints-{{ section.id }}" class="ap-section">
  <div class="ap-container">
    <div class="ap-header js-ap-animate">
      <h2 class="ap-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="ap-timeline">
      <div class="ap-line-wrapper">
        <div class="ap-line-fill js-ap-line-fill"></div>
      </div>

      <div class="ap-points-list">
        {%- for block in section.blocks -%}
          <div class="ap-point-item js-ap-point js-ap-animate" {{ block.shopify_attributes }}>
            <div class="ap-point-dot"></div>
            <div class="ap-point-block">
              {%- if block.settings.title != blank -%}
                <h3 class="ap-point-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <div class="ap-point-desc">{{ block.settings.description }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('#AnimationPoints-{{ section.id }}');
    if (!section) return;

    const animateElements = section.querySelectorAll('.js-ap-animate');
    const points = section.querySelectorAll('.js-ap-point');
    const lineFill = section.querySelector('.js-ap-line-fill');
    
    // Intersection Observer for fade-in animations
    const observerOptions = {
      threshold: 0.15,
      rootMargin: "0px 0px -50px 0px"
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, observerOptions);

    animateElements.forEach(el => observer.observe(el));

    // Scroll listener for timeline line and dot activation
    function updateTimeline() {
      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      
      const sectionHeight = section.offsetHeight;
      const sectionTop = rect.top;
      
      // Calculate line progress
      // Start filling when the section header hits mid-viewport
      // Finish when the last point block is scrolled past
      const startTrigger = viewportHeight * 0.7;
      let progress = 0;
      
      if (sectionTop < startTrigger) {
          progress = (startTrigger - sectionTop) / (sectionHeight - viewportHeight * 0.3);
      }
      
      progress = Math.max(0, Math.min(1, progress));
      
      if (lineFill) {
        lineFill.style.height = (progress * 100) + '%';
      }

      points.forEach(point => {
        const pointRect = point.getBoundingClientRect();
        // Activate dot when it passes the middle of the screen
        if (pointRect.top < viewportHeight * 0.6) {
          point.classList.add('is-active');
        } else {
          point.classList.remove('is-active');
        }
      });
    }

    window.addEventListener('scroll', updateTimeline, { passive: true });
    updateTimeline(); // Initial check
  });
</script>

