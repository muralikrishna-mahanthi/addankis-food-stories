{%- style -%}
  {%- for block in section.blocks -%}
    {{ block.settings.font_family | font_face: font_display: 'swap' }}
    
    .afspl-text-block-{{ block.id }} {
      font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
      font-size: {{ block.settings.font_size_mobile }}px;
      font-weight: {{ block.settings.font_weight }};
      color: {{ block.settings.text_color }};
      letter-spacing: {{ block.settings.letter_spacing }}px;
      word-spacing: {{ block.settings.word_spacing }}px;
      text-align: {{ block.settings.text_alignment }};
      margin-bottom: {{ block.settings.margin_bottom }}px;
      line-height: 1.5;
    }

    .afspl-text-block-{{ block.id }} p {
      margin: 0;
    }

    @media screen and (min-width: 750px) {
      .afspl-text-block-{{ block.id }} {
        font-size: {{ block.settings.font_size }}px;
      }
    }
  {%- endfor -%}

  .afspl-text-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 20px;
    padding-right: 20px;
    width: 100%;
    box-sizing: border-box;
  }

  @media screen and (min-width: 750px) {
    .afspl-text-section-{{ section.id }} {
      padding-left: {{ section.settings.padding_horizontal }}px;
      padding-right: {{ section.settings.padding_horizontal }}px;
    }
  }

  .afspl-text-container-{{ section.id }} {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
  }
{%- endstyle -%}

<div class="afspl-text-section-{{ section.id }}">
  <div class="afspl-text-container-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="afspl-text-block-{{ block.id }}" {{ block.shopify_attributes }}>
        {{ block.settings.text }}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "AFSPL Text",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 400,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "label": "Container Max Width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 300,
      "step": 3,
      "unit": "px",
      "label": "Desktop Horizontal Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Text Block",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add your text here</p>"
        },
        {
          "type": "font_picker",
          "id": "font_family",
          "label": "Font Family",
          "default": "helvetica_n4"
        },
        {
          "type": "range",
          "id": "font_size",
          "min": 10,
          "max": 110,
          "step": 1,
          "unit": "px",
          "label": "Font Size (Desktop)",
          "default": 18
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "px",
          "label": "Font Size (Mobile)",
          "default": 16
        },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font Weight",
          "options": [
            { "value": "300", "label": "Light" },
            { "value": "400", "label": "Normal" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semi Bold" },
            { "value": "700", "label": "Bold" },
            { "value": "800", "label": "Extra Bold" },
            { "value": "900", "label": "Black" }
          ],
          "default": "400"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "letter_spacing",
          "min": -5,
          "max": 20,
          "step": 0.5,
          "unit": "px",
          "label": "Letter Spacing",
          "default": 0
        },
        {
          "type": "range",
          "id": "word_spacing",
          "min": -10,
          "max": 50,
          "step": 1,
          "unit": "px",
          "label": "Word Spacing",
          "default": 0
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Block Margin Bottom",
          "default": 16
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AFSPL Text",
      "blocks": [
        {
          "type": "text_block"
        }
      ]
    }
  ]
}
{% endschema %}
