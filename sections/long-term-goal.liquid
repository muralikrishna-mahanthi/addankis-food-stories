{%- style -%}
  .goal-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    min-height: {{ section.settings.height_mob }}vh;
    display: flex;
    align-items: center;
    padding: 60px 20px;
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 768px) {
    .goal-section-{{ section.id }} {
      min-height: {{ section.settings.height_desktop }}vh;
      padding: 100px 5%;
    }
  }

  /* Background Orbital Rings */
  .goal-bg-circles-{{ section.id }} {
    position: absolute;
    top: 50%;
    right: 25%;
    transform: translate(50%, -50%);
    width: 2000px;
    height: 2000px;
    pointer-events: none;
    z-index: 1;
  }

  .bg-circle-{{ section.id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 50%;
  }

  .c-1-{{ section.id }} { width: 600px; height: 600px; }
  .c-2-{{ section.id }} { width: 1000px; height: 1000px; }
  .c-3-{{ section.id }} { width: 1400px; height: 1400px; }
  .c-4-{{ section.id }} { width: 1800px; height: 1800px; }

  .goal-container-{{ section.id }} {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px;
    align-items: center;
    z-index: 2;
    position: relative;
  }

  @media screen and (min-width: 1024px) {
    .goal-container-{{ section.id }} {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  /* Left Side Content */
  .goal-content-{{ section.id }} {
    max-width: 650px;
  }

  .goal-sub-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    color: {{ section.settings.accent_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 12px;
    font-weight: 600;
    margin-bottom: 25px;
  }

  .goal-sub-{{ section.id }}::before {
    content: "";
    width: 30px;
    height: 2px;
    background-color: {{ section.settings.accent_color }};
  }

  .goal-h-{{ section.id }} {
    color: {{ section.settings.h_color }};
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 25px;
  }

  .goal-h-{{ section.id }} em, 
  .goal-h-{{ section.id }} i {
    color: {{ section.settings.accent_color }};
    font-style: italic;
  }

  .goal-p-{{ section.id }} {
    color: {{ section.settings.p_color }};
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 40px;
    opacity: 0.8;
  }

  /* Goal Blocks */
  .goal-items-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .goal-item-{{ section.id }} {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 25px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
    transition: all 0.3s ease;
  }

  .goal-item-{{ section.id }}:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateX(10px);
  }

  .goal-dot-{{ section.id }} {
    width: 10px;
    height: 10px;
    background-color: {{ section.settings.accent_color }};
    border-radius: 50%;
    margin-top: 6px;
    flex-shrink: 0;
    box-shadow: 0 0 10px {{ section.settings.accent_color }};
  }

  .goal-item-text-{{ section.id }} {
    color: #fff;
    font-size: 15px;
    line-height: 1.5;
  }

  .goal-item-text-{{ section.id }} strong {
    color: #fff;
    font-weight: 700;
  }

  /* Right Side Visual Graphic */
  .goal-visual-{{ section.id }} {
    position: relative;
    height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .orbit-container-{{ section.id }} {
    position: relative;
    width: 500px;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .orbit-ring-{{ section.id }} {
    position: absolute;
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: 50%;
  }

  .ring-1-{{ section.id }} { width: 320px; height: 320px; }
  .ring-2-{{ section.id }} { width: 500px; height: 500px; }

  .center-node-{{ section.id }} {
    width: 140px;
    height: 140px;
    background-color: {{ section.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-align: center;
    z-index: 5;
    box-shadow: 0 0 60px rgba(230, 141, 69, 0.4);
    animation: pulse 3s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 60px rgba(230, 141, 69, 0.4); }
    50% { transform: scale(1.05); box-shadow: 0 0 80px rgba(230, 141, 69, 0.6); }
  }

  .center-node-{{ section.id }} span {
    font-size: 20px;
    font-weight: 700;
  }

  .center-node-{{ section.id }} small {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 5px;
    opacity: 0.9;
  }

  .orbit-node-{{ section.id }} {
    position: absolute;
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    color: #fff;
    z-index: 4;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-align: center;
  }

  .orbit-node-{{ section.id }}:hover {
    background: {{ section.settings.accent_color }};
    border-color: transparent;
    transform: scale(1.1);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .node-icon-{{ section.id }} {
    width: 24px;
    height: 24px;
    margin-bottom: 5px;
    object-fit: contain;
  }

  .node-label-{{ section.id }} {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .node-brands-{{ section.id }} { top: 0; right: 15%; }
  .node-partners-{{ section.id }} { top: 35%; left: -5%; }
  .node-urban-{{ section.id }} { bottom: 25%; right: -5%; }
  .node-rural-{{ section.id }} { bottom: 0; left: 15%; }

  @media screen and (max-width: 1023px) {
    .goal-visual-{{ section.id }} {
      height: 450px;
      margin-top: 40px;
    }
    .orbit-container-{{ section.id }} { width: 350px; height: 350px; }
    .ring-1-{{ section.id }} { width: 220px; height: 220px; }
    .ring-2-{{ section.id }} { width: 350px; height: 350px; }
    .orbit-node-{{ section.id }} { width: 70px; height: 70px; }
    .center-node-{{ section.id }} { width: 110px; height: 110px; }
  }

  /* Font Handling */
  {% if section.settings.h_font.family %}
    {{ section.settings.h_font | font_face: font_display: 'swap' }}
    .goal-h-{{ section.id }} { 
      font-family: {{ section.settings.h_font.family }}, {{ section.settings.h_font.fallback_families }}; 
    }
  {% endif %}
  {% if section.settings.p_font.family %}
    {{ section.settings.p_font | font_face: font_display: 'swap' }}
    .goal-p-{{ section.id }}, .goal-item-text-{{ section.id }} { 
      font-family: {{ section.settings.p_font.family }}, {{ section.settings.p_font.fallback_families }}; 
    }
  {% endif %}

{%- endstyle -%}

<section class="goal-section-{{ section.id }}">
  <!-- Large Background Orbits -->
  <div class="goal-bg-circles-{{ section.id }}">
    <div class="bg-circle-{{ section.id }} c-1-{{ section.id }}"></div>
    <div class="bg-circle-{{ section.id }} c-2-{{ section.id }}"></div>
    <div class="bg-circle-{{ section.id }} c-3-{{ section.id }}"></div>
    <div class="bg-circle-{{ section.id }} c-4-{{ section.id }}"></div>
  </div>

  <div class="goal-container-{{ section.id }}">
    
    <div class="goal-content-{{ section.id }}">
      {% if section.settings.subheading != blank %}
        <div class="goal-sub-{{ section.id }}">{{ section.settings.subheading }}</div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="goal-h-{{ section.id }}">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="goal-p-{{ section.id }}">{{ section.settings.description }}</div>
      {% endif %}

      <div class="goal-items-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="goal-item-{{ section.id }}" {{ block.shopify_attributes }}>
            <div class="goal-dot-{{ section.id }}"></div>
            <div class="goal-item-text-{{ section.id }}">
              <strong>{{ block.settings.title }}</strong> — {{ block.settings.text }}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="goal-visual-{{ section.id }}">
      <div class="orbit-container-{{ section.id }}">
        <div class="orbit-ring-{{ section.id }} ring-1-{{ section.id }}"></div>
        <div class="orbit-ring-{{ section.id }} ring-2-{{ section.id }}"></div>
        
        <div class="center-node-{{ section.id }}">
          <span>{{ section.settings.center_text }}</span>
          <small>{{ section.settings.center_subtext }}</small>
        </div>

        <!-- Brands Node -->
        <div class="orbit-node-{{ section.id }} node-brands-{{ section.id }}">
          {% if section.settings.icon_brands != blank %}
            <img src="{{ section.settings.icon_brands | image_url: width: 50 }}" class="node-icon-{{ section.id }}" alt="Brands">
          {% endif %}
          <span class="node-label-{{ section.id }}">BRANDS</span>
        </div>

        <!-- Partners Node -->
        <div class="orbit-node-{{ section.id }} node-partners-{{ section.id }}">
          {% if section.settings.icon_partners != blank %}
            <img src="{{ section.settings.icon_partners | image_url: width: 50 }}" class="node-icon-{{ section.id }}" alt="Partners">
          {% endif %}
          <span class="node-label-{{ section.id }}">PARTNERS</span>
        </div>

        <!-- Urban Node -->
        <div class="orbit-node-{{ section.id }} node-urban-{{ section.id }}">
          {% if section.settings.icon_urban != blank %}
            <img src="{{ section.settings.icon_urban | image_url: width: 50 }}" class="node-icon-{{ section.id }}" alt="Urban">
          {% endif %}
          <span class="node-label-{{ section.id }}">URBAN</span>
        </div>

        <!-- Rural Node -->
        <div class="orbit-node-{{ section.id }} node-rural-{{ section.id }}">
          {% if section.settings.icon_rural != blank %}
            <img src="{{ section.settings.icon_rural | image_url: width: 50 }}" class="node-icon-{{ section.id }}" alt="Rural">
          {% endif %}
          <span class="node-label-{{ section.id }}">RURAL</span>
        </div>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Long Term Goal",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a3628"
    },
    {
      "type": "color",
      "id": "h_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "p_color",
      "label": "Description Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#e68d45"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Desktop Height",
      "default": 90
    },
    {
      "type": "range",
      "id": "height_mob",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Mobile Height",
      "default": 80
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "h_font",
      "label": "Heading Font Family",
      "default": "assistant_n4"
    },
    {
      "type": "font_picker",
      "id": "p_font",
      "label": "Text Font Family",
      "default": "assistant_n4"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "LONG-TERM GOAL"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Leading India's <em>Brand Builder</em> & Distribution Era"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Addanki's Food Stories aims to become the most trusted FMCG brand builder and distribution platform in India — supporting multiple successful consumer brands and reaching millions of households across every state and district."
    },
    {
      "type": "header",
      "content": "Visual Node Settings"
    },
    {
      "type": "text",
      "id": "center_text",
      "label": "Center Node Text",
      "default": "1K Cr"
    },
    {
      "type": "text",
      "id": "center_subtext",
      "label": "Center Node Subtext",
      "default": "VISION"
    },
    {
      "type": "image_picker",
      "id": "icon_brands",
      "label": "Brands Node Icon"
    },
    {
      "type": "image_picker",
      "id": "icon_partners",
      "label": "Partners Node Icon"
    },
    {
      "type": "image_picker",
      "id": "icon_urban",
      "label": "Urban Node Icon"
    },
    {
      "type": "image_picker",
      "id": "icon_rural",
      "label": "Rural Node Icon"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Goal Point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Point Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Point Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Long Term Goal",
      "blocks": [
        {
          "type": "point",
          "settings": {
            "title": "Multiple Successful Consumer Brands",
            "text": "incubated, built, and scaled under our ecosystem umbrella."
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "Millions of Households Reached",
            "text": "across urban, semi-urban, and rural India through our distribution network."
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "India's Strongest Rural Distribution",
            "text": "enabling products to reach the last mile, where growth truly awaits."
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "₹1000 Crore Ecosystem",
            "text": "a landmark reflecting our scale, impact, and trust earned across markets."
          }
        }
      ]
    }
  ]
}
