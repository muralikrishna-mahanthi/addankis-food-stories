{%- style -%}
  .block-content-{{ section.id }} {
    padding: 8rem 5%;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    overflow: hidden;
  }
  .block-content__container {
    max-width: 1400px;
    margin: 0 auto;
  }
  .block-content__header {
    text-align: center;
    margin-bottom: 6rem;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.165, 0.84, 0.44, 1), transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .block-content__header.animate-in {
    opacity: 1;
    transform: translateY(0);
  }
  .block-content__title {
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 800;
    margin: 0;
    color: {{ section.settings.text_color }};
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .block-content__subtitle {
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    max-width: 800px;
    margin: 2rem auto 0;
    opacity: 0.8;
    line-height: 1.6;
  }
  
  .block-content__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .block-content__card {
    background: #ffffff;
    border-radius: 16px;
    padding: 4rem 3rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    opacity: 0;
    transform: translateY(40px);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .block-content__card.animate-in {
    animation: fadeUpStagger 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
  }
  .block-content__card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
  }

  /* Accent line on top of card */
  .block-content__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: {{ section.settings.accent_color | default: '#3A81F4' }};
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .block-content__card:hover::before {
    transform: scaleX(1);
  }

  .block-content__card-index {
    font-size: 4rem;
    font-weight: 900;
    color: {{ section.settings.accent_color | default: '#3A81F4' }};
    opacity: 0.2;
    margin-bottom: 1rem;
    line-height: 1;
    transition: opacity 0.4s ease;
  }
  .block-content__card:hover .block-content__card-index {
    opacity: 0.5;
  }

  .block-content__card-title {
    font-size: 2.2rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: {{ section.settings.card_title_color | default: '#003A6A' }};
    line-height: 1.2;
  }
  .block-content__card-text {
    font-size: 1.6rem;
    line-height: 1.6;
    color: {{ section.settings.card_text_color | default: '#555555' }};
    margin: 0;
  }

  @keyframes fadeUpStagger {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 768px) {
    .block-content-{{ section.id }} {
      padding: 6rem 5%;
    }
    .block-content__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .block-content__card {
      padding: 3rem 2rem;
    }
  }
{%- endstyle -%}

<section class="block-content-{{ section.id }}" id="BlockContent-{{ section.id }}">
  <div class="block-content__container">
    <div class="block-content__header js-animate-header">
      <h2 class="block-content__title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="block-content__subtitle">{{ section.settings.subtitle | newline_to_br }}</p>
      {%- endif -%}
    </div>

    <div class="block-content__grid">
      {%- for block in section.blocks -%}
        <div class="block-content__card js-animate-card" style="animation-delay: {{ forloop.index0 | times: 0.15 }}s;" {{ block.shopify_attributes }}>
          <div class="block-content__card-index">0{{ forloop.index }}</div>
          <h3 class="block-content__card-title">{{ block.settings.title }}</h3>
          <p class="block-content__card-text">{{ block.settings.description | newline_to_br }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('BlockContent-{{ section.id }}');
    if (!section) return;

    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    };

    const header = section.querySelector('.js-animate-header');
    const cards = section.querySelectorAll('.js-animate-card');

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    if (header) observer.observe(header);
    cards.forEach(card => observer.observe(card));
  });
</script>

{% schema %}
{
  "name": "Block Content",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
