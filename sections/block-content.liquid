      "default": "#003A6A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Card Hover Accent & Index",
      "default": "#3A81F4"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#003A6A"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#555555"
    }
  ],
  "blocks": [
    {
      "type": "capability",
      "name": "Capability",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Capability Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Capability description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Block Content (What We Do)",
      "blocks": [
        {
          "type": "capability",
          "settings": {
            "title": "Brand Building & Strategy",
            "description": "We develop trusted consumer brands rooted in Indian traditions and modern lifestyles across home care, wellness, traditional foods, and healthy lifestyle products."
          }
        },
        {
          "type": "capability",
          "settings": {
            "title": "Market Expansion",
            "description": "We empower innovative products to reach retailers, distributors, and consumers efficiently by driving deep rural GT market expansion."
          }
        },
        {
          "type": "capability",
          "settings": {
            "title": "Distribution Network",
            "description": "Creating robust distribution systems to ensure that products safely and reliably reach every town and village across India."
          }
        },
        {
          "type": "capability",
          "settings": {
            "title": "Sales Execution",
            "description": "Combining strong understanding of the Indian General Trade, sales team deployment, retail market penetration, and strategic trade marketing."
          }
        }
      ]
    }
  ]
}
{% endschema %}
