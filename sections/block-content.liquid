{%- style -%}
  {{ section.settings.heading_font | font_face: display: 'swap' }}
  {{ section.settings.subtitle_font | font_face: display: 'swap' }}
  {{ section.settings.index_font | font_face: display: 'swap' }}
  {{ section.settings.card_title_font | font_face: display: 'swap' }}
  {{ section.settings.card_text_font | font_face: display: 'swap' }}

  .block-content-{{ section.id }} {
    padding: 8rem 5%;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }
  .block-content__container {
    max-width: 1400px;
    margin: 0 auto;
  }
  .block-content__header {
    text-align: center;
    margin-bottom: 6rem;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.165, 0.84, 0.44, 1), transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .block-content__header.animate-in {
    opacity: 1;
    transform: translateY(0);
  }
  .block-content__title {
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    font-size: clamp(3rem, 5vw, {{ section.settings.heading_size }}rem);
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.text_color }};
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .block-content__subtitle {
    font-family: {{ section.settings.subtitle_font.family }}, {{ section.settings.subtitle_font.fallback_families }};
    font-size: clamp(1.4rem, 2vw, {{ section.settings.subtitle_size }}rem);
    font-weight: {{ section.settings.subtitle_weight }};
    color: {{ section.settings.subtitle_color }};
    max-width: 800px;
    margin: 2rem auto 0;
    line-height: 1.6;
  }
  
  .block-content__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 3rem;
  }

  .block-content__card {
    background: #ffffff;
    border: 1px solid #EFEFEF;
    padding: 4rem 3rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    opacity: 0;
    transform: translateY(40px);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .block-content__card.animate-in {
    animation: fadeUpStagger 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
  }
  .block-content__card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.08);
  }

  .block-content__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--block-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .block-content__card:hover::before {
    transform: scaleX(1);
  }

  .block-content__card-index {
    font-family: {{ section.settings.index_font.family }}, {{ section.settings.index_font.fallback_families }};
    font-size: {{ section.settings.index_size }}rem;
    font-weight: {{ section.settings.index_weight }};
    color: var(--block-accent);
    opacity: 0.2;
    margin-bottom: 1rem;
    line-height: 1;
    transition: opacity 0.4s ease;
  }
  .block-content__card:hover .block-content__card-index {
    opacity: 0.5;
  }

  .block-content__card-title {
    font-family: {{ section.settings.card_title_font.family }}, {{ section.settings.card_title_font.fallback_families }};
    font-size: {{ section.settings.card_title_size }}rem;
    font-weight: {{ section.settings.card_title_weight }};
    color: {{ section.settings.card_title_color | default: '#003A6A' }};
    margin-top: 0;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .block-content__card-text {
    font-family: {{ section.settings.card_text_font.family }}, {{ section.settings.card_text_font.fallback_families }};
    font-size: {{ section.settings.card_text_size }}rem;
    font-weight: {{ section.settings.card_text_weight }};
    color: {{ section.settings.card_text_color | default: '#555555' }};
    margin: 0 0 2rem 0;
    line-height: 1.6;
  }

  .block-content__card-bullets ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .block-content__card-bullets ul li {
    font-family: {{ section.settings.card_text_font.family }}, {{ section.settings.card_text_font.fallback_families }};
    font-size: {{ section.settings.card_text_size }}rem;
    font-weight: {{ section.settings.card_text_weight }};
    color: {{ section.settings.card_text_color | default: '#555555' }};
    position: relative;
    padding-left: 2rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .block-content__card-bullets ul li p {
    margin: 0;
  }
  .block-content__card-bullets ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--block-accent);
  }

  .block-content__divider {
    border: none;
    border-top: 1px solid #E2E2E2;
    margin: 2.5rem 0;
    width: 100%;
  }

  .block-content__tags-heading {
    font-family: {{ section.settings.card_text_font.family }}, {{ section.settings.card_text_font.fallback_families }};
    font-size: {{ section.settings.card_text_size }}rem;
    font-weight: {{ section.settings.card_text_weight }};
    color: {{ section.settings.card_text_color | default: '#555555' }};
    margin: 0 0 1.5rem 0;
  }

  .block-content__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .block-content__tag {
    font-family: {{ section.settings.card_text_font.family }}, {{ section.settings.card_text_font.fallback_families }};
    font-size: clamp(1rem, 2vw, {{ section.settings.card_text_size | minus: 0.2 }}rem);
    border: 1px solid;
    border-radius: 50px;
    line-height: 1.2;
    background: transparent;
    transition: all 0.3s ease;
  }
  .block-content__tag:hover {
    background-color: var(--hover-bg) !important;
    color: var(--hover-text) !important;
    border-color: var(--hover-border) !important;
  }

  @keyframes fadeUpStagger {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 768px) {
    .block-content-{{ section.id }} {
      padding: 6rem 5%;
    }
    .block-content__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .block-content__card {
      padding: 3rem 2rem;
    }
  }
{%- endstyle -%}

<section class="block-content-{{ section.id }}" id="BlockContent-{{ section.id }}">
  <div class="block-content__container">
    <div class="block-content__header js-animate-header">
      <h2 class="block-content__title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="block-content__subtitle">{{ section.settings.subtitle | newline_to_br }}</p>
      {%- endif -%}
    </div>

    <div class="block-content__grid">
      {%- for block in section.blocks -%}
        <div class="block-content__card js-animate-card block-{{ block.id }}" style="animation-delay: {{ forloop.index0 | times: 0.15 }}s; --block-accent: {{ block.settings.accent_color | default: section.settings.accent_color }};" {{ block.shopify_attributes }}>
          
          <div class="block-content__card-index" style="{% if section.settings.index_size == 0 %}display: none;{% endif %}">0{{ forloop.index }}</div>
          
          <h3 class="block-content__card-title">{{ block.settings.title }}</h3>
          
          {%- if block.settings.description != blank -%}
            <p class="block-content__card-text">{{ block.settings.description | newline_to_br }}</p>
          {%- endif -%}
          
          {%- if block.settings.bullet_points != blank -%}
            <div class="block-content__card-bullets">
              {{ block.settings.bullet_points }}
            </div>
          {%- endif -%}

          {%- if block.settings.show_divider -%}
            <hr class="block-content__divider">
          {%- endif -%}

          {%- if block.settings.tags_heading != blank -%}
            <p class="block-content__tags-heading">{{ block.settings.tags_heading }}</p>
          {%- endif -%}

          {%- if block.settings.tags_list != blank -%}
            <div class="block-content__tags">
              {% assign tags = block.settings.tags_list | split: ',' %}
              {% for tag in tags %}
                <span class="block-content__tag" style="color: {{ block.settings.tags_text_color }}; border-color: {{ block.settings.tags_border_color }}; background-color: {{ block.settings.tags_bg_color }}; padding: {{ block.settings.tags_padding_y }}px {{ block.settings.tags_padding_x }}px; --hover-bg: {{ block.settings.tags_hover_bg_color }}; --hover-text: {{ block.settings.tags_hover_text_color }}; --hover-border: {{ block.settings.tags_hover_border_color }};">
                  {{ tag | strip }}
                </span>
              {% endfor %}
            </div>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('BlockContent-{{ section.id }}');
    if (!section) return;

    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    };

    const header = section.querySelector('.js-animate-header');
    const cards = section.querySelectorAll('.js-animate-card');

    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    if (header) observer.observe(header);
    cards.forEach(card => observer.observe(card));
  })();
</script>

