{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.slide_font | font_face: font_display: 'swap' }}

  #SlidingProducts-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.pt_desktop }}px 0 {{ section.settings.pb_desktop }}px;
    overflow: hidden;
    position: relative;
  }

  @media screen and (max-width: 749px) {
    #SlidingProducts-{{ section.id }} {
      padding: {{ section.settings.pt_mobile }}px 0 {{ section.settings.pb_mobile }}px;
    }
  }

  .sliding-products__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    position: relative;
  }

  .sliding-products__header {
    text-align: center;
    margin-bottom: 5rem;
    padding: 0 2rem;
  }

  .sliding-products__title {
    margin: 0;
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }} !important;
    font-size: {{ section.settings.heading_size_mobile }}rem !important;
    font-weight: {{ section.settings.heading_weight }} !important;
    color: {{ section.settings.heading_color }} !important;
  }

  @media screen and (min-width: 750px) {
    .sliding-products__title {
      font-size: {{ section.settings.heading_size_desktop }}rem !important;
    }
  }

  /* Slider Logic */
  .sliding-products__track-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding: 12rem 0 6rem; /* Extra space for the arch */
    perspective: 1500px;
  }

  .sliding-products__track {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
    align-items: center;
    transform-style: preserve-3d;
  }

  .sliding-products__slide {
    flex: 0 0 60%;
    margin: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    position: relative;
    backface-visibility: hidden;
  }

  @media screen and (min-width: 750px) {
    .sliding-products__slide {
      flex: 0 0 18%; /* Fits 5 items comfortably */
      margin: 0 1%;
    }
  }

  .sliding-products__img-wrap {
    width: 100%;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    cursor: pointer;
  }

  .sliding-products__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* Detached Info Below */
  .sliding-products__info-bar {
    text-align: center;
    margin-top: 4rem;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 120px;
  }

  .sliding-products__active-title {
    font-family: {{ section.settings.slide_font.family }}, {{ section.settings.slide_font.fallback_families }} !important;
    font-size: 2.8rem;
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    margin: 0 0 2rem;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .sliding-products__active-btn {
    display: inline-flex;
    padding: 1.5rem 4rem;
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.bg_color }};
    text-decoration: none;
    font-size: 1.6rem;
    font-weight: 700;
    border-radius: 50px;
    transition: all 0.4s ease;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .sliding-products__active-btn:hover {
    transform: scale(1.05);
    background: {{ section.settings.accent_color | default: section.settings.heading_color }};
  }

  /* Side Buttons */
  .sliding-products__nav {
    position: absolute;
    top: 40%;
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 4rem;
    pointer-events: none;
    z-index: 50;
    transform: translateY(-50%);
  }

  .sliding-products__btn {
    width: 50px;
    height: 50px;
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.bg_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: auto;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .sliding-products__btn:hover {
    transform: scale(1.1);
  }

  .sliding-products__btn svg { width: 24px; height: 24px; }
{%- endstyle -%}

<section id="SlidingProducts-{{ section.id }}" class="sliding-products">
  <div class="sliding-products__container">
    
    <div class="sliding-products__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="sliding-products__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="sliding-products__track-wrap">
      <div class="sliding-products__track">
        {%- for block in section.blocks -%}
          <div class="sliding-products__slide hamsaa-original" 
               data-title="{{ block.settings.title | escape }}" 
               data-link="{{ block.settings.link | default: '#' }}"
               data-btn="{{ block.settings.btn_label | escape }}"
               {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link | default: '#' }}" class="sliding-products__img-wrap">
              {%- if block.settings.image != blank -%}
                 {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {%- else -%}
                 {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
          </div>
        {%- endfor -%}
      </div>

      <div class="sliding-products__nav">
        <div class="sliding-products__btn hamsaa-prev">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7"/></svg>
        </div>
        <div class="sliding-products__btn hamsaa-next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5l7 7-7 7"/></svg>
        </div>
      </div>
    </div>

    <!-- Detached Smart Button -->
    <div class="sliding-products__info-bar">
      <h3 class="sliding-products__active-title">Product Name</h3>
      <a href="#" class="sliding-products__active-btn">Shop Now</a>
    </div>

  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('SlidingProducts-{{ section.id }}');
    if (!section) return;

    const track = section.querySelector('.sliding-products__track');
    let slides = Array.from(section.querySelectorAll('.sliding-products__slide'));
    const nextBtn = section.querySelector('.hamsaa-next');
    const prevBtn = section.querySelector('.hamsaa-prev');
    const titleEl = section.querySelector('.sliding-products__active-title');
    const btnEl = section.querySelector('.sliding-products__active-btn');
    
    const originalCount = slides.length;
    if (originalCount === 0) return;

    // Cloning for Infinite Loop (clone at both ends)
    const clonesToCreate = Math.max(3, originalCount);
    for(let i=0; i<clonesToCreate; i++) {
        const firstClone = slides[i % originalCount].cloneNode(true);
        const lastClone = slides[(originalCount - 1 - (i % originalCount)) % originalCount].cloneNode(true);
        firstClone.classList.add('is-clone');
        lastClone.classList.add('is-clone');
        track.appendChild(firstClone);
        track.insertBefore(lastClone, track.firstChild);
    }

    // Refresh slides array after cloning
    slides = Array.from(section.querySelectorAll('.sliding-products__slide'));
    let currentIndex = clonesToCreate; // Start at the first original slide
    const intensity = {{ section.settings.u_curve_intensity | default: 80 }};

    function updateSlider(animate = true) {
      if (!animate) track.style.transition = 'none';
      else track.style.transition = 'transform 0.6s cubic-bezier(0.25, 1, 0.5, 1)';

      const containerWidth = section.querySelector('.sliding-products__track-wrap').offsetWidth;
      
      slides.forEach((slide, i) => {
        const distance = Math.abs(i - currentIndex);
        let yOffset = distance * intensity; // Mountain Arc (0 at center, positive goes DOWN)
        let rotation = (i - currentIndex) * -10;
        let scale = 1 - (distance * 0.15);
        let opacity = 1 - (distance * 0.35);

        if (i === currentIndex) {
          yOffset = 0;
          rotation = 0;
          scale = 1.35;
          opacity = 1;
          
          // Update Detached Button
          titleEl.style.opacity = '0';
          btnEl.style.opacity = '0';
          setTimeout(() => {
            titleEl.textContent = slide.dataset.title;
            btnEl.textContent = slide.dataset.btn || 'Shop Now';
            btnEl.href = slide.dataset.link;
            titleEl.style.opacity = '1';
            btnEl.style.opacity = '1';
          }, 200);
        }

        slide.style.transform = `translateY(${yOffset}px) rotateY(${rotation}deg) scale(${scale})`;
        slide.style.opacity = Math.max(0, opacity);
        slide.style.zIndex = 100 - distance;
      });

      const activeSlide = slides[currentIndex];
      const offset = (containerWidth / 2) - (activeSlide.offsetLeft + activeSlide.offsetWidth / 2);
      track.style.transform = `translateX(${offset}px)`;

      if (!animate) {
        // Force reflow
        track.offsetHeight;
        track.style.transition = 'transform 0.6s cubic-bezier(0.25, 1, 0.5, 1)';
      }
    }

    function checkLoop() {
        if (currentIndex >= originalCount + clonesToCreate) {
            currentIndex = clonesToCreate;
            updateSlider(false);
        } else if (currentIndex < clonesToCreate) {
            currentIndex = originalCount + clonesToCreate - 1;
            updateSlider(false);
        }
    }

    nextBtn.addEventListener('click', () => {
      currentIndex++;
      updateSlider();
      setTimeout(checkLoop, 600);
    });

    prevBtn.addEventListener('click', () => {
      currentIndex--;
      updateSlider();
      setTimeout(checkLoop, 600);
    });

    window.addEventListener('resize', () => {
      updateSlider(false);
    });
    
    // Initial Setup
    setTimeout(() => updateSlider(false), 200);

    // Theme Editor Sync
    document.addEventListener('shopify:section:load', () => {
      location.reload(); // Re-initialize clones
    });
  })();
</script>

{% schema %}
{
  "name": "Sliding Products",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "Featured Catalog" },
    { "type": "header", "content": "Typography" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading Font", "default": "assistant_n4" },
    { "type": "range", "id": "heading_size_desktop", "label": "Font Size (Desktop)", "min": 2, "max": 10, "step": 0.5, "unit": "rem", "default": 4.5 },
    { "type": "range", "id": "heading_size_mobile", "label": "Font Size (Mobile)", "min": 2, "max": 6, "step": 0.5, "unit": "rem", "default": 2.5 },
    { "type": "select", "id": "heading_weight", "label": "Font Weight", "options": [{"value":"400","label":"Regular"},{"value":"700","label":"Bold"},{"value":"900","label":"Black"}], "default": "700" },
    { "type": "color", "id": "heading_color", "label": "Primary Color", "default": "#1a1a1a" },
    { "type": "header", "content": "Slide Design" },
    { "type": "font_picker", "id": "slide_font", "label": "Slide Title Font", "default": "assistant_n4" },
    { "type": "range", "id": "image_radius", "label": "Image Border Radius", "min": 0, "max": 100, "step": 5, "default": 20 },
    { "type": "color", "id": "accent_color", "label": "Button Hover Color", "default": "#c5a47e" },
    { "type": "range", "id": "u_curve_intensity", "label": "Arch Depth Intensity", "min": 0, "max": 150, "step": 5, "default": 80 },
    { "type": "header", "content": "Layout Spacing" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "range", "id": "container_width", "label": "Container Width", "min": 1000, "max": 1600, "step": 50, "default": 1400 },
    { "type": "range", "id": "pt_desktop", "label": "Top Padding (Desktop)", "min": 0, "max": 100, "step": 5, "default": 80 },
    { "type": "range", "id": "pb_desktop", "label": "Bottom Padding (Desktop)", "min": 0, "max": 100, "step": 5, "default": 80 },
    { "type": "range", "id": "pt_mobile", "label": "Top Padding (Mobile)", "min": 0, "max": 100, "step": 5, "default": 50 },
    { "type": "range", "id": "pb_mobile", "label": "Bottom Padding (Mobile)", "min": 0, "max": 100, "step": 5, "default": 50 }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Product Image" },
        { "type": "text", "id": "title", "label": "Product Title", "default": "Luxury Essential Oil" },
        { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Link Location" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sliding Products",
      "blocks": [
        { "type": "product", "settings": { "title": "Camphor Oil" } },
        { "type": "product", "settings": { "title": "Wellness Balm" } },
        { "type": "product", "settings": { "title": "Pure Camphor" } },
        { "type": "product", "settings": { "title": "Aroma Diffuser" } },
        { "type": "product", "settings": { "title": "Essential Mist" } }
      ]
    }
  ]
}
{% endschema %}
