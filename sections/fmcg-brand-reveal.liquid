{%- style -%}
  .fmcg-brand-reveal-{{ section.id }} {
    --progress: 0;
    position: relative;
    height: 200vh; /* Scroll distance */
    background: {{ section.settings.bg_color }};
  }

  .fmcg-brand-reveal__sticky {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Shared Layer Styles */
  .fmcg-brand-reveal__layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transition: opacity 0.1s linear; /* Small lag for smoothness */
    will-change: opacity, transform;
  }

  /* Part 1: Split Content Layer */
  .fmcg-brand-reveal__content-layer {
    z-index: 2;
    display: flex;
    flex-direction: column;
    opacity: calc(1 - (var(--progress) * 2)); /* Fades out by 50% scroll */
    pointer-events: {% if section.settings.progress > 0.5 %}none{% else %}auto{% endif %};
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal__content-layer {
      flex-direction: {% if section.settings.layout == 'image_first' %}row{% else %}row-reverse{% endif %};
    }
  }

  .fmcg-brand-reveal__image-part {
    flex: 1;
    height: 50vh;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal__image-part {
      height: 100vh;
      flex: 0 0 {{ section.settings.image_width }}%;
    }
  }

  .fmcg-brand-reveal__image-part img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s ease-out;
    transform: scale(calc(1 + (var(--progress) * 0.2)));
  }

  .fmcg-brand-reveal__text-part {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem;
    background: {{ section.settings.content_bg }};
    text-align: {{ section.settings.text_alignment }};
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal__text-part {
      padding: 6rem;
    }
  }

  .fmcg-brand-reveal__heading {
    font-size: {{ section.settings.heading_size_mobile }}rem;
    font-weight: 900;
    color: {{ section.settings.heading_color }};
    margin-bottom: 2rem;
    line-height: 1.1;
    text-transform: uppercase;
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal__heading {
      font-size: {{ section.settings.heading_size_desktop }}rem;
    }
  }

  .fmcg-brand-reveal__description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin-bottom: 3rem;
    max-width: 600px;
    {% if section.settings.text_alignment == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
  }

  .fmcg-brand-reveal__btn {
    display: inline-flex;
    padding: 1.5rem 3rem;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    text-decoration: none;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: 50px;
    transition: all 0.3s ease;
    align-self: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }

  .fmcg-brand-reveal__btn:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  /* Part 2: Video Layer */
  .fmcg-brand-reveal__video-layer {
    z-index: 1;
    opacity: calc((var(--progress) - 0.2) * 2); /* Starts fading in after 20% scroll */
    background: #000;
  }

  .fmcg-brand-reveal__video-layer video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fmcg-brand-reveal__video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.video_overlay_bg }};
    opacity: {{ section.settings.video_overlay_opacity | divided_by: 100.0 }};
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .fmcg-brand-reveal__video-text {
    font-size: 3rem;
    font-weight: 900;
    color: #fff;
    text-transform: uppercase;
    transform: translateY(calc(30px * (1 - var(--progress))));
    opacity: var(--progress);
  }

{%- endstyle -%}

<div class="fmcg-brand-reveal-{{ section.id }}" id="FmcgBrandReveal-{{ section.id }}">
  <div class="fmcg-brand-reveal__sticky">
    
    <!-- Layer 1: Split Content -->
    <div class="fmcg-brand-reveal__layer fmcg-brand-reveal__content-layer">
      <div class="fmcg-brand-reveal__image-part">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="fmcg-brand-reveal__text-part">
        {%- if section.settings.heading != blank -%}
          <h2 class="fmcg-brand-reveal__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="fmcg-brand-reveal__description">{{ section.settings.description }}</div>
        {%- endif -%}
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_link }}" class="fmcg-brand-reveal__btn">
            {{ section.settings.btn_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Layer 2: Video Reveal -->
    <div class="fmcg-brand-reveal__layer fmcg-brand-reveal__video-layer">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '2000x' }}
      {%- else -%}
         <div style="width:100%; height:100%; background:#111; display:flex; align-items:center; justify:center; color:#fff;">Video Placeholder</div>
      {%- endif -%}

      {%- if section.settings.video_text != blank -%}
        <div class="fmcg-brand-reveal__video-overlay">
          <div class="fmcg-brand-reveal__video-text">{{ section.settings.video_text }}</div>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

<script>
  (function() {
    const section = document.getElementById('FmcgBrandReveal-{{ section.id }}');
    if (!section) return;

    function upgradeReveal() {
      const rect = section.getBoundingClientRect();
      const sectionHeight = section.offsetHeight;
      const viewportHeight = window.innerHeight;
      
      // Calculate progress (0 to 1) based on sticky container path
      // rect.top will go from 0 (at start) to -(sectionHeight - viewportHeight) (at end)
      let progress = -rect.top / (sectionHeight - viewportHeight);
      
      // Clamp between 0 and 1
      progress = Math.max(0, Math.min(1, progress));
      
      section.style.setProperty('--progress', progress.toFixed(4));
    }

    window.addEventListener('scroll', upgradeReveal, { passive: true });
    window.addEventListener('resize', upgradeReveal);
    
    // Initial sync
    upgradeReveal();

    // Re-patching on Shopify Theme Editor events
    document.addEventListener('shopify:section:load', upgradeReveal);
  })();
</script>

{% schema %}
{
  "name": "FMCG Brand Reveal",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Part 1: Intro Content"
    },
    { "type": "image_picker", "id": "image", "label": "Intro Image" },
    { "type": "select", "id": "layout", "label": "Image Position (Desktop)", "options": [{"value":"image_first","label":"Left side"},{"value":"text_first","label":"Right side"}], "default": "image_first" },
    { "type": "range", "id": "image_width", "label": "Image Width (Desktop)", "min": 30, "max": 70, "step": 5, "unit": "%", "default": 50 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Experience the Unseen" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Discover the secrets of our premium FMCG brand builder platform, where quality meets innovation.</p>" },
    { "type": "select", "id": "text_alignment", "label": "Text Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "left" },
    {
      "type": "header",
      "content": "Heading - Desktop"
    },
    { "type": "range", "id": "heading_size", "min": 2, "max": 15, "step": 0.5, "unit": "rem", "label": "Desktop Size", "default": 5.5 },
    { "type": "select", "id": "heading_weight_desktop", "label": "Desktop Weight", "options": [{"value":"400","label":"Normal"},{"value":"700","label":"Bold"},{"value":"900","label":"Black 900"},{"value":"950","label":"Extra Black 950"}], "default": "900" },
    { "type": "range", "id": "heading_line_height", "min": 0.8, "max": 1.5, "step": 0.1, "label": "Desktop Line Height", "default": 1.1 },
    { "type": "range", "id": "heading_letter_spacing", "min": -5, "max": 20, "step": 0.5, "unit": "px", "label": "Desktop Letter Spacing", "default": -1 },
    {
      "type": "header",
      "content": "Heading - Mobile"
    },
    { "type": "range", "id": "heading_size_mobile", "min": 1, "max": 10, "step": 0.5, "unit": "rem", "label": "Mobile Size", "default": 2.5 },
    { "type": "select", "id": "heading_weight_mobile", "label": "Mobile Weight", "options": [{"value":"400","label":"Normal"},{"value":"700","label":"Bold"},{"value":"900","label":"Black 900"},{"value":"950","label":"Extra Black 950"}], "default": "900" },
    { "type": "range", "id": "heading_line_height_mobile", "min": 0.8, "max": 1.5, "step": 0.1, "label": "Mobile Line Height", "default": 1.1 },
    { "type": "range", "id": "heading_letter_spacing_mobile", "min": -5, "max": 10, "step": 0.5, "unit": "px", "label": "Mobile Letter Spacing", "default": -1 },

    
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#333333" },
    { "type": "color", "id": "content_bg", "label": "Content Background", "default": "#ffffff" },
    {
      "type": "header",
      "content": "Call to Action"
    },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Our Story" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    { "type": "color", "id": "btn_bg", "label": "Button Background", "default": "#000000" },
    { "type": "color", "id": "btn_text", "label": "Button Text", "default": "#ffffff" },
    {
      "type": "header",
      "content": "Part 2: Video Reveal"
    },
    { "type": "video", "id": "video", "label": "Reveal Video" },
    { "type": "text", "id": "video_text", "label": "Overlay Text (Scroll Reveal)", "default": "ADDANKI'S VISION" },
    { "type": "color", "id": "video_overlay_bg", "label": "Video Overlay Color", "default": "#000000" },
    { "type": "range", "id": "video_overlay_opacity", "label": "Video Overlay Opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 30 },
    {
      "type": "header",
      "content": "Global Settings"
    },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" }
  ],
  "presets": [
    {
      "name": "FMCG Brand Reveal"
    }
  ]
}
{% endschema %}
