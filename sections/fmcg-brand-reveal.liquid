{%- style -%}
  {{ section.settings.heading_font | font_face: display: 'swap' }}
  {{ section.settings.desc_font | font_face: display: 'swap' }}
  {{ section.settings.vt_font | font_face: display: 'swap' }}

  .fmcg-brand-reveal-{{ section.id }} {
    --progress: 0;
    position: relative;
    height: 200vh; /* Scroll distance */
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.pt_mobile }}px;
    padding-bottom: {{ section.settings.pb_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal-{{ section.id }} {
      padding-top: {{ section.settings.pt_desktop }}px;
      padding-bottom: {{ section.settings.pb_desktop }}px;
    }
  }

  .fmcg-brand-reveal__sticky {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fmcg-brand-reveal__layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transition: opacity 0.1s linear;
    will-change: opacity, transform;
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__content-layer {
    z-index: 2;
    display: flex;
    flex-direction: column;
    opacity: calc(1 - (var(--progress) * 2));
    pointer-events: auto;
    transition: opacity 0.2s ease;
  }

  /* Disable clicks when content is faded out */
  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__content-layer[style*="--progress: 0.6"],
  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__content-layer[style*="--progress: 0.7"],
  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__content-layer[style*="--progress: 0.8"],
  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__content-layer[style*="--progress: 0.9"],
  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__content-layer[style*="--progress: 1.0"] {
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__content-layer {
      flex-direction: {% if section.settings.layout == 'image_first' %}row{% else %}row-reverse{% endif %};
    }
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__image-part {
    flex: 1;
    height: 50vh;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__image-part {
      height: 100vh;
      flex: 0 0 {{ section.settings.image_width }}%;
    }
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__image-part img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s ease-out;
    transform: scale(calc(1 + (var(--progress) * 0.2)));
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__text-part {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem;
    background: {{ section.settings.content_bg }};
    text-align: {{ section.settings.text_alignment }};
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__text-part {
      padding: 6rem;
    }
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__heading {
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }} !important;
    font-size: {{ section.settings.heading_size_mobile }}rem !important;
    font-weight: {{ section.settings.heading_weight | default: '900' }} !important;
    font-style: {{ section.settings.heading_style | default: 'normal' }} !important;
    line-height: {{ section.settings.heading_line_height | default: '1.1' }} !important;
    letter-spacing: {{ section.settings.heading_letter_spacing | default: '0' }}px !important;
    color: {{ section.settings.heading_color }} !important;
    margin-bottom: 2.5rem !important;
    text-transform: {{ section.settings.heading_transform | default: 'uppercase' }} !important;
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__heading {
      font-size: {{ section.settings.heading_size_desktop }}rem !important;
    }
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__description {
    font-family: {{ section.settings.desc_font.family }}, {{ section.settings.desc_font.fallback_families }} !important;
    font-size: {{ section.settings.desc_size_mobile }}px !important;
    font-weight: {{ section.settings.desc_weight | default: '400' }} !important;
    font-style: {{ section.settings.desc_style | default: 'normal' }} !important;
    line-height: 1.6 !important;
    color: {{ section.settings.text_color }} !important;
    margin-bottom: 3rem;
    max-width: 600px;
    {% if section.settings.text_alignment == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__description {
      font-size: {{ section.settings.desc_size_desktop }}px !important;
    }
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__btn {
    display: inline-flex;
    padding: 1.5rem 3rem;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    text-decoration: none !important;
    font-size: {{ section.settings.btn_size_mobile }}px !important;
    font-weight: {{ section.settings.btn_weight | default: '800' }} !important;
    font-style: {{ section.settings.btn_style | default: 'normal' }} !important;
    text-transform: uppercase !important;
    letter-spacing: 1px;
    border-radius: {{ section.settings.btn_radius | default: 50 }}px;
    transition: all 0.3s ease;
    align-self: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__btn {
      font-size: {{ section.settings.btn_size_desktop }}px !important;
    }
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__btn:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    background: {{ section.settings.btn_bg_hover | default: section.settings.btn_bg }};
    color: {{ section.settings.btn_text_hover | default: section.settings.btn_text }};
  }

  /* Part 2: Video Layer */
  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__video-layer {
    z-index: 1;
    opacity: calc((var(--progress) - 0.2) * 2);
    background: #000;
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__video-layer video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.video_overlay_bg }};
    opacity: {{ section.settings.video_overlay_opacity | divided_by: 100.0 }};
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__video-text {
    font-family: {{ section.settings.vt_font.family }}, {{ section.settings.vt_font.fallback_families }} !important;
    font-size: {{ section.settings.vt_size_mobile }}px !important;
    font-weight: {{ section.settings.vt_weight | default: '900' }} !important;
    font-style: {{ section.settings.vt_style | default: 'normal' }} !important;
    color: {{ section.settings.vt_color | default: '#ffffff' }} !important;
    text-transform: uppercase !important;
    transform: translateY(calc(30px * (1 - var(--progress))));
    opacity: var(--progress);
  }

  @media screen and (min-width: 750px) {
    .fmcg-brand-reveal-{{ section.id }} .fmcg-brand-reveal__video-text {
      font-size: {{ section.settings.vt_size_desktop }}px !important;
    }
  }

{%- endstyle -%}

<div class="fmcg-brand-reveal-{{ section.id }}" id="FmcgBrandReveal-{{ section.id }}">
  <div class="fmcg-brand-reveal__sticky">
    
    <div class="fmcg-brand-reveal__layer fmcg-brand-reveal__content-layer">
      <div class="fmcg-brand-reveal__image-part">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="fmcg-brand-reveal__text-part">
        {%- if section.settings.heading != blank -%}
          <h2 class="fmcg-brand-reveal__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="fmcg-brand-reveal__description">{{ section.settings.description }}</div>
        {%- endif -%}
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_link }}" class="fmcg-brand-reveal__btn">
            {{ section.settings.btn_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="fmcg-brand-reveal__layer fmcg-brand-reveal__video-layer">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '2000x' }}
      {%- else -%}
         <div style="width:100%; height:100%; background:#111; display:flex; align-items:center; justify-content:center; color:#fff;">Video Placeholder</div>
      {%- endif -%}

      {%- if section.settings.video_text != blank -%}
        <div class="fmcg-brand-reveal__video-overlay">
          <div class="fmcg-brand-reveal__video-text">{{ section.settings.video_text }}</div>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

<script>
  (function() {
    const section = document.getElementById('FmcgBrandReveal-{{ section.id }}');
    if (!section) return;

    function upgradeReveal() {
      const rect = section.getBoundingClientRect();
      const sectionHeight = section.offsetHeight;
      const viewportHeight = window.innerHeight;
      let progress = -rect.top / (sectionHeight - viewportHeight);
      progress = Math.max(0, Math.min(1, progress));
      section.style.setProperty('--progress', progress.toFixed(4));
    }

    window.addEventListener('scroll', upgradeReveal, { passive: true });
    window.addEventListener('resize', upgradeReveal);
    upgradeReveal();
    document.addEventListener('shopify:section:load', upgradeReveal);
  })();
</script>

