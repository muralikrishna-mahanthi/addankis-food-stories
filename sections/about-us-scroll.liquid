{%- style -%}
  .about-us-split-{{ section.id }} {
    display: block;
    height: {{ section.blocks.size | times: 100 }}vh;
    background-color: {{ section.blocks.first.settings.bg_color | default: '#3A81F4' }};
    transition: background-color 0.8s ease;
  }

  .about-us-split__sticky {
    position: sticky;
    top: 0;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-wrap: wrap;
    background-color: {{ section.blocks.first.settings.bg_color | default: '#3A81F4' }};
    transition: background-color 0.8s ease;
    overflow: hidden;
  }

  .about-us-split__left {
    width: 50%;
    position: relative;
    min-height: 100vh;
  }

  /* Stack imagery absolutely so they crossfade dynamically */
  .about-us-split__media-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s ease, visibility 0.8s ease;
    z-index: 1;
  }
  .about-us-split__media-layer.active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }
  .about-us-split__media-layer img,
  .about-us-split__media-layer .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .about-us-split__media-layer .placeholder-svg {
    background-color: #e5e5e5;
  }

  .about-us-split__right {
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 8%;
  }

  @media screen and (max-width: 749px) {
    .about-us-split-{{ section.id }} {
      height: auto;
    }
    .about-us-split__sticky {
      position: relative;
      height: auto;
      min-height: unset;
      overflow: visible;
    }
    .about-us-split__left,
    .about-us-split__right {
      width: 100%;
    }
    .about-us-split__left {
      height: 50vh;
      min-height: unset;
    }
    .about-us-split__media-layer {
      display: none;
    }
    .about-us-split__media-layer.active {
      display: block;
    }
    .about-us-split__right {
      padding: 4rem 1.5rem;
    }
  }

  /* Pills Base Style */
  .about-us-split__pills {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 3rem; 
  }
  .about-us-split__pill {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    line-height: 1;
    transition: all 0.4s ease;
    cursor: default;
  }
  .about-us-split__pill.active {
    transform: scale(1.1);
  }

  /* Textual Content Stack configured for sliding fade up */
  .about-us-split__content-stack {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
  }

  .about-us-split__content-layer {
    grid-row: 1 / -1;
    grid-column: 1 / -1;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-start;
  }

  .about-us-split__content-layer.active {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
    transform: translateY(0);
  }

  /* Structural base styling */
  .about-us-split__heading {
    margin: 0;
    line-height: 1.05;
  }

  .about-us-split__text {
    margin: 0;
    line-height: 1.5;
  }
  .about-us-split__text p {
    margin: 0 0 1rem 0;
  }
  .about-us-split__text p:last-child {
    margin: 0;
  }

  .about-us-split__btn {
    display: inline-flex;
    text-decoration: none;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    line-height: 1;
    transition: all 0.3s ease;
  }
  .about-us-split__btn:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }

{%- endstyle -%}

<section class="about-us-split-{{ section.id }}" id="AboutUsSplit-{{ section.id }}">
  <div class="about-us-split__sticky">
    
    <div class="about-us-split__left">
      {%- for block in section.blocks -%}
        <div class="about-us-split__media-layer {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'lifestyle-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="about-us-split__right">
      <div class="about-us-split__pills">
        {%- for block in section.blocks -%}
          {{ block.settings.pills_font_family | font_face: display: 'swap' }}
          <style>
            .about-us-split__pill-{{ block.id }} {
              width: {{ block.settings.pills_size }}rem;
              height: {{ block.settings.pills_size }}rem;
              font-size: {{ block.settings.pills_size | divided_by: 2.2 }}rem;
              font-family: {{ block.settings.pills_font_family.family }}, {{ block.settings.pills_font_family.fallback_families }};
              font-weight: {{ block.settings.pills_font_weight }};
              background-color: {{ block.settings.pills_inactive_bg }};
              color: {{ block.settings.pills_inactive_text }};
            }
            .about-us-split__pill-{{ block.id }}.active {
              background-color: {{ block.settings.pills_active_bg }};
              color: {{ block.settings.pills_active_text }};
            }
          </style>
          <div class="about-us-split__pill about-us-split__pill-{{ block.id }} {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
            0{{ forloop.index }}
          </div>
        {%- endfor -%}
      </div>

      <div class="about-us-split__content-stack">
        {%- for block in section.blocks -%}
          {{ block.settings.heading_font_family | font_face: display: 'swap' }}
          {{ block.settings.text_font_family | font_face: display: 'swap' }}
          {{ block.settings.btn_font_family | font_face: display: 'swap' }}
          
          <style>
            .about-us-split__content-layer-{{ block.id }} .about-us-split__heading {
              padding-top: {{ block.settings.heading_padding_top }}px;
              padding-bottom: {{ block.settings.heading_padding_bottom }}px;
              font-family: {{ block.settings.heading_font_family.family }}, {{ block.settings.heading_font_family.fallback_families }};
              font-weight: {{ block.settings.heading_font_weight }};
              font-size: clamp(2rem, 6vw, {{ block.settings.heading_font_size }}rem);
              color: {{ block.settings.heading_text_color }};
            }
            
            .about-us-split__content-layer-{{ block.id }} .about-us-split__text {
              padding-top: {{ block.settings.text_padding_top }}px;
              padding-bottom: {{ block.settings.text_padding_bottom }}px;
              font-family: {{ block.settings.text_font_family.family }}, {{ block.settings.text_font_family.fallback_families }};
              font-weight: {{ block.settings.text_font_weight }};
              font-size: {{ block.settings.text_font_size }}rem;
              color: {{ block.settings.text_color }};
            }
            
            .about-us-split__content-layer-{{ block.id }} .about-us-split__btn-container {
              padding-top: {{ block.settings.btn_padding_top }}px;
              padding-bottom: {{ block.settings.btn_padding_bottom }}px;
            }
            
            .about-us-split__content-layer-{{ block.id }} .about-us-split__btn {
              padding: {{ block.settings.btn_pad_y }}rem {{ block.settings.btn_pad_x }}rem;
              font-family: {{ block.settings.btn_font_family.family }}, {{ block.settings.btn_font_family.fallback_families }};
              font-weight: {{ block.settings.btn_font_weight }};
              font-size: {{ block.settings.btn_font_size }}rem;
              background-color: {{ block.settings.btn_bg_color }};
              color: {{ block.settings.btn_text_color }};
            }
          </style>

          <div class="about-us-split__content-layer about-us-split__content-layer-{{ block.id }} {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" data-bg="{{ block.settings.bg_color }}">
            {%- if block.settings.heading != blank -%}
              <h2 class="about-us-split__heading">{{ block.settings.heading | newline_to_br }}</h2>
            {%- endif -%}
            
            {%- if block.settings.text != blank -%}
              <div class="about-us-split__text">{{ block.settings.text }}</div>
            {%- endif -%}

            {%- if block.settings.btn_text != blank -%}
              <div class="about-us-split__btn-container">
                <a href="{{ block.settings.btn_link | default: '#' }}" class="about-us-split__btn">
                  {{ block.settings.btn_text }}
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
    
  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('AboutUsSplit-{{ section.id }}');
    if (!section) return;

    const stickyLayer = section.querySelector('.about-us-split__sticky');
    const mediaLayers = section.querySelectorAll('.about-us-split__media-layer');
    const contentLayers = section.querySelectorAll('.about-us-split__content-layer');
    const pills = section.querySelectorAll('.about-us-split__pill');
    
    const totalBlocks = {{ section.blocks.size }};
    if (totalBlocks === 0) return;

    function handleScroll() {
      const rect = section.getBoundingClientRect();
      const sectionHeight = section.offsetHeight;
      const viewportHeight = window.innerHeight;
      
      if (sectionHeight <= viewportHeight + 10) return;
      
      let progress = -rect.top / (sectionHeight - viewportHeight);
      progress = Math.max(0, Math.min(0.99, progress));
      
      const activeIndex = Math.floor(progress * totalBlocks);
      
      // Sync transitions between elements
      mediaLayers.forEach(l => l.classList.remove('active'));
      contentLayers.forEach(l => l.classList.remove('active'));
      pills.forEach(p => p.classList.remove('active'));

      if(mediaLayers[activeIndex]) mediaLayers[activeIndex].classList.add('active');
      if(pills[activeIndex]) pills[activeIndex].classList.add('active');

      if(contentLayers[activeIndex]) {
        contentLayers[activeIndex].classList.add('active');
        
        // Dynamic background update
        const bgColor = contentLayers[activeIndex].getAttribute('data-bg');
        if (bgColor && bgColor !== 'rgba(0,0,0,0)') {
           section.style.backgroundColor = bgColor;
           if (stickyLayer) stickyLayer.style.backgroundColor = bgColor;
        }
      }
    }

    if (totalBlocks > 1) {
      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll();
    }
  })();
</script>

