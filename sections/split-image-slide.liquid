{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .split-image-slide {
    position: relative;
    overflow: hidden;
    width: 100%;
    background: {{ section.settings.background_gradient | default: section.settings.background_color }};
  }

  .split-image-slide__container {
    max-width: {{ section.settings.page_width }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
  }

  .split-image-slide__wrapper {
    position: relative;
    height: {{ section.settings.desktop_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .split-image-slide__slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: all {{ section.settings.fade_speed }}ms cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    gap: {{ section.settings.column_gap }}px;
    z-index: 1;
  }

  /* Fade & Scale (Zoom) */
  {%- if section.settings.transition_type == 'zoom' -%}
    .split-image-slide__slide { transform: scale(1.05); }
    .split-image-slide__slide.is-active { transform: scale(1); }
  {%- endif -%}

  /* Slide Animation */
  {%- if section.settings.transition_type == 'slide' -%}
    .split-image-slide__slide { transform: translateX(100%); }
    .split-image-slide__slide.is-active { transform: translateX(0); }
    .split-image-slide__slide.is-prev { transform: translateX(-100%); }
  {%- endif -%}

  .split-image-slide__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }

  .split-image-slide__column {
    position: relative;
    height: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .split-image-slide__column img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .split-image-slide__column:hover img {
    transform: scale(1.08);
  }

  /* Desktop Column Widths */
  .split-image-slide__column--left {
    flex: 0 0 calc({{ section.settings.left_column_width }}% - ({{ section.settings.column_gap }}px * 2 / 3));
  }
  .split-image-slide__column--middle {
    flex: 0 0 calc({{ section.settings.middle_column_width }}% - ({{ section.settings.column_gap }}px * 2 / 3));
  }
  .split-image-slide__column--right {
    flex: 1;
  }

  /* Controls Area (Below Images) */
  .split-image-slide__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-top: 32px;
    min-height: 56px;
  }

  .split-image-slide__nav-group {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    gap: 12px;
    z-index: 10;
  }

  .split-image-slide__nav {
    width: 50px;
    height: 50px;
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    color: {{ section.settings.arrow_color }};
  }

  .split-image-slide__nav:hover {
    background: rgba(0, 0, 0, 0.1);
    transform: scale(1.05);
  }

  .split-image-slide__nav svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Indicators */
  .split-image-slide__indicators {
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  .split-image-slide__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(0,0,0,0.1);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .split-image-slide__dot.is-active {
    background: {{ section.settings.arrow_color | default: '#000' }};
    transform: scale(1.3);
    width: 24px;
    border-radius: 5px;
  }

  /* Mobile Styles */
  @media screen and (max-width: 749px) {
    .split-image-slide__container {
      padding: 0 1rem;
    }

    .split-image-slide__wrapper {
      height: {{ section.settings.mobile_height }}px;
      display: flex; 
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      position: relative;
    }

    .split-image-slide__wrapper::-webkit-scrollbar {
      display: none;
    }

    .split-image-slide__slide {
      position: relative;
      flex: 0 0 100%;
      width: 100%;
      height: 100%;
      opacity: 1;
      visibility: visible;
      transform: none;
      display: flex;
      scroll-snap-align: center;
      transition: transform 0.3s ease;
    }

    .split-image-slide__column--left,
    .split-image-slide__column--right {
      display: none;
    }

    .split-image-slide__column--middle {
      flex: 0 0 100%;
      width: 100%;
      margin: 0;
      border-radius: {{ section.settings.border_radius_mobile }}px;
    }

    .split-image-slide__controls {
      margin-top: 20px;
      flex-direction: column;
      gap: 15px;
    }

    .split-image-slide__nav-group {
      position: static;
      transform: none;
      justify-content: center;
      width: 100%;
    }

    .split-image-slide__nav {
      width: 44px;
      height: 44px;
    }
  }
{%- endstyle -%}

<div class="split-image-slide section-{{ section.id }}-padding" id="SplitImageSlide-{{ section.id }}" data-autoplay="{{ section.settings.autoplay_speed }}">
  <div class="split-image-slide__container">
    <div class="split-image-slide__wrapper" id="Slider-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="split-image-slide__slide {% if forloop.first %}is-active{% endif %}" {{ block.shopify_attributes }} data-index="{{ forloop.index0 }}">
          <div class="split-image-slide__column split-image-slide__column--left">
            {%- if block.settings.image_left != blank -%}
              {{ block.settings.image_left | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 33vw, 100vw' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="split-image-slide__column split-image-slide__column--middle">
            {%- if block.settings.image_middle != blank -%}
              {{ block.settings.image_middle | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 40vw, 100vw' }}
            {%- else -%}
              {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="split-image-slide__column split-image-slide__column--right">
            {%- if block.settings.image_right != blank -%}
              {{ block.settings.image_right | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 33vw, 100vw' }}
            {%- else -%}
              {{ 'collection-3' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="split-image-slide__controls">
        <div class="split-image-slide__indicators">
          {%- for block in section.blocks -%}
            <button class="split-image-slide__dot {% if forloop.first %}is-active{% endif %}" aria-label="Go to slide {{ forloop.index }}" data-index="{{ forloop.index0 }}"></button>
          {%- endfor -%}
        </div>

        <div class="split-image-slide__nav-group">
          <button class="split-image-slide__nav split-image-slide__nav--prev" aria-label="Previous slide">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button class="split-image-slide__nav split-image-slide__nav--next" aria-label="Next slide">
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = '{{ section.id }}';
    const container = document.getElementById(`SplitImageSlide-${sectionId}`);
    if (!container) return;

    const wrapper = container.querySelector('.split-image-slide__wrapper');
    const slides = container.querySelectorAll('.split-image-slide__slide');
    const dots = container.querySelectorAll('.split-image-slide__dot');
    const prevBtn = container.querySelector('.split-image-slide__nav--prev');
    const nextBtn = container.querySelector('.split-image-slide__nav--next');
    
    let currentIndex = 0;
    let interval = null;
    const autoplaySpeed = parseInt(container.dataset.autoplay) * 1000;

    function updateUI(index, direction = 'next') {
      // Update Desktop Classes
      if (window.innerWidth >= 750) {
        slides.forEach((slide, i) => {
          slide.classList.remove('is-active', 'is-prev');
          if (i === index) {
            slide.classList.add('is-active');
          } else if (i === currentIndex) {
            slide.classList.add('is-prev');
          }
        });
      } else {
        // Smoothly scroll on mobile
        const slideWidth = wrapper.offsetWidth;
        wrapper.scrollTo({
          left: slideWidth * index,
          behavior: 'smooth'
        });
      }

      // Update Dots
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === index);
      });
      
      currentIndex = index;
    }

    function goToNext() {
      const nextIndex = (currentIndex + 1) % slides.length;
      updateUI(nextIndex, 'next');
    }

    function goToPrev() {
      const prevIndex = (currentIndex - 1 + slides.length) % slides.length;
      updateUI(prevIndex, 'prev');
    }

    if (nextBtn) nextBtn.addEventListener('click', () => { goToNext(); resetAutoplay(); });
    if (prevBtn) prevBtn.addEventListener('click', () => { goToPrev(); resetAutoplay(); });

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.dataset.index);
        updateUI(index);
        resetAutoplay();
      });
    });

    function startAutoplay() {
      if (autoplaySpeed > 0) {
        interval = setInterval(goToNext, autoplaySpeed);
      }
    }

    function resetAutoplay() {
      clearInterval(interval);
      startAutoplay();
    }

    // Scroll listener for mobile to update dots when swiping
    wrapper.addEventListener('scroll', () => {
      if (window.innerWidth < 750) {
        const slideWidth = wrapper.offsetWidth;
        const newIndex = Math.round(wrapper.scrollLeft / slideWidth);
        if (newIndex !== currentIndex) {
          currentIndex = newIndex;
          dots.forEach((dot, i) => {
            dot.classList.toggle('is-active', i === currentIndex);
          });
        }
      }
    });

    // Pause on hover
    container.addEventListener('mouseenter', () => clearInterval(interval));
    container.addEventListener('mouseleave', () => startAutoplay());

    startAutoplay();
    
    // Theme Editor handling
    if (Shopify.designMode) {
      document.addEventListener('shopify:section:select', () => updateUI(0));
      document.addEventListener('shopify:block:select', (event) => {
        const index = Array.from(slides).indexOf(event.target);
        if (index > -1) updateUI(index);
      });
    }
  });
</script>

{% schema %}
{
  "name": "Split Image Slide",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "range",
      "id": "page_width",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "default": 1400,
      "label": "Page Width"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background Gradient"
    },
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 400,
      "max": 1000,
      "step": 50,
      "default": 700,
      "label": "Section Height (px)"
    },
    {
      "type": "range",
      "id": "left_column_width",
      "min": 10,
      "max": 45,
      "step": 1,
      "default": 25,
      "label": "Left Image Width (%)"
    },
    {
      "type": "range",
      "id": "middle_column_width",
      "min": 25,
      "max": 70,
      "step": 1,
      "default": 50,
      "label": "Middle Image Width (%)"
    },
    {
      "type": "paragraph",
      "content": "Right image fills the remaining space."
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 30,
      "label": "Gap between images (px)"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 32,
      "label": "Image Rounded Corners (px)"
    },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "default": 500,
      "label": "Mobile Height (px)"
    },
    {
      "type": "range",
      "id": "border_radius_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 24,
      "label": "Mobile Rounded Corners (px)"
    },
    {
      "type": "header",
      "content": "Animation & Navigation"
    },
    {
