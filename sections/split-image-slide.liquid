    {
      "type": "select",
      "id": "transition_type",
      "label": "Animation Style",
      "options": [
        { "value": "fade", "label": "Classic Fade" },
        { "value": "zoom", "label": "Fade & Scale" },
        { "value": "slide", "label": "Horizontal Slide" }
      ],
      "default": "zoom"
    },
